---
import Base from '../layouts/Base.astro';
import SmartLink from '../components/SmartLink.astro';

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Green Card Through Marriage 2026: Complete Guide to Every Path",
    "description": "How to get a green card through marriage to a U.S. citizen or LPR — every path explained (K-1, CR-1, AOS), costs, timelines, and exactly what to do first.",
    "url": "https://ldrvisa.org/green-card-through-marriage",
    "dateModified": "2026-04-29",
    "datePublished": "2026-04-29",
    "author": { "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org" },
    "publisher": {
      "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org",
      "logo": { "@type": "ImageObject", "url": "https://ldrvisa.org/favicon.svg" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://ldrvisa.org/green-card-through-marriage" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ldrvisa.org/" },
      { "@type": "ListItem", "position": 2, "name": "Green Card Through Marriage", "item": "https://ldrvisa.org/green-card-through-marriage" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How long does it take to get a green card through marriage?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "It depends on the path. If you marry a U.S. citizen and file for Adjustment of Status inside the U.S., expect 12–24 months. If you use the CR-1 spousal visa (spouse abroad), expect 18–36 months total. If you use the K-1 fiancé visa, expect 12–18 months to enter, then another 12–24 months for Adjustment of Status after marriage — so 24–42 months total to a green card. IR-1 holders (married 2+ years when approved) get a 10-year green card immediately."
        }
      },
      {
        "@type": "Question",
        "name": "Can I get a green card if I married a U.S. citizen abroad?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. The most common path is the CR-1 spousal visa. The U.S. citizen spouse files Form I-130 from the U.S., USCIS approves it, and the National Visa Center processes the case before the foreign spouse attends a consular interview at the U.S. embassy in their home country. Upon entry, the foreign spouse becomes a conditional permanent resident and the green card is mailed within a few weeks."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between a K-1 visa and a CR-1 visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The K-1 fiancé visa is for unmarried couples — you enter the U.S., marry within 90 days, then file for Adjustment of Status. The CR-1 spousal visa is for couples already married — the foreign spouse enters directly as a conditional permanent resident. K-1 is faster to enter the U.S. but requires a second immigration filing (I-485) after marriage. CR-1 is slower overall but grants green card status upon entry."
        }
      },
      {
        "@type": "Question",
        "name": "How much does it cost to get a green card through marriage?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For CR-1 spousal visa: approximately $1,220 in government fees (I-130 $675 + NVC $325 + USCIS immigrant fee $220). For K-1 + Adjustment of Status: approximately $3,285 in government fees (I-129F $675 + K-1 visa $265 + I-485 $1,440 + I-765/I-131 included in I-485 bundle). These are filing fees only — attorney fees, translation, and medical exams add $1,500–$5,000+ depending on complexity."
        }
      },
      {
        "@type": "Question",
        "name": "Can I get a green card through marriage if I am undocumented?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "It depends on how you entered the U.S. If you entered legally (with a valid visa) and overstayed, you may still be eligible to adjust status inside the U.S. after marrying a U.S. citizen. If you entered without inspection (EWI — crossed the border without a visa), Adjustment of Status is generally not available and you may face a 3- or 10-year bar upon departure. Consult an immigration attorney immediately — do not file anything without professional advice in this situation."
        }
      },
      {
        "@type": "Question",
        "name": "Does marrying a U.S. citizen guarantee a green card?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Marriage to a U.S. citizen makes you an 'immediate relative,' which means there is no visa backlog — but you still must prove the marriage is genuine, meet all eligibility requirements, pass background and health checks, and complete the immigration process. A fraudulent marriage attempt is a federal crime. USCIS and consular officers are trained to detect marriages entered for immigration purposes."
        }
      }
    ]
  }
]);
---

<Base
  title="Green Card Through Marriage 2026: Every Path, Cost & Timeline Explained"
  description="How to get a green card through marriage — K-1, CR-1, or Adjustment of Status. Costs, timelines, eligibility, and exactly what to do first. Updated 2026."
  schema={schema}
>

  <!-- Breadcrumb -->
  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="breadcrumb">
        <li><a href="/">Home</a></li>
        <li aria-current="page">Green Card Through Marriage</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="hero-badge">🟢 Permanent Residence Guide</div>
      <h1>Green Card Through Marriage<br/><span>Every Path. Every Cost. 2026.</span></h1>
      <p class="hero-sub">Married to a U.S. citizen or planning to be? Here's the complete picture — which path applies to you, what it costs, how long it takes, and exactly what to do first.</p>

      <!-- Conversion CTA — top of page, highest intent -->
      <div class="hero-cta-block">
        <div class="hcb-main">
          <div class="hcb-text">
            <strong>Not sure which path is right for you?</strong>
            <p>Answer 3 questions and get your personalized roadmap.</p>
          </div>
          <a href="#which-path" class="btn-cta-hero">Find My Path →</a>
        </div>
      </div>

      <div class="stat-bar">
        <div class="sb-item"><span class="sb-val">~500K</span><span class="sb-label">Marriage-based green cards granted per year</span></div>
        <div class="sb-item"><span class="sb-val">3 paths</span><span class="sb-label">K-1, CR-1, or AOS</span></div>
        <div class="sb-item"><span class="sb-val">No cap</span><span class="sb-label">No visa backlog for spouses of citizens</span></div>
        <div class="sb-item"><span class="sb-val">3 years</span><span class="sb-label">To citizenship after green card</span></div>
      </div>
    </div>
  </section>

  <div class="container">
    <div class="content-sidebar-grid">

      <main class="main-col">

        <!-- Overview -->
        <section id="overview" class="content-section">
          <h2>How a Green Card Through Marriage Works</h2>
          <p>Marriage to a U.S. citizen makes the foreign spouse an <strong>immediate relative</strong> — the highest-priority immigrant category. Unlike most other green card categories, there is no annual cap and no waiting list for immediate relatives. That means once you're approved, there's no line to wait in.</p>
          <p>However, "no backlog" doesn't mean "fast." The process still involves USCIS petition review, document collection, background checks, and either a consular interview (if abroad) or an interview at a USCIS field office (if already in the U.S.). Total timelines range from 12 months to 3+ years depending on your situation.</p>

          <div class="alert-box alert-info">
            <div class="alert-icon">⚖️</div>
            <div>
              <strong>LPR petitioner? Different rules apply.</strong>
              <p>If the petitioner is a Lawful Permanent Resident (green card holder) — not a U.S. citizen — the foreign spouse files under the F2A preference category, which <em>does</em> have an annual cap and can have a wait of 1–3 years before a visa number is available. This guide focuses primarily on spouses of U.S. citizens.</p>
            </div>
          </div>
        </section>

        <!-- Which path decision tree -->
        <section id="which-path" class="content-section">
          <h2>Which Path Is Right for You?</h2>
          <p>Your situation determines which immigration path to take. There are three main routes to a green card through marriage — the right one depends on where you are now, whether you're married, and how quickly you need to be in the U.S.</p>

          <div class="path-decision">
            <div class="pd-question">
              <div class="pd-q-icon">❓</div>
              <strong>Where is the foreign spouse right now?</strong>
            </div>
            <div class="pd-branches">
              <div class="pd-branch pd-branch-us">
                <div class="pd-branch-label">Already inside the U.S.</div>
                <div class="pd-branch-sub">With a valid visa or visa waiver entry</div>
                <div class="pd-result">
                  <div class="pd-result-badge">Best path:</div>
                  <div class="pd-result-title">Adjustment of Status (I-485)</div>
                  <div class="pd-result-desc">Marry first, then file I-485 to adjust status without leaving. Faster than consular processing. No departure required. Work permit available while pending.</div>
                  <a href="#path-aos" class="pd-result-link">See AOS details →</a>
                </div>
              </div>
              <div class="pd-branch pd-branch-abroad">
                <div class="pd-branch-label">Outside the U.S.</div>
                <div class="pd-branch-sub">Living in their home country</div>
                <div class="pd-sub-question">Are you married yet?</div>
                <div class="pd-sub-branches">
                  <div class="pd-sub-branch">
                    <div class="pd-sub-label">✅ Already married</div>
                    <div class="pd-result pd-result-cr1">
                      <div class="pd-result-badge">Best path:</div>
                      <div class="pd-result-title">CR-1 Spousal Visa</div>
                      <div class="pd-result-desc">File I-130 from the U.S. Spouse enters as a conditional permanent resident. Green card mailed on arrival. One process instead of two.</div>
                      <a href="#path-cr1" class="pd-result-link">See CR-1 details →</a>
                    </div>
                  </div>
                  <div class="pd-sub-branch">
                    <div class="pd-sub-label">💍 Not married yet</div>
                    <div class="pd-result pd-result-k1">
                      <div class="pd-result-badge">Best path:</div>
                      <div class="pd-result-title">K-1 Fiancé Visa</div>
                      <div class="pd-result-desc">Enter the U.S. on a K-1 visa, marry within 90 days, then file for Adjustment of Status. Faster initial entry, but two separate processes total.</div>
                      <a href="#path-k1" class="pd-result-link">See K-1 details →</a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Path comparison table -->
        <section id="comparison" class="content-section">
          <h2>Side-by-Side: K-1 vs CR-1 vs AOS</h2>

          <div class="comparison-table-wrap">
            <table class="comparison-table">
              <thead>
                <tr>
                  <th></th>
                  <th class="th-k1">K-1 Fiancé Visa</th>
                  <th class="th-cr1">CR-1 Spousal Visa</th>
                  <th class="th-aos">Adjustment of Status</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td class="row-label">Who can use it</td>
                  <td>Unmarried couples — abroad</td>
                  <td>Married couples — abroad</td>
                  <td>Married couples — inside U.S.</td>
                </tr>
                <tr>
                  <td class="row-label">Entry status</td>
                  <td>Nonimmigrant (K-1 visa)</td>
                  <td>Conditional permanent resident</td>
                  <td>Already in the U.S.</td>
                </tr>
                <tr>
                  <td class="row-label">Time to enter U.S.</td>
                  <td>12–18 months</td>
                  <td>18–36 months</td>
                  <td>Already here</td>
                </tr>
                <tr>
                  <td class="row-label">Time to green card</td>
                  <td class="cell-warn">24–42 months total</td>
                  <td class="cell-ok">18–36 months total</td>
                  <td class="cell-ok">12–24 months</td>
                </tr>
                <tr>
                  <td class="row-label">Green card type on entry</td>
                  <td>None — must file I-485</td>
                  <td class="cell-ok">CR-1 (2-year) or IR-1 (10-year)</td>
                  <td>10-year after approval</td>
                </tr>
                <tr>
                  <td class="row-label">Must marry within</td>
                  <td class="cell-warn">90 days of entry</td>
                  <td>Already married ✓</td>
                  <td>Already married ✓</td>
                </tr>
                <tr>
                  <td class="row-label">Work authorization while pending</td>
                  <td>EAD after I-485 filing (~6 mo)</td>
                  <td class="cell-ok">Immediately upon entry</td>
                  <td>EAD after I-485 filing (~6 mo)</td>
                </tr>
                <tr>
                  <td class="row-label">Can travel during process</td>
                  <td>After Advance Parole issued</td>
                  <td class="cell-ok">Yes, with green card</td>
                  <td>After Advance Parole issued</td>
                </tr>
                <tr>
                  <td class="row-label">Approx. government fees</td>
                  <td class="cell-warn">~$3,285 total</td>
                  <td>~$1,220 total</td>
                  <td>~$2,115 total</td>
                </tr>
                <tr>
                  <td class="row-label">I-751 to remove conditions</td>
                  <td>Yes — after 2 years</td>
                  <td>Yes — after 2 years (unless IR-1)</td>
                  <td>Yes — after 2 years</td>
                </tr>
                <tr>
                  <td class="row-label">Citizenship eligible</td>
                  <td>After 3 years of LPR</td>
                  <td>After 3 years of LPR</td>
                  <td>After 3 years of LPR</td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Conversion CTA after comparison — high intent moment -->
          <div class="mid-cta-block">
            <div class="mcb-content">
              <div class="mcb-icon">📋</div>
              <div>
                <strong>See the complete process for your path</strong>
                <p>Choose your situation below for a step-by-step breakdown with exact forms, fees, and timelines.</p>
              </div>
            </div>
            <div class="mcb-links">
              <SmartLink href="/k1-visa" class="mcb-btn mcb-k1">K-1 Guide →</SmartLink>
              <SmartLink href="/cr1-visa" class="mcb-btn mcb-cr1">CR-1 Guide →</SmartLink>
              <SmartLink href="/adjustment-of-status" class="mcb-btn mcb-aos">AOS Guide →</SmartLink>
            </div>
          </div>
        </section>

        <!-- Path 1: AOS -->
        <section id="path-aos" class="content-section">
          <h2>Path 1 — Adjustment of Status (Already in the U.S.)</h2>
          <div class="path-tag path-tag-aos">Best for: couples where the foreign spouse is already in the U.S. on any valid visa</div>

          <p>Adjustment of Status (AOS) lets a foreign national already inside the U.S. change their immigration status to permanent resident without leaving the country. For spouses of U.S. citizens, this is usually the fastest and most convenient path.</p>

          <div class="process-steps">
            <div class="ps-item">
              <div class="ps-num">1</div>
              <div>
                <h3>Get married</h3>
                <p>Legal marriage in any U.S. state. Obtain a certified marriage certificate — you'll need multiple certified copies.</p>
              </div>
            </div>
            <div class="ps-item">
              <div class="ps-num">2</div>
              <div>
                <h3>File the AOS package</h3>
                <p>Submit I-130 + I-485 + I-864 + I-765 + I-131 simultaneously. As of 2024–2026, USCIS accepts concurrent filing for immediate relatives. Total fee: ~$2,115.</p>
              </div>
            </div>
            <div class="ps-item">
              <div class="ps-num">3</div>
              <div>
                <h3>Biometrics appointment</h3>
                <p>USCIS schedules a biometrics appointment at your local Application Support Center (ASC). Fingerprints and photo taken. ~1–3 months after filing.</p>
              </div>
            </div>
            <div class="ps-item">
              <div class="ps-num">4</div>
              <div>
                <h3>EAD and Advance Parole issued</h3>
                <p>Approximately 3–8 months after filing, you receive a combo card (EAD + Advance Parole) allowing you to work and travel while your I-485 is pending.</p>
              </div>
            </div>
            <div class="ps-item">
              <div class="ps-num">5</div>
              <div>
                <h3>AOS interview</h3>
                <p>Most couples are scheduled for an interview at a USCIS field office. Both spouses attend. Officer reviews the relationship and confirms eligibility. ~8–20 months after filing.</p>
              </div>
            </div>
            <div class="ps-item">
              <div class="ps-num">6</div>
              <div>
                <h3>Green card approved and mailed</h3>
                <p>Upon approval, the 2-year conditional green card is mailed. File I-751 ~21 months later to remove conditions and receive your 10-year card.</p>
              </div>
            </div>
          </div>

          <div class="path-cta-box">
            <div class="pcb-text">
              <strong>📋 Full AOS guide</strong>
              <p>Forms, documents, fees, interview prep, and common mistakes — all in one place.</p>
            </div>
            <SmartLink href="/adjustment-of-status" class="pcb-btn">Read the Complete AOS Guide →</SmartLink>
          </div>
        </section>

        <!-- Path 2: CR-1 -->
        <section id="path-cr1" class="content-section">
          <h2>Path 2 — CR-1 Spousal Visa (Married, Abroad)</h2>
          <div class="path-tag path-tag-cr1">Best for: couples already married where the foreign spouse lives outside the U.S.</div>

          <p>The CR-1 (Conditional Resident) spousal visa allows the foreign spouse to enter the U.S. directly as a conditional permanent resident. It's a single immigration process — no second filing after arrival (other than I-751 later to remove conditions).</p>

          <div class="process-steps">
            <div class="ps-item">
              <div class="ps-num">1</div>
              <div>
                <h3>Petitioner files I-130</h3>
                <p>U.S. citizen files I-130 (Petition for Alien Relative) + I-130A with USCIS. Fee: $675. Processing: ~12–18 months.</p>
              </div>
            </div>
            <div class="ps-item">
              <div class="ps-num">2</div>
              <div>
                <h3>NVC processing</h3>
                <p>After USCIS approval, case transfers to the National Visa Center. Both parties submit financial documents (I-864), civil documents, and the DS-260 online application. NVC schedules the consular interview. ~1–4 months.</p>
              </div>
            </div>
            <div class="ps-item">
              <div class="ps-num">3</div>
              <div>
                <h3>Medical exam</h3>
                <p>Foreign spouse completes a medical exam with a USCIS-approved panel physician in their country. Results sealed for the interview.</p>
              </div>
            </div>
            <div class="ps-item">
              <div class="ps-num">4</div>
              <div>
                <h3>Consular interview</h3>
                <p>Foreign spouse attends the interview at the U.S. embassy or consulate with a full document package. Officer determines eligibility and issues the visa.</p>
              </div>
            </div>
            <div class="ps-item">
              <div class="ps-num">5</div>
              <div>
                <h3>Enter U.S. — green card mailed</h3>
                <p>Upon entry, CBP stamps the passport. The green card (Form I-551) is mailed to the U.S. address within 2–4 weeks. Pay the $220 USCIS Immigrant Fee at pay.gov.</p>
              </div>
            </div>
          </div>

          <div class="path-cta-box">
            <div class="pcb-text">
              <strong>📋 Full CR-1 guide</strong>
              <p>Complete walkthrough including I-130, NVC, consular interview, and what happens after arrival.</p>
            </div>
            <SmartLink href="/cr1-visa" class="pcb-btn">Read the Complete CR-1 Guide →</SmartLink>
          </div>
        </section>

        <!-- Path 3: K-1 -->
        <section id="path-k1" class="content-section">
          <h2>Path 3 — K-1 Fiancé Visa (Not Married Yet, Abroad)</h2>
          <div class="path-tag path-tag-k1">Best for: engaged couples where the fiancé(e) lives outside the U.S. and wants to marry in the U.S.</div>

          <p>The K-1 visa allows an engaged foreign national to enter the U.S. specifically to marry their U.S. citizen petitioner. It moves faster to initial U.S. entry than the CR-1, but requires a second immigration filing (Adjustment of Status) after marriage — making it a two-stage process overall.</p>

          <div class="process-steps">
            <div class="ps-item">
              <div class="ps-num">1</div>
              <div>
                <h3>File I-129F (K-1 petition)</h3>
                <p>U.S. citizen files Form I-129F with USCIS. Fee: $675. Processing: 7–14 months. Couple must have met in person within 2 years.</p>
              </div>
            </div>
            <div class="ps-item">
              <div class="ps-num">2</div>
              <div>
                <h3>NVC transfer + consular interview</h3>
                <p>Case transfers to NVC, then to the embassy. Fiancé(e) attends interview, submits medical exam and supporting documents. ~2–4 months after USCIS approval.</p>
              </div>
            </div>
            <div class="ps-item">
              <div class="ps-num">3</div>
              <div>
                <h3>Enter U.S. and marry within 90 days</h3>
                <p>The K-1 visa is a 90-day single-entry visa. The couple must marry before the visa expires. There is no extension.</p>
              </div>
            </div>
            <div class="ps-item">
              <div class="ps-num">4</div>
              <div>
                <h3>File Adjustment of Status (I-485)</h3>
                <p>After marriage, file the AOS package: I-485 + I-864 + I-765 + I-131. This is a separate process from the K-1. Total additional fee: ~$2,610. Processing: 12–24 months.</p>
              </div>
            </div>
            <div class="ps-item">
              <div class="ps-num">5</div>
              <div>
                <h3>Receive conditional green card</h3>
                <p>After AOS approval, receive the 2-year conditional green card. File I-751 at the 21-month mark to remove conditions and get the full 10-year card.</p>
              </div>
            </div>
          </div>

          <div class="path-cta-box">
            <div class="pcb-text">
              <strong>📋 Full K-1 guide</strong>
              <p>I-129F petition, consular interview, 90-day window, and AOS after marriage — complete breakdown.</p>
            </div>
            <SmartLink href="/k1-visa" class="pcb-btn">Read the Complete K-1 Guide →</SmartLink>
          </div>
        </section>

        <!-- Full cost breakdown -->
        <section id="costs" class="content-section">
          <h2>Full Cost Breakdown — Every Path</h2>
          <p>Immigration fees add up fast. Here's every government filing fee, plus estimates for common out-of-pocket costs:</p>

          <div class="cost-tables">
            <div class="cost-block">
              <div class="cost-header cost-k1-h">K-1 + AOS Path</div>
              <table class="info-table">
                <tbody>
                  <tr><td>Form I-129F (K-1 petition)</td><td class="cost-val">$675</td></tr>
                  <tr><td>MRV visa fee (K-1 interview)</td><td class="cost-val">$265</td></tr>
                  <tr><td>Form I-485 (AOS)</td><td class="cost-val">$1,440</td></tr>
                  <tr><td>I-765 EAD + I-131 AP (included in I-485)</td><td class="cost-val">$0</td></tr>
                  <tr><td>Form I-131A (if needed)</td><td class="cost-val">$575</td></tr>
                  <tr class="cost-subtotal"><td><strong>Government fees subtotal</strong></td><td class="cost-val"><strong>~$3,285</strong></td></tr>
                  <tr class="cost-extra"><td>Medical exam (varies by country)</td><td class="cost-val">$200–$500</td></tr>
                  <tr class="cost-extra"><td>Document translations</td><td class="cost-val">$100–$400</td></tr>
                  <tr class="cost-extra"><td>Attorney fees (if used)</td><td class="cost-val">$2,000–$5,000</td></tr>
                  <tr class="cost-total"><td><strong>Estimated total</strong></td><td class="cost-val"><strong>$5,500–$9,000+</strong></td></tr>
                </tbody>
              </table>
            </div>

            <div class="cost-block">
              <div class="cost-header cost-cr1-h">CR-1 Path</div>
              <table class="info-table">
                <tbody>
                  <tr><td>Form I-130 (petition)</td><td class="cost-val">$675</td></tr>
                  <tr><td>NVC immigrant visa fee</td><td class="cost-val">$325</td></tr>
                  <tr><td>USCIS Immigrant Fee (on entry)</td><td class="cost-val">$220</td></tr>
                  <tr><td>Form I-751 (remove conditions)</td><td class="cost-val">$750</td></tr>
                  <tr class="cost-subtotal"><td><strong>Government fees subtotal</strong></td><td class="cost-val"><strong>~$1,970</strong></td></tr>

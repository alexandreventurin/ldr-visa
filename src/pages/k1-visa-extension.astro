---
import Base from '../layouts/Base.astro';
import SmartLink from '../components/SmartLink.astro';

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "K-1 Visa Extension: Can You Extend the 90-Day Period?",
    "description": "The hard truth about K-1 visa extensions in 2026 — why USCIS doesn't grant them, what your real options are if the 90 days runs out, and how to protect your status.",
    "url": "https://ldrvisa.org/k1-visa-extension",
    "dateModified": "2026-04-30",
    "datePublished": "2026-04-30",
    "author": { "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org" },
    "publisher": {
      "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org",
      "logo": { "@type": "ImageObject", "url": "https://ldrvisa.org/favicon.svg" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://ldrvisa.org/k1-visa-extension" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ldrvisa.org/" },
      { "@type": "ListItem", "position": 2, "name": "K-1 Visa", "item": "https://ldrvisa.org/k1-visa" },
      { "@type": "ListItem", "position": 3, "name": "K-1 Visa Extension", "item": "https://ldrvisa.org/k1-visa-extension" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Can you extend a K-1 fiancé visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. The K-1 visa cannot be extended. USCIS does not grant extensions of the 90-day authorized stay period. Once you enter the U.S. on a K-1 visa, you must either marry your petitioner within 90 days and file for Adjustment of Status, or depart the U.S. before day 90. There is no legal mechanism to extend the K-1 period."
        }
      },
      {
        "@type": "Question",
        "name": "What happens if you don't marry within 90 days on a K-1 visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If you don't marry within 90 days, your K-1 visa status expires and you are required to leave the U.S. immediately. Staying beyond day 90 without marrying accrues unlawful presence, which can trigger a 3-year or 10-year bar on re-entering the U.S. You cannot file for Adjustment of Status after the 90 days without first marrying."
        }
      },
      {
        "@type": "Question",
        "name": "Can you change status from K-1 to a tourist visa or B-2?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Generally, no. USCIS considers K-1 visa holders to have entered with 'preconceived intent' to marry and remain in the U.S. Changing status to B-2 tourist visa is typically denied because USCIS views it as an attempt to circumvent the K-1 marriage requirement. Filing for Adjustment of Status after the 90 days (but without marrying) is also not permitted."
        }
      },
      {
        "@type": "Question",
        "name": "What if you marry after day 90 but before leaving the U.S.?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If you marry after the 90-day K-1 period expires but while still in the U.S., you may be ineligible to file for Adjustment of Status because your authorized stay has ended. You would likely need to leave the U.S. and apply for a CR-1 or IR-1 immigrant visa from abroad. Consult an immigration attorney immediately in this situation."
        }
      },
      {
        "@type": "Question",
        "name": "Can you leave the U.S. and re-enter on a K-1 visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. The K-1 visa is a single-entry visa. Once you enter the U.S., the K-1 visa is used. If you leave the U.S. before marrying, your K-1 visa is no longer valid and you cannot re-enter on it. You would need to apply for a new K-1 visa or an immigrant visa if you are married."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between K-1 visa validity and the 90-day period?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "These are two separate things. The K-1 visa stamp has a validity period (usually 6 months) during which you can use it to enter the U.S. The 90-day authorized stay period begins when you enter the U.S. — this is the period within which you must marry. Even if your visa stamp still shows as 'valid,' once you've entered, the clock is the 90-day stay period, not the visa stamp validity."
        }
      }
    ]
  }
]);
---


---
import Base from '../layouts/Base.astro';
import SmartLink from '../components/SmartLink.astro';

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "CR-1 Visa Processing Time 2026: Complete Timeline by Stage",
    "description": "Current CR-1 spousal visa processing times for 2026 — USCIS I-130, NVC processing, embassy interview wait times, and total timeline.",
    "url": "https://ldrvisa.org/cr1-visa-processing-time",
    "dateModified": "2026-04-28",
    "datePublished": "2026-04-28",
    "author": { "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org" },
    "publisher": {
      "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org",
      "logo": { "@type": "ImageObject", "url": "https://ldrvisa.org/favicon.svg" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://ldrvisa.org/cr1-visa-processing-time" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ldrvisa.org/" },
      { "@type": "ListItem", "position": 2, "name": "CR-1 Visa", "item": "https://ldrvisa.org/cr1-visa" },
      { "@type": "ListItem", "position": 3, "name": "Processing Time", "item": "https://ldrvisa.org/cr1-visa-processing-time" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How long does the CR-1 visa take in 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The total CR-1 spousal visa process takes approximately 18–24 months in 2026. USCIS takes 12–18 months to approve the I-130 petition, NVC processing adds 3–6 months for fee payment and document submission, and the embassy interview and visa issuance adds 1–3 months depending on the country."
        }
      },
      {
        "@type": "Question",
        "name": "How long does USCIS take to process Form I-130 for a CR-1 visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "USCIS is currently processing Form I-130 for spouses of U.S. citizens in approximately 12–18 months as of April 2026. Times vary by filing location — the Chicago Lockbox and Dallas Lockbox route cases to different service centers. Always verify current times at egov.uscis.gov/processing-times."
        }
      },
      {
        "@type": "Question",
        "name": "How long does NVC processing take for a CR-1 visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "NVC processing for a CR-1 visa typically takes 3–6 months. This includes the time to pay the immigrant visa fee and Affidavit of Support fee (1–4 weeks), upload and submit all required documents (2–6 weeks), NVC review of the package (4–12 weeks), and interview scheduling after case completion (2–6 weeks)."
        }
      },
      {
        "@type": "Question",
        "name": "Which countries have the fastest CR-1 interview scheduling?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Countries with lower visa volume and well-staffed embassies schedule interviews fastest. Canada, Australia, Germany, South Korea, and the United Kingdom typically schedule within 1–2 months of NVC completion. High-volume countries like Mexico, the Philippines, India, and Brazil have longer embassy queues of 2–4 months or more."
        }
      },
      {
        "@type": "Question",
        "name": "What causes CR-1 visa delays?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Common causes of CR-1 delays include: a Request for Evidence (RFE) from USCIS adding 3–6 months, missing or incomplete documents in the NVC package, name check and security clearance holds, embassy appointment backlogs at high-volume posts, country-based visa quotas (Immediate Relatives are exempt but backlogs at NVC can still vary), and incomplete or inconsistent NVC submissions requiring resubmission."
        }
      },
      {
        "@type": "Question",
        "name": "How can I speed up my CR-1 visa processing?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "There is no premium processing for I-130. To minimize delays: file a complete and well-documented I-130 from day one, respond promptly to any USCIS RFE, submit all NVC documents correctly and completely in one package, and monitor your case at my.uscis.gov and ceac.state.gov. If outside the published processing time, contact your U.S. Congressional representative for a formal inquiry."
        }
      }
    ]
  }
]);
---
<Base
  title="CR-1 Visa Processing Time 2026: Complete Timeline by Stage"
  description="Current CR-1 spousal visa processing times for 2026 — USCIS I-130, NVC processing, embassy interview wait times, and total timeline."
  canonical="https://ldrvisa.org/cr1-visa-processing-time"
  ogType="article"
  schema={schema}
>

<style>

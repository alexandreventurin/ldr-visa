    { id: 'overview',    label: 'AOS Timeline Overview' },
    { id: 'by-stage',    label: 'Stage-by-Stage Breakdown' },
    { id: 'by-office',   label: 'Times by Field Office' },
    { id: 'ead',         label: 'EAD & Advance Parole' },
    { id: 'delays',      label: 'What Causes Delays' },

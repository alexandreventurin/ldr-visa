---
import Base from '../layouts/Base.astro';

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Affidavit of Support (I-864): Income Requirements & Complete Guide for 2026",
    "description": "Everything about Form I-864 — 2026 income requirements, poverty guidelines, joint sponsors, common mistakes, and a step-by-step filing guide.",
    "url": "https://ldrvisa.org/affidavit-of-support",
    "dateModified": "2026-04-27",
    "datePublished": "2026-04-27",
    "author": { "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org" },
    "publisher": {
      "@type": "Organization",
      "name": "LDR Visa",
      "url": "https://ldrvisa.org",
      "logo": { "@type": "ImageObject", "url": "https://ldrvisa.org/favicon.svg" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://ldrvisa.org/affidavit-of-support" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ldrvisa.org" },
      { "@type": "ListItem", "position": 2, "name": "Affidavit of Support", "item": "https://ldrvisa.org/affidavit-of-support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much income is required for the Affidavit of Support in 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "In 2026, the sponsor must earn at least 125% of the federal poverty guideline for their household size. For a household of 2 (sponsor + immigrant), that is $31,937/year. For a household of 3, it is $40,188/year. For a household of 4, it is $48,438/year."
        }
      },
      {
        "@type": "Question",
        "name": "What happens if I don't meet the income requirement?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You can use a joint sponsor — a second person who also signs an I-864 and meets the income requirement independently. The joint sponsor takes on equal legal responsibility. You can also combine income with a household member by filing Form I-864A."
        }
      },
      {
        "@type": "Question",
        "name": "Is the Affidavit of Support legally binding?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. By signing Form I-864, the sponsor makes a legally enforceable contract with the U.S. government to support the immigrant at 125% of the poverty level. This obligation lasts until the immigrant becomes a U.S. citizen, has 40 qualifying work quarters, leaves the U.S. permanently, or dies."
        }
      },
      {
        "@type": "Question",
        "name": "Can I use assets instead of income for the Affidavit of Support?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. If your income falls short, you can supplement with assets worth at least 5 times the income shortfall (3 times for a U.S. citizen sponsoring a spouse or child). Assets include savings accounts, stocks, bonds, and real estate equity (minus mortgage)."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between I-864 and I-134?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Form I-864 is the legally binding Affidavit of Support used for immigrant visas (CR-1, IR-1) and adjustment of status. Form I-134 is a declaration of financial support used for some nonimmigrant visa purposes, including at the K-1 embassy interview. I-134 is not legally binding in the same way as I-864."
        }
      },
      {
        "@type": "Question",
        "name": "How long does the Affidavit of Support obligation last?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The I-864 obligation ends when the immigrant: becomes a U.S. citizen, accumulates 40 qualifying quarters of work (about 10 years), permanently departs the U.S., or dies. Divorce does NOT end the obligation."
        }
      }
    ]
  }
]);

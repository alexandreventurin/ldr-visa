  .tl-stage:last-child { border-right: none; }
  .tl-stage::after { content: "›"; position: absolute; right: -0.6rem; top: 50%; transform: translateY(-50%); color: var(--color-muted); font-size: 1.2rem; z-index: 1; }
  .tl-stage:last-child::after { display: none; }
  .tl-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-muted); margin-bottom: 0.3rem; }
  .tl-time { font-size: 1.1rem; font-weight: 800; color: var(--color-accent); }
  .tl-sublabel { font-size: 0.75rem; color: var(--color-muted); margin-top: 0.2rem; }
  @media(max-width: 600px){ .tl-stages { flex-direction: column; } .tl-stage::after { display: none; } }

  .content-wrap { max-width: 1100px; margin: 0 auto; padding: 3rem 1.5rem; display: grid; grid-template-columns: 1fr 300px; gap: 3rem; align-items: start; }
  @media(max-width: 860px){ .content-wrap { grid-template-columns: 1fr; } .sidebar { display: none; } }
  .main-content { min-width: 0; }
  .sidebar { position: sticky; top: 5rem; }

  .section { margin-bottom: 3rem; }
  .section h2 { font-size: 1.5rem; font-weight: 700; margin: 0 0 1rem; padding-bottom: 0.5rem; border-bottom: 2px solid var(--color-accent); }
  .section h3 { font-size: 1.1rem; font-weight: 700; margin: 1.5rem 0 0.5rem; }
  .section p { color: var(--color-text); line-height: 1.8; margin: 0.75rem 0; }
  .section ul { margin: 0.75rem 0 0.75rem 1.5rem; color: var(--color-text); line-height: 1.9; }

  /* Stage cards */
  .stage-card { border: 1px solid var(--color-border); border-radius: 12px; margin-bottom: 1.5rem; overflow: hidden; }

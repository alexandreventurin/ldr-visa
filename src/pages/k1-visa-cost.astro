---
import Base from '../layouts/Base.astro';
import SmartLink from '../components/SmartLink.astro';

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "K-1 Visa Cost 2026: Every Fee From I-129F to Green Card",
    "description": "The complete K-1 fiancé visa cost breakdown for 2026 — every government fee, medical exam, translation, and attorney cost from petition to green card. No hidden numbers.",
    "url": "https://ldrvisa.org/k1-visa-cost",
    "dateModified": "2026-04-29",
    "datePublished": "2026-04-29",
    "author": { "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org" },
    "publisher": {
      "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org",
      "logo": { "@type": "ImageObject", "url": "https://ldrvisa.org/favicon.svg" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://ldrvisa.org/k1-visa-cost" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ldrvisa.org/" },
      { "@type": "ListItem", "position": 2, "name": "K-1 Visa", "item": "https://ldrvisa.org/k1-visa" },
      { "@type": "ListItem", "position": 3, "name": "K-1 Visa Cost", "item": "https://ldrvisa.org/k1-visa-cost" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does a K-1 visa cost in 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The K-1 visa itself costs $940 in government fees: $675 for Form I-129F and $265 for the MRV (Machine Readable Visa) fee paid at the embassy. However, to complete the full process from fiancé visa to green card, total government fees reach approximately $3,285. Add $500–$1,200 for medical exams, $100–$400 for translations, and $2,000–$6,000+ for an immigration attorney, and couples typically spend $5,000–$10,000+ from start to green card."
        }
      },
      {
        "@type": "Question",
        "name": "What is the I-129F filing fee?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Form I-129F filing fee is $675 as of 2026. This is the fee paid to USCIS when the U.S. citizen petitioner files the K-1 fiancé visa petition. The fee is non-refundable even if the petition is denied. It must be paid by check or money order payable to 'U.S. Department of Homeland Security,' or online through the USCIS portal."
        }
      },
      {
        "@type": "Question",
        "name": "How much does the Adjustment of Status cost after K-1?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "After marrying on the K-1 visa, the foreign spouse must file for Adjustment of Status (I-485) to get a green card. The I-485 filing fee is $1,440 as of 2026, which includes the biometrics fee and covers the I-765 (EAD work permit) and I-131 (Advance Parole travel document) if filed concurrently. The I-751 to remove conditions later costs an additional $750."
        }
      },
      {
        "@type": "Question",
        "name": "Are K-1 visa fees refundable?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. USCIS filing fees are non-refundable regardless of the outcome of the petition. This includes the I-129F fee ($675), I-485 fee ($1,440), and I-751 fee ($750). The MRV fee ($265) paid at the embassy is also non-refundable. If a petition is denied, you must file again and pay all fees again."
        }
      },
      {
        "@type": "Question",
        "name": "Can I get a fee waiver for the K-1 visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "USCIS fee waivers (Form I-912) are available for certain immigration benefit requests, but they are NOT available for Form I-129F (K-1 petition) or the MRV consular fee. Fee waivers may be available for the I-485 Adjustment of Status application for qualifying applicants who cannot afford the fee and meet specific financial criteria. The I-131 and I-765 filed with I-485 are included in the bundle fee."
        }
      },
      {
        "@type": "Question",
        "name": "Is K-1 cheaper than CR-1?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No — the K-1 path is significantly more expensive than the CR-1. K-1 to green card costs approximately $3,285 in government fees (plus a second round of medical exams and attorney fees). The CR-1 spousal visa costs approximately $1,970 in government fees total. The K-1's main advantage is faster initial U.S. entry, not cost savings."
        }
      }
    ]
  }
]);
---

<Base
  title="K-1 Visa Cost 2026: Every Fee From Petition to Green Card"
  description="Complete K-1 visa cost breakdown — I-129F fee, MRV fee, medical exam, I-485, I-751, attorney costs. No hidden numbers. Updated April 2026."
  schema={schema}
>

  <!-- Breadcrumb -->
  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="breadcrumb">
        <li><a href="/">Home</a></li>
        <li><SmartLink href="/k1-visa">K-1 Visa</SmartLink></li>
        <li aria-current="page">K-1 Visa Cost</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="hero-badge">💰 2026 Cost Guide</div>
      <h1>K-1 Visa Cost 2026:<br/><span>Every Fee, No Surprises</span></h1>
      <p class="hero-sub">Most couples underestimate the total cost by 50% because they only look at the K-1 visa fee. Here's the complete picture — every fee from I-129F to your 10-year green card.</p>

      <!-- Total cost summary bar -->
      <div class="cost-hero-bar">
        <div class="chb-item chb-highlight">
          <span class="chb-label">K-1 visa only</span>
          <span class="chb-val">$940</span>
          <span class="chb-sub">Govt. fees to enter U.S.</span>
        </div>
        <div class="chb-divider">→</div>
        <div class="chb-item">
          <span class="chb-label">K-1 + AOS (govt. fees)</span>
          <span class="chb-val">$3,285</span>
          <span class="chb-sub">Full process to green card</span>
        </div>
        <div class="chb-divider">→</div>
        <div class="chb-item chb-total">
          <span class="chb-label">Realistic total</span>
          <span class="chb-val">$5K–$10K+</span>
          <span class="chb-sub">Including all out-of-pocket</span>
        </div>
      </div>
    </div>
  </section>

  <div class="container">
    <div class="content-sidebar-grid">

      <main class="main-col">

        <!-- Overview -->
        <section id="overview" class="content-section">
          <h2>Why the Total Cost Is Higher Than You Think</h2>
          <p>When people search "K-1 visa cost," they often find the $940 figure — the I-129F petition fee ($675) plus the MRV consular fee ($265). That's the cost to <em>enter</em> the U.S. on a K-1 visa. But the K-1 is only the first step of a two-stage process.</p>
          <p>After entering on the K-1 and marrying within 90 days, you must file for <strong>Adjustment of Status</strong> (green card) — a completely separate process with its own substantial fees. Then, after ~2 years, you file to remove conditions. Most couples pay fees across 3–4 years total.</p>

          <div class="cost-stages-overview">
            <div class="cso-item">
              <div class="cso-stage">Stage 1</div>
              <div class="cso-name">K-1 Petition (USCIS)</div>
              <div class="cso-fee">$675</div>
            </div>
            <div class="cso-arrow">→</div>
            <div class="cso-item">
              <div class="cso-stage">Stage 2</div>
              <div class="cso-name">Consular Visa Fee</div>
              <div class="cso-fee">$265</div>
            </div>
            <div class="cso-arrow">→</div>
            <div class="cso-item cso-big">
              <div class="cso-stage">Stage 3</div>
              <div class="cso-name">Adjustment of Status</div>
              <div class="cso-fee">$1,440</div>
            </div>
            <div class="cso-arrow">→</div>
            <div class="cso-item">
              <div class="cso-stage">Stage 4</div>
              <div class="cso-name">Remove Conditions (I-751)</div>
              <div class="cso-fee">$750</div>
            </div>
          </div>
        </section>

        <!-- Stage 1: I-129F -->
        <section id="stage1-fees" class="content-section">
          <h2>Stage 1 — Filing the I-129F Petition</h2>
          <p>The petitioner (U.S. citizen) pays these fees when filing Form I-129F with USCIS:</p>

          <table class="fee-table">
            <thead>
              <tr>
                <th>Item</th>
                <th>Fee</th>
                <th>Who Pays</th>
                <th>When</th>
              </tr>
            </thead>
            <tbody>
              <tr class="fee-required">
                <td><strong>Form I-129F filing fee</strong></td>
                <td class="fee-amt">$675</td>
                <td>Petitioner (U.S. citizen)</td>
                <td>At petition filing</td>
              </tr>
              <tr class="fee-optional">
                <td>Attorney fee (if used)</td>
                <td class="fee-amt">$500–$1,500</td>
                <td>Petitioner</td>
                <td>Before/at filing</td>
              </tr>
              <tr class="fee-optional">
                <td>Document translations</td>
                <td class="fee-amt">$50–$200</td>
                <td>Petitioner</td>
                <td>At filing</td>
              </tr>
              <tr class="fee-optional">
                <td>Certified mail / courier</td>
                <td class="fee-amt">$20–$50</td>
                <td>Petitioner</td>
                <td>At filing</td>
              </tr>
            </tbody>
            <tfoot>
              <tr class="fee-subtotal">
                <td><strong>Stage 1 subtotal</strong></td>
                <td class="fee-amt"><strong>$675–$2,425</strong></td>
                <td colspan="2">Depending on attorney use</td>
              </tr>
            </tfoot>
          </table>

          <div class="alert-box alert-info">
            <div class="alert-icon">💡</div>
            <div>
              <strong>I-129F fee is non-refundable</strong>
              <p>USCIS does not refund filing fees if the petition is denied or withdrawn. If your petition is denied, you must refile and pay the $675 again. There is no fee waiver available for I-129F.</p>
            </div>
          </div>
        </section>

        <!-- Stage 2: Embassy fees -->
        <section id="stage2-fees" class="content-section">
          <h2>Stage 2 — NVC &amp; Consular Interview Fees</h2>
          <p>After USCIS approves the I-129F, the case goes to the beneficiary (foreign fiancé/e) for the embassy stage:</p>

          <table class="fee-table">
            <thead>
              <tr>
                <th>Item</th>
                <th>Fee</th>
                <th>Who Pays</th>
                <th>When</th>
              </tr>
            </thead>
            <tbody>
              <tr class="fee-required">
                <td><strong>MRV (Machine Readable Visa) fee</strong></td>
                <td class="fee-amt">$265</td>
                <td>Beneficiary</td>
                <td>Before interview</td>
              </tr>
              <tr class="fee-required">
                <td><strong>Medical exam — panel physician</strong></td>
                <td class="fee-amt">$150–$500</td>
                <td>Beneficiary</td>
                <td>Before interview</td>
              </tr>
              <tr class="fee-required">
                <td><strong>Vaccinations (if not up to date)</strong></td>
                <td class="fee-amt">$50–$400</td>
                <td>Beneficiary</td>
                <td>At medical exam</td>
              </tr>
              <tr class="fee-optional">
                <td>Document translations (civil docs)</td>
                <td class="fee-amt">$50–$200</td>
                <td>Beneficiary</td>
                <td>Before interview</td>
              </tr>
              <tr class="fee-optional">
                <td>Police certificate fees (varies by country)</td>
                <td class="fee-amt">$0–$100</td>
                <td>Beneficiary</td>
                <td>Before interview</td>
              </tr>
              <tr class="fee-optional">
                <td>Travel to embassy (if not local)</td>
                <td class="fee-amt">Varies</td>
                <td>Beneficiary</td>
                <td>Interview day</td>
              </tr>
            </tbody>
            <tfoot>
              <tr class="fee-subtotal">
                <td><strong>Stage 2 subtotal</strong></td>
                <td class="fee-amt"><strong>$515–$1,465+</strong></td>
                <td colspan="2">Medical exam cost varies significantly by country</td>
              </tr>
            </tfoot>
          </table>

          <div class="country-med-box">
            <h3>Medical Exam Cost by Region</h3>
            <div class="cmb-grid">
              <div class="cmb-item">
                <div class="cmb-region">Latin America</div>
                <div class="cmb-range">$150–$350</div>
              </div>
              <div class="cmb-item">
                <div class="cmb-region">Western Europe</div>
                <div class="cmb-range">$200–$400</div>
              </div>
              <div class="cmb-item">
                <div class="cmb-region">Southeast Asia</div>
                <div class="cmb-range">$100–$250</div>
              </div>
              <div class="cmb-item">
                <div class="cmb-region">Philippines</div>
                <div class="cmb-range">$180–$320</div>
              </div>
              <div class="cmb-item">
                <div class="cmb-region">Eastern Europe</div>
                <div class="cmb-range">$150–$300</div>
              </div>
              <div class="cmb-item">
                <div class="cmb-region">Africa</div>
                <div class="cmb-range">$100–$250</div>
              </div>
            </div>
            <p class="cmb-note">Costs vary by panel physician and country. Vaccinations are billed separately and can add $50–$400 depending on which vaccines are needed.</p>
          </div>
        </section>

        <!-- Stage 3: AOS -->
        <section id="stage3-fees" class="content-section">
          <h2>Stage 3 — Adjustment of Status (Green Card)</h2>
          <p>This is the largest single cost in the K-1 process. After marrying, the foreign spouse files for Adjustment of Status to receive the green card. As of 2026, USCIS charges a single bundled fee for the I-485 that includes the EAD and Advance Parole:</p>

          <table class="fee-table">
            <thead>
              <tr>
                <th>Item</th>
                <th>Fee</th>
                <th>Who Pays</th>
                <th>Notes</th>
              </tr>
            </thead>
            <tbody>
              <tr class="fee-required">
                <td><strong>Form I-485 (AOS application)</strong></td>
                <td class="fee-amt">$1,440</td>
                <td>Beneficiary</td>
                <td>Includes biometrics</td>
              </tr>
              <tr class="fee-required">
                <td><strong>Form I-765 (EAD work permit)</strong></td>
                <td class="fee-amt fee-incl">Included</td>
                <td>—</td>
                <td>Filed concurrently with I-485</td>
              </tr>
              <tr class="fee-required">
                <td><strong>Form I-131 (Advance Parole / travel)</strong></td>
                <td class="fee-amt fee-incl">Included</td>
                <td>—</td>
                <td>Filed concurrently with I-485</td>
              </tr>
              <tr class="fee-required">
                <td><strong>Form I-693 (AOS medical exam)</strong></td>
                <td class="fee-amt">$200–$500</td>
                <td>Beneficiary</td>
                <td>Done by USCIS civil surgeon inside U.S.</td>
              </tr>
              <tr class="fee-optional">
                <td>Attorney fee for AOS package</td>
                <td class="fee-amt">$1,000–$3,000</td>
                <td>Both</td>
                <td>Optional but recommended</td>
              </tr>
              <tr class="fee-optional">
                <td>Document translations (if needed)</td>
                <td class="fee-amt">$50–$200</td>
                <td>Beneficiary</td>
                <td>Foreign documents not yet translated</td>
              </tr>
            </tbody>
            <tfoot>
              <tr class="fee-subtotal">
                <td><strong>Stage 3 subtotal</strong></td>
                <td class="fee-amt"><strong>$1,640–$5,140</strong></td>
                <td colspan="2">Depending on attorney use and medical costs</td>
              </tr>
            </tfoot>
          </table>

          <div class="alert-box alert-warning">
            <div class="alert-icon">⚠️</div>
            <div>
              <strong>Second medical exam required</strong>
              <p>The K-1 requires one medical exam before the consular interview (abroad). AOS requires a second separate medical exam (Form I-693) done by a USCIS-designated civil surgeon inside the U.S. You pay for two medical exams total on the K-1 path. On the CR-1 path, only one medical exam is needed.</p>
            </div>
          </div>

          <!-- Affiliate CTA — AOS is complex, high conversion moment -->
          <div class="affiliate-cta">
            <div class="afc-left">
              <div class="afc-icon">🧾</div>
              <div>
                <strong>Preparing your AOS package yourself?</strong>
                <p>Guided filing platforms walk you through every form, flag errors before submission, and cost $299–$599 — saving most couples $1,000–$2,500 vs. a full attorney. Best for straightforward cases with no prior denials or criminal history.</p>
              </div>
            </div>
            <a href="#" class="afc-btn" data-affiliate="aos-self-filing">See Self-Filing Options →</a>
          </div>
        </section>

        <!-- Stage 4: I-751 -->
        <section id="stage4-fees" class="content-section">
          <h2>Stage 4 — Remove Conditions (I-751)</h2>
          <p>Filed ~21 months after receiving the conditional green card. This converts the 2-year CR-1 card into a full 10-year permanent green card:</p>

          <table class="fee-table">
            <thead>
              <tr>
                <th>Item</th>
                <th>Fee</th>
                <th>Notes</th>
              </tr>
            </thead>
            <tbody>
              <tr class="fee-required">
                <td><strong>Form I-751 (Remove Conditions)</strong></td>
                <td class="fee-amt">$750</td>
                <td>Includes biometrics. Filed 21–24 months after green card.</td>
              </tr>
              <tr class="fee-optional">
                <td>Attorney fee (if used)</td>
                <td class="fee-amt">$500–$1,500</td>
                <td>Recommended for waiver-based I-751 cases</td>
              </tr>
            </tbody>
            <tfoot>
              <tr class="fee-subtotal">
                <td><strong>Stage 4 subtotal</strong></td>
                <td class="fee-amt"><strong>$750–$2,250</strong></td>
                <td>Processing time: 24–36 months</td>
              </tr>
            </tfoot>
          </table>
        </section>

        <!-- Full cost summary -->
        <section id="total-cost" class="content-section">
          <h2>Complete Cost Summary — K-1 to Green Card</h2>

          <div class="total-cost-card">
            <div class="tcc-header">
              <h3>Total Estimated Cost: K-1 Path</h3>
              <div class="tcc-badge">2026 figures</div>
            </div>
            <table class="summary-table">
              <tbody>
                <tr class="st-stage">
                  <td colspan="3"><strong>Stage 1 — I-129F Petition</strong></td>
                </tr>
                <tr>
                  <td>Form I-129F filing fee</td>
                  <td class="st-required">Required</td>
                  <td class="st-amt">$675</td>
                </tr>
                <tr class="st-stage">
                  <td colspan="3"><strong>Stage 2 — Consular / Embassy</strong></td>
                </tr>
                <tr>
                  <td>MRV (K-1 visa) fee</td>
                  <td class="st-required">Required</td>
                  <td class="st-amt">$265</td>
                </tr>
                <tr>
                  <td>Medical exam abroad</td>
                  <td class="st-required">Required</td>
                  <td class="st-amt">~$250</td>
                </tr>
                <tr>
                  <td>Vaccinations (if needed)</td>
                  <td class="st-optional">If needed</td>
                  <td class="st-amt">$0–$400</td>
                </tr>
                <tr class="st-stage">
                  <td colspan="3"><strong>Stage 3 — Adjustment of Status</strong></td>
                </tr>
                <tr>
                  <td>Form I-485 (includes EAD + AP)</td>
                  <td class="st-required">Required</td>
                  <td class="st-amt">$1,440</td>
                </tr>
                <tr>
                  <td>I-693 medical exam (civil surgeon)</td>
                  <td class="st-required">Required</td>
                  <td class="st-amt">~$300</td>
                </tr>
                <tr class="st-stage">
                  <td colspan="3"><strong>Stage 4 — Remove Conditions</strong></td>
                </tr>
                <tr>
                  <td>Form I-751</td>
                  <td class="st-required">Required</td>
                  <td class="st-amt">$750</td>
                </tr>
                <tr class="st-stage">
                  <td colspan="3"><strong>Out-of-Pocket (not govt. fees)</strong></td>
                </tr>
                <tr>
                  <td>Document translations</td>
                  <td class="st-optional">Likely needed</td>
                  <td class="st-amt">$100–$400</td>
                </tr>
                <tr>
                  <td>Self-filing platform (optional)</td>
                  <td class="st-optional">Optional</td>
                  <td class="st-amt">$299–$599</td>
                </tr>
                <tr>
                  <td>Immigration attorney (full process)</td>
                  <td class="st-optional">Optional</td>
                  <td class="st-amt">$2,000–$6,000</td>
                </tr>
              </tbody>
              <tfoot>
                <tr class="st-total-govt">
                  <td><strong>Government fees total</strong></td>
                  <td></td>
                  <td class="st-amt"><strong>~$3,680</strong></td>
                </tr>
                <tr class="st-total-realistic">
                  <td><strong>Realistic total (with out-of-pocket)</strong></td>
                  <td></td>
                  <td class="st-amt"><strong>$5,000–$10,500+</strong></td>
                </tr>
              </tfoot>
            </table>
          </div>
        </section>

        <!-- K-1 vs CR-1 cost comparison -->
        <section id="k1-vs-cr1-cost" class="content-section">
          <h2>K-1 vs CR-1 — Which Is Cheaper?</h2>
          <p>If cost is your primary concern, the <strong>CR-1 spousal visa is significantly cheaper</strong> than the K-1 path. Here's why:</p>

          <div class="vs-cost-grid">
            <div class="vc-card vc-k1">
              <div class="vc-header">K-1 Path</div>
              <div class="vc-fees">
                <div class="vcf-item"><span>I-129F</span><span>$675</span></div>
                <div class="vcf-item"><span>MRV fee</span><span>$265</span></div>
                <div class="vcf-item"><span>Medical abroad</span><span>~$250</span></div>
                <div class="vcf-item"><span>I-485 (AOS)</span><span>$1,440</span></div>
                <div class="vcf-item"><span>I-693 medical</span><span>~$300</span></div>
                <div class="vcf-item"><span>I-751</span><span>$750</span></div>
              </div>
              <div class="vc-total">~$3,680 govt. fees</div>
              <div class="vc-note">Two medical exams. Two separate processes. But faster entry.</div>
            </div>
            <div class="vc-vs">VS</div>
            <div class="vc-card vc-cr1">
              <div class="vc-header">CR-1 Path</div>
              <div class="vc-fees">
                <div class="vcf-item"><span>I-130</span><span>$675</span></div>
                <div class="vcf-item"><span>NVC visa fee</span><span>$325</span></div>
                <div class="vcf-item"><span>Medical abroad</span><span>~$250</span></div>
                <div class="vcf-item"><span>USCIS imm. fee</span><span>$220</span></div>
                <div class="vcf-item"><span>I-751</span><span>$750</span></div>
                <div class="vcf-item vcf-savings"><span>No I-485 needed</span><span class="savings-badge">Save $1,440</span></div>
              </div>
              <div class="vc-total vc-total-green">~$2,220 govt. fees</div>
              <div class="vc-note">One medical exam. One continuous process. But slower entry (must be married first).</div>
            </div>
          </div>

          <div class="savings-callout">
            <div class="sc-icon">💰</div>
            <div>
              <strong>CR-1 saves ~$1,460 in government fees alone</strong>
              <p>Plus one fewer medical exam (~$250–$500 savings) and typically lower total attorney fees since it's one process. The K-1 is worth the extra cost if you're not married yet and want to enter the U.S. sooner — otherwise the CR-1 is more economical.</p>
              <SmartLink href="/k1-vs-cr1" class="sc-link">See the full K-1 vs CR-1 comparison →</SmartLink>
            </div>
          </div>
        </section>

        <!-- How to reduce costs -->
        <section id="reduce-costs" class="content-section">
          <h2>How to Reduce K-1 Visa Costs</h2>

          <div class="reduce-grid">
            <div class="rg-card">
              <div class="rg-icon">📋</div>
              <h3>Use a guided filing platform</h3>
              <p>For straightforward cases, platforms like Boundless, RapidVisa, or FileRight guide you through every form for $299–$599. That's $1,500–$3,000 less than a full attorney retainer.</p>
              <div class="rg-savings">Potential savings: $1,000–$2,500</div>
            </div>
            <div class="rg-card">
              <div class="rg-icon">💉</div>
              <h3>Get vaccinations before the medical exam</h3>
              <p>Panel physicians charge clinic rates for vaccinations — often 2–3× higher than a local pharmacy or health department. Get all required vaccines before your medical appointment.</p>
              <div class="rg-savings">Potential savings: $100–$300</div>
            </div>
            <div class="rg-card">
              <div class="rg-icon">🌍</div>
              <h3>Choose a lower-cost panel physician</h3>
              <p>Most countries have multiple USCIS-approved panel physicians. Compare prices in your area — fees can vary by $50–$150 for the same exam. Check the embassy's approved physician list.</p>
              <div class="rg-savings">Potential savings: $50–$150</div>
            </div>
            <div class="rg-card">
              <div class="rg-icon">📄</div>
              <h3>Translate documents yourself</h3>
              <p>You do not need a professional agency for translations. Any competent bilingual person (including yourself, if fluent) can translate and certify documents. Only use professional services for complex legal documents.</p>
              <div class="rg-savings">Potential savings: $100–$300</div>
            </div>
            <div class="rg-card">
              <div class="rg-icon">💑</div>
              <h3>Get married before filing</h3>
              <p>If you haven't married yet, consider whether the CR-1 spousal visa makes more sense for your situation. Getting married first and filing I-130 saves ~$1,460 in government fees and one entire medical exam.</p>
              <div class="rg-savings">Potential savings: $1,700–$2,200</div>
            </div>
            <div class="rg-card">
              <div class="rg-icon">⏰</div>
              <h3>File accurately the first time</h3>
              <p>Errors that lead to RFEs (Requests for Evidence) or denied petitions mean refiling and paying fees again. A careful, complete first submission avoids paying $675–$1,440 twice. Double-check every form before mailing.</p>
              <div class="rg-savings">Avoids: $675–$2,115 repeat fees</div>
            </div>
          </div>

          <!-- Affiliate CTA — after cost reduction section, prime conversion moment -->
          <div class="bottom-affiliate">

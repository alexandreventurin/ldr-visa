---
import Base from '../layouts/Base.astro';
import SmartLink from '../components/SmartLink.astro';

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "K-2 Visa: Bringing Your Fiancé's Children to the U.S. (2026)",
    "description": "The K-2 visa lets unmarried children under 21 of a K-1 beneficiary accompany or follow their parent to the U.S. Learn eligibility, process, documents, and what happens after arrival.",
    "url": "https://ldrvisa.org/k2-visa",
    "dateModified": "2026-05-01",
    "datePublished": "2026-05-01",
    "author": { "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org" },
    "publisher": {
      "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org",
      "logo": { "@type": "ImageObject", "url": "https://ldrvisa.org/favicon.svg" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://ldrvisa.org/k2-visa" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ldrvisa.org/" },
      { "@type": "ListItem", "position": 2, "name": "K-1 Fiancé Visa", "item": "https://ldrvisa.org/k1-visa" },
      { "@type": "ListItem", "position": 3, "name": "K-2 Visa", "item": "https://ldrvisa.org/k2-visa" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the K-2 visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The K-2 visa is a derivative nonimmigrant visa that allows unmarried children under 21 of a K-1 fiancé(e) beneficiary to accompany or follow their parent to the United States. It is filed as part of the same I-129F petition as the K-1 and cannot be applied for separately."
        }
      },
      {
        "@type": "Question",
        "name": "Who qualifies for a K-2 visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A child qualifies for K-2 status if they are: (1) unmarried, (2) under 21 years old, (3) a biological, step, or legally adopted child of the K-1 beneficiary (not the U.S. petitioner), and (4) listed on the K-1 I-129F petition. The child does not need to be the biological child of the U.S. petitioner."
        }
      },
      {
        "@type": "Question",
        "name": "Does the K-2 child have to enter the U.S. at the same time as the K-1 parent?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. The K-2 child can accompany or follow the K-1 parent. However, the K-2 visa is only valid as long as the K-1 parent's status is valid. If the K-1 parent does not marry within 90 days and adjusts status, the K-2 child's path to a green card is also closed. K-2 children should enter while the K-1 case is still in good standing."
        }
      },
      {
        "@type": "Question",
        "name": "What happens to K-2 children after the K-1 marriage?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "After the K-1 parent marries the U.S. citizen and files Form I-485 for adjustment of status, K-2 children file their own I-485 applications concurrently as derivatives. They receive green cards as stepchildren of the U.S. citizen. The child must still be unmarried and under 21 when the I-485 is filed."
        }
      },
      {
        "@type": "Question",
        "name": "Can a K-2 child work or go to school in the U.S.?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "K-2 visa holders are admitted as nonimmigrants and can attend school in the U.S. They cannot work legally on K-2 status alone. To work, they must file for an Employment Authorization Document (EAD) after the I-485 adjustment of status application is filed. School enrollment is generally permitted without additional authorization."
        }
      },
      {
        "@type": "Question",
        "name": "What if the child turns 21 before the green card is approved?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "This is the 'aging out' problem. The Child Status Protection Act (CSPA) provides some protection by 'freezing' the child's age for immigration purposes at the date the I-130 or I-129F was filed, minus USCIS processing time. However, CSPA protections for K-2 derivatives are limited. If aging out is a concern, consult an immigration attorney as soon as possible."
        }
      }
    ]
  }
]);

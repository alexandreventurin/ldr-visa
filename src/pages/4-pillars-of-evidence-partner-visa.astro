---
import Base from '../layouts/Base.astro';
import SmartLink from '../components/SmartLink.astro';

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "4 Pillars of Evidence for a Partner Visa 2026: Prove Your Relationship",
    "description": "The 4 categories of evidence USCIS and embassies look for to approve partner visas — photos, communication, finances, and social recognition — with strength ratings and examples for LDR couples.",
    "url": "https://ldrvisa.org/4-pillars-of-evidence-partner-visa",
    "dateModified": "2026-04-28",
    "datePublished": "2026-04-28",
    "author": { "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org" },
    "publisher": {
      "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org",
      "logo": { "@type": "ImageObject", "url": "https://ldrvisa.org/favicon.svg" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://ldrvisa.org/4-pillars-of-evidence-partner-visa" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ldrvisa.org/" },
      { "@type": "ListItem", "position": 2, "name": "Bona Fide Marriage", "item": "https://ldrvisa.org/bona-fide-marriage" },
      { "@type": "ListItem", "position": 3, "name": "4 Pillars of Evidence", "item": "https://ldrvisa.org/4-pillars-of-evidence-partner-visa" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much evidence is enough for a partner visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "There is no fixed minimum, but USCIS and consular officers want to see evidence across multiple categories — not just one type. A strong package typically includes 30–50 photos across multiple visits, 6–12 months of communication logs, travel receipts, at least 2–3 third-party support letters, and evidence of financial connection. Variety across all 4 pillars is more persuasive than a large amount of just one type."
        }
      },
      {
        "@type": "Question",
        "name": "Do I need evidence from all 4 pillars?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You don't need evidence from every single subcategory, but having something from each of the 4 main pillars — visual documentation, communication records, financial connection, and social recognition — significantly strengthens your case. Officers look for corroboration across categories. If one pillar is weak, a stronger showing in others can compensate."
        }
      },
      {
        "@type": "Question",
        "name": "What is the most important type of evidence for a partner visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No single type is automatically most important — officers evaluate the totality of evidence. However, photos across multiple visits and dates, combined with multi-year communication logs, form the backbone of most strong applications. Third-party letters from people who have personally witnessed the couple's relationship add significant weight because they provide independent corroboration."
        }
      },
      {
        "@type": "Question",
        "name": "Do long-distance couples need more evidence than couples who live together?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Not necessarily more evidence, but LDR couples should be strategic about what they submit. Communication logs are actually a strength for LDR couples — years of daily digital communication clearly shows an ongoing relationship. Officers understand LDR couples can't show joint utility bills or shared housing, so travel records, visit photos, and financial transfers between partners become especially important."
        }
      },
      {
        "@type": "Question",
        "name": "Should I translate foreign-language documents?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Any document not in English must be accompanied by a complete, certified English translation. The translator must certify that the translation is accurate and that they are competent to translate. This applies to support letters, bank statements, social media screenshots, and any other evidence in a foreign language."
        }
      },
      {
        "@type": "Question",
        "name": "Can social media be used as evidence for a partner visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Public social media posts showing the relationship — especially posts that span multiple years, tag the partner, or show you together with friends and family — are accepted as supplemental evidence. Screenshots should include the URL, date, and profile information. Private messages from social media can also be printed as communication logs, though WhatsApp exports are typically easier to present."
        }
      }
    ]
  }
]);
---

<Base
  title="4 Pillars of Evidence for a Partner Visa 2026: Prove Your Relationship"
  description="The 4 evidence categories USCIS and embassies require for partner visa approval — photos, communication, finances, social recognition — with strength ratings and LDR-specific tips."
  schema={schema}
>

  <!-- Breadcrumb -->
  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="breadcrumb">
        <li><a href="/">Home</a></li>
        <li><SmartLink href="/bona-fide-marriage">Bona Fide Marriage</SmartLink></li>
        <li aria-current="page">4 Pillars of Evidence</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="hero-badge">🏛️ Relationship Evidence</div>
      <h1>4 Pillars of Evidence<br/><span>for a Partner Visa</span></h1>
      <p class="hero-sub">USCIS and consular officers evaluate relationship evidence across four categories. Understanding each pillar — and how they reinforce each other — is the key to building an approval-ready package.</p>
      <div class="pillars-bar">
        <div class="pb-item"><div class="pb-icon">📸</div><span>Visual Documentation</span></div>
        <div class="pb-item"><div class="pb-icon">💬</div><span>Communication Records</span></div>
        <div class="pb-item"><div class="pb-icon">💳</div><span>Financial Connection</span></div>
        <div class="pb-item"><div class="pb-icon">👥</div><span>Social Recognition</span></div>
      </div>
    </div>
  </section>

  <div class="container">
    <div class="content-sidebar-grid">

      <!-- MAIN COLUMN -->
      <main class="main-col">

        <!-- Intro -->
        <section id="overview" class="content-section">
          <h2>Why the "4 Pillars" Framework Works</h2>
          <p>Immigration officers are trained skeptics. Their job is to identify sham relationships — arrangements entered purely for immigration benefits. To do that, they look for evidence that is <strong>specific, corroborated, and spans multiple categories</strong>.</p>
          <p>The 4-pillar framework maps directly to how USCIS and consular officers think about relationship evidence — whether you're applying for a <SmartLink href="/k1-visa">K-1 fiancé visa</SmartLink>, a <SmartLink href="/cr1-visa">CR-1 spousal visa</SmartLink>, or going through <SmartLink href="/adjustment-of-status">Adjustment of Status</SmartLink>. The same evidence standard applies across all three paths, and strong bona fide evidence is what the <SmartLink href="/affidavit-of-support">Affidavit of Support</SmartLink> alone cannot replace. A case built across all four pillars is far stronger than one with an overwhelming amount of just one type — because independent categories corroborate each other.</p>

          <div class="strength-legend">
            <div class="sl-item"><div class="sl-dot dot-strong"></div><div><strong>Strong</strong> — Highly persuasive. Carries significant weight on its own.</div></div>
            <div class="sl-item"><div class="sl-dot dot-medium"></div><div><strong>Medium</strong> — Good supporting evidence. Strengthened by other types.</div></div>
            <div class="sl-item"><div class="sl-dot dot-supp"></div><div><strong>Supplemental</strong> — Adds texture. Not relied on alone, but reinforces stronger items.</div></div>
          </div>
        </section>

        <!-- Pillar 1: Photos -->
        <section id="pillar-photos" class="content-section">
          <div class="pillar-header pillar-purple">
            <div class="pillar-num">01</div>
            <div>
              <h2>Pillar 1: Visual Documentation</h2>
              <p>Photos, videos, and visual records of your relationship and shared life</p>
            </div>
          </div>

          <p>Visual evidence is often the first thing an officer reviews. It provides an immediate, intuitive sense of whether the relationship is real — and how long it has been ongoing. Quality and variety matter more than quantity alone.</p>

          <div class="evidence-items">
            <div class="ev-item">
              <div class="ev-strength dot-strong"></div>
              <div>
                <strong>Photos across multiple visits and locations</strong>
                <p>Candid photos from different trips — different countries, cities, or settings — clearly show an ongoing relationship rather than a one-time meeting. Include a mix of sightseeing, everyday moments, and intimate settings.</p>
              </div>
            </div>
            <div class="ev-item">
              <div class="ev-strength dot-strong"></div>
              <div>
                <strong>Photos with each other's families</strong>
                <p>Meeting the family is a significant relationship milestone. Photos of your partner with your parents, siblings, or close family members are among the strongest visual evidence available — they show social integration.</p>
              </div>
            </div>
            <div class="ev-item">
              <div class="ev-strength dot-medium"></div>
              <div>
                <strong>Photos from a single visit</strong>
                <p>Better than nothing, but weaker in isolation. If you've only had one visit, supplement heavily with communication records, financial evidence of flight bookings, and support letters describing the visit.</p>
              </div>
            </div>
            <div class="ev-item">
              <div class="ev-strength dot-medium"></div>
              <div>
                <strong>Screenshots of video calls with timestamps</strong>
                <p>For LDR couples, video call screenshots showing both faces — with date/time visible — demonstrate ongoing visual contact. Especially useful to bridge gaps between in-person visits.</p>
              </div>
            </div>
            <div class="ev-item">
              <div class="ev-strength dot-supp"></div>
              <div>
                <strong>Videos together</strong>
                <p>Short video clips from visits or video calls can be submitted as supplemental evidence. Reference them in a cover letter and include printed screenshots if the officer prefers paper.</p>
              </div>
            </div>
          </div>

          <div class="pillar-tips">
            <h3>📱 Tips for LDR Couples</h3>
            <ul>
              <li>Screenshot every video call milestone — first call, anniversary calls, holiday calls. Save with date in filename.</li>
              <li>Take photos in recognizable public locations during visits (landmarks, restaurants, transit) — they timestamp and locate your visit naturally.</li>
              <li>Send physical printed photos to each other. The postmarks and delivery envelopes become supporting evidence themselves.</li>
              <li>Caption your photos with dates and locations before submitting — don't make the officer guess.</li>
            </ul>
          </div>

          <div class="avoid-box">
            <h3>🚫 What Not to Submit</h3>
            <ul>
              <li>Heavily filtered or clearly staged photos with no candid shots</li>
              <li>All photos from the same day or same location</li>
              <li>Photos with no metadata and no context about when/where they were taken</li>
              <li>Dozens of nearly identical poses — select 30–50 curated best photos</li>
            </ul>
          </div>
        </section>

        <!-- Pillar 2: Communication -->
        <section id="pillar-comms" class="content-section">
          <div class="pillar-header pillar-blue">
            <div class="pillar-num">02</div>
            <div>
              <h2>Pillar 2: Communication Records</h2>
              <p>Logs, exports, and records showing ongoing daily contact</p>
            </div>
          </div>

          <p>For long-distance couples, communication records are your strongest pillar. Years of daily digital contact — across time zones, through life events, with no gaps — tells a story that a single visit cannot.</p>

          <div class="evidence-items">
            <div class="ev-item">
              <div class="ev-strength dot-strong"></div>
              <div>
                <strong>WhatsApp full chat export (multi-year)</strong>
                <p>The gold standard for LDR communication evidence. Export your full chat history — it shows message frequency, voice notes, photos shared, and video calls. A multi-year export with consistent daily contact is extremely persuasive.</p>
                <div class="how-to-box">
                  <strong>How to export:</strong> WhatsApp → Chat → ⋮ or tap name → More → Export Chat → Without Media. Submit a printed sample (3–5 representative weeks from different months) plus the full file on a USB or noted as available.
                </div>
              </div>
            </div>
            <div class="ev-item">
              <div class="ev-strength dot-strong"></div>
              <div>
                <strong>Call logs (phone, WhatsApp, FaceTime)</strong>
                <p>Screenshots or exports of call history showing duration and frequency. International calls with consistent daily patterns spanning months or years carry significant weight.</p>
              </div>
            </div>
            <div class="ev-item">
              <div class="ev-strength dot-medium"></div>
              <div>
                <strong>Email correspondence</strong>
                <p>Older relationships often have email history. Print a selection of emails — especially early exchanges — to show the relationship's origin and development over time.</p>
              </div>
            </div>
            <div class="ev-item">
              <div class="ev-strength dot-medium"></div>
              <div>
                <strong>Dating app or social media DMs</strong>
                <p>Screenshots of your first contact on the platform where you met — with dates — establish the relationship's origin. Officers appreciate seeing the beginning of the story.</p>
              </div>
            </div>
            <div class="ev-item">
              <div class="ev-strength dot-supp"></div>
              <div>
                <strong>Handwritten letters and cards</strong>
                <p>Physical letters sent by mail show a different kind of intentionality than digital messages. Birthday cards, holiday cards, or love letters sent internationally are touching supplemental evidence.</p>
              </div>
            </div>
          </div>

          <div class="pillar-tips">
            <h3>🌍 The LDR Advantage</h3>
            <p>Most couples who met locally cannot produce years of digital communication logs — they were together in person. Your LDR status actually makes this pillar <em>stronger</em> for you. Officers understand that long-distance couples communicate daily via technology. Lean into it.</p>
          </div>
        </section>

        <!-- Pillar 3: Financial -->
        <section id="pillar-financial" class="content-section">
          <div class="pillar-header pillar-green">
            <div class="pillar-num">03</div>
            <div>
              <h2>Pillar 3: Financial Connection</h2>
              <p>Money spent on the relationship — travel, transfers, joint accounts</p>
            </div>
          </div>

          <p>Financial evidence shows real-world commitment. Booking flights, sending money, paying for shared experiences — these create a paper trail that's difficult to fabricate and signals genuine investment in the relationship.</p>

          <div class="evidence-items">
            <div class="ev-item">
              <div class="ev-strength dot-strong"></div>
              <div>
                <strong>Flight tickets and hotel bookings</strong>
                <p>Receipts for international flights — especially ones purchased for your partner — plus hotel bookings during visits. These directly prove in-person contact and show financial investment. Match dates to your visit photos.</p>
              </div>
            </div>
            <div class="ev-item">
              <div class="ev-strength dot-strong"></div>
              <div>
                <strong>Money transfers between partners</strong>
                <p>Bank transfer records, Western Union receipts, Wise/PayPal transfers between your accounts. Even small regular transfers (helping with phone bills, gifts) show ongoing financial entanglement across borders.</p>
              </div>
            </div>
            <div class="ev-item">
              <div class="ev-strength dot-medium"></div>
              <div>
                <strong>Joint bank account or credit card</strong>
                <p>Strongest financial evidence available — shows a truly shared financial life. Not realistic for most LDR couples before the visa is approved, but if you have one, include statements.</p>
              </div>
            </div>
            <div class="ev-item">
              <div class="ev-strength dot-medium"></div>
              <div>
                <strong>Named as beneficiary or emergency contact</strong>
                <p>Naming your partner as beneficiary on life insurance, or as your emergency contact at work, signals long-term commitment. Include the relevant document pages showing the designation.</p>
              </div>
            </div>
            <div class="ev-item">
              <div class="ev-strength dot-supp"></div>
              <div>
                <strong>Gifts sent internationally</strong>
                <p>Receipts from international shipping or gift purchases — especially for birthdays, holidays, or anniversaries — show ongoing relationship investment. Include the shipping receipts and photos of the gifts if available.</p>
              </div>
            </div>
          </div>

          <div class="pillar-tips">
            <h3>💡 LDR Financial Evidence Tips</h3>
            <ul>
              <li>Even sending $50 for a partner's phone bill creates a documented transfer — save every receipt.</li>
              <li>Always book travel in your own name and keep the booking confirmation. If your partner books for you, have them save the receipt.</li>
              <li>Use Wise or similar services for transfers — they provide clear exportable transaction histories with both party names.</li>
            </ul>
          </div>
        </section>

        <!-- Pillar 4: Social Recognition -->
        <section id="pillar-social" class="content-section">
          <div class="pillar-header pillar-orange">
            <div class="pillar-num">04</div>
            <div>
              <h2>Pillar 4: Social Recognition</h2>
              <p>Evidence that others — family, friends, community — recognize the relationship</p>
            </div>
          </div>

          <p>Social recognition evidence provides independent, third-party corroboration. When people outside the relationship — friends, family, colleagues — confirm that your relationship is real, it removes the officer's ability to attribute the entire case to self-serving statements.</p>

          <div class="evidence-items">
            <div class="ev-item">
              <div class="ev-strength dot-strong"></div>
              <div>
                <strong>Support letters from friends and family (firsthand witnesses)</strong>
                <p>The most valuable social recognition evidence. 2–4 letters from people who have personally witnessed the couple together or have direct knowledge of the relationship. Each letter should describe specific observations — not generic praise.</p>
                <div class="how-to-box">
                  <strong>What strong letters include:</strong> How the writer knows both parties, specific instances of seeing the couple together or interacting, how long they have known the relationship exists, and a statement of belief in its genuineness. Signed, dated, with writer's name and contact info.
                </div>
              </div>
            </div>
            <div class="ev-item">
              <div class="ev-strength dot-medium"></div>
              <div>
                <strong>Public social media posts</strong>
                <p>Posts tagging each other, relationship status changes, photos shared publicly — especially spanning multiple years. Take screenshots including the URL, timestamp, and profile name. Translate any captions in other languages.</p>
              </div>
            </div>
            <div class="ev-item">
              <div class="ev-strength dot-medium"></div>
              <div>
                <strong>Engagement or wedding announcements</strong>
                <p>Any public announcement of your engagement — social media post, newspaper notice, family event invitation — shows you have publicly declared your commitment to the relationship.</p>
              </div>
            </div>
            <div class="ev-item">
              <div class="ev-strength dot-supp"></div>
              <div>
                <strong>Photos with each other's social circles</strong>
                <p>Photos with each other's friends during visits — not just family — show integration into each other's lives beyond the romantic bubble. Group photos, outings, events.</p>
              </div>
            </div>
          </div>

          <div class="avoid-box">
            <h3>🚫 What Makes Support Letters Weak</h3>
            <ul>
              <li>"They are a wonderful couple and truly love each other" — too generic, no specific observations</li>
              <li>Letters from people who have never met both partners in person</li>
              <li>Multiple letters that sound identical — suggests they were written by the same person</li>
              <li>Letters that only describe one partner, not the couple's relationship</li>
            </ul>
          </div>
        </section>

        <!-- Evidence matrix -->
        <section id="matrix" class="content-section">
          <h2>Evidence Strength Matrix by Visa Stage</h2>
          <p>Different stages of the immigration process place different weights on evidence types. Use this matrix to prioritize what to submit at each stage:</p>

          <div class="matrix-wrap">
            <table class="matrix-table">
              <thead>
                <tr>
                  <th>Evidence Type</th>
                  <th>I-129F / I-130 <span class="th-sub">USCIS petition</span></th>
                  <th>Consular Interview <span class="th-sub">embassy/consulate</span></th>
                  <th>AOS I-485 <span class="th-sub">USCIS field office</span></th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Photos (multiple visits)</td>
                  <td><span class="badge badge-strong">Strong</span></td>
                  <td><span class="badge badge-strong">Strong</span></td>
                  <td><span class="badge badge-strong">Strong</span></td>
                </tr>
                <tr>
                  <td>Communication logs</td>
                  <td><span class="badge badge-strong">Strong</span></td>
                  <td><span class="badge badge-medium">Medium</span></td>
                  <td><span class="badge badge-medium">Medium</span></td>
                </tr>
                <tr>
                  <td>Travel receipts / flights</td>
                  <td><span class="badge badge-strong">Strong</span></td>
                  <td><span class="badge badge-strong">Strong</span></td>
                  <td><span class="badge badge-medium">Medium</span></td>
                </tr>
                <tr>
                  <td>Financial transfers</td>
                  <td><span class="badge badge-medium">Medium</span></td>
                  <td><span class="badge badge-medium">Medium</span></td>
                  <td><span class="badge badge-medium">Medium</span></td>
                </tr>
                <tr>
                  <td>Third-party support letters</td>
                  <td><span class="badge badge-medium">Medium</span></td>
                  <td><span class="badge badge-strong">Strong</span></td>
                  <td><span class="badge badge-strong">Strong</span></td>
                </tr>
                <tr>
                  <td>Social media posts</td>
                  <td><span class="badge badge-supp">Supplemental</span></td>
                  <td><span class="badge badge-medium">Medium</span></td>
                  <td><span class="badge badge-supp">Supplemental</span></td>
                </tr>
                <tr>
                  <td>Joint accounts / shared bills</td>
                  <td><span class="badge badge-supp">Supplemental</span></td>
                  <td><span class="badge badge-medium">Medium</span></td>
                  <td><span class="badge badge-strong">Strong</span></td>
                </tr>
                <tr>
                  <td>Video call screenshots</td>
                  <td><span class="badge badge-medium">Medium</span></td>
                  <td><span class="badge badge-supp">Supplemental</span></td>
                  <td><span class="badge badge-supp">Supplemental</span></td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <!-- LDR specific -->
        <section id="ldr-guide" class="content-section">
          <h2>LDR-Specific Evidence Strategy</h2>
          <p>Long-distance couples face a unique challenge: you can't show joint utility bills, shared leases, or daily in-person photos. But you have advantages too. Here's how to play to your strengths:</p>

          <div class="ldr-grid">
            <div class="ldr-item">
              <div class="ldr-icon">📆</div>
              <div>
                <h3>Build a chronological timeline</h3>
                <p>Create a one-page relationship timeline — when you first messaged, first called, first visited, got engaged. This gives the officer a narrative anchor and makes all your evidence more coherent.</p>
              </div>
            </div>
            <div class="ldr-item">
              <div class="ldr-icon">✈️</div>
              <div>
                <h3>Document every single visit</h3>
                <p>Every trip deserves its own folder: flight booking confirmation, hotel receipts, photos with dates and locations, anything purchased together (tickets, restaurants). Each visit is a standalone proof point.</p>
              </div>
            </div>
            <div class="ldr-item">
              <div class="ldr-icon">💬</div>
              <div>
                <h3>Lean into digital communication</h3>
                <p>Your WhatsApp history spanning years is something local couples simply don't have. A well-organized communication export that shows daily contact across time zones is one of the most compelling LDR evidence packages.</p>
              </div>
            </div>
            <div class="ldr-item">
              <div class="ldr-icon">🌐</div>
              <div>
                <h3>Show shared digital life</h3>
                <p>Streaming accounts, online gaming, watch parties, shared playlists — digital shared experiences are part of a modern LDR relationship. Screenshots with context can add texture to your communication evidence.</p>
              </div>
            </div>
            <div class="ldr-item">
              <div class="ldr-icon">👨‍👩‍👧</div>
              <div>
                <h3>Get letters from people who've witnessed the relationship remotely</h3>
                <p>Friends who've seen you on video calls with your partner, or family members your partner has met virtually, can still write meaningful support letters based on firsthand observation — even if they've never met your partner in person.</p>
              </div>
            </div>
            <div class="ldr-item">
              <div class="ldr-icon">📋</div>
              <div>
                <h3>Write a personal couple's statement</h3>
                <p>A detailed relationship statement written by both of you — covering your story, how you manage the distance, and your plans — ties all 4 pillars together into a coherent narrative. See our <SmartLink href="/bona-fide-marriage-letter">marriage letter guide</SmartLink> for a full template.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Common mistakes -->
        <section id="mistakes" class="content-section">
          <h2>Common Evidence Mistakes</h2>
          <div class="mistakes-list">
            <div class="mistake-item">
              <div class="mistake-num">01</div>
              <div>
                <h3>Only submitting recent evidence</h3>
                <p>Officers want to see the relationship's history, not just recent activity. A stack of evidence from the last 3 months raises questions about why nothing older exists. Build a timeline that spans from when you met to now.</p>
              </div>
            </div>
            <div class="mistake-item">
              <div class="mistake-num">02</div>
              <div>
                <h3>Generic support letters</h3>
                <p>"They're a lovely couple" letters without specific observations, dates, or firsthand accounts add almost no value — and submitting weak letters alongside strong evidence dilutes your package. Quality over quantity.</p>
              </div>
            </div>
            <div class="mistake-item">
              <div class="mistake-num">03</div>
              <div>
                <h3>All photos from one trip</h3>
                <p>If you have 80 photos from one visit and nothing else, officers will note the absence of evidence spanning the relationship's full duration. One great trip is a data point — multiple visits across time is a pattern.</p>
              </div>
            </div>
            <div class="mistake-item">
              <div class="mistake-num">04</div>
              <div>
                <h3>Not translating foreign-language documents</h3>
                <p>Every document not in English requires a complete, certified translation. Officers cannot evaluate what they cannot read — untranslated evidence effectively doesn't exist in the officer's review.</p>
              </div>
            </div>
            <div class="mistake-item">
              <div class="mistake-num">05</div>
              <div>
                <h3>Submitting too much disorganized evidence</h3>
                <p>500 unorganized photos with no context or labeling is harder to evaluate than 50 well-captioned photos organized chronologically. An officer who can't quickly understand your evidence package is not impressed by its volume.</p>
              </div>
            </div>
            <div class="mistake-item">
              <div class="mistake-num">06</div>
              <div>
                <h3>Relying on a single pillar</h3>
                <p>A pile of photos with no communication records, no financial evidence, and no third-party letters can still be denied — because all the evidence is self-generated and in one category. Cross-category corroboration is what makes a case bulletproof.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Organizing your package -->
        <section id="organize" class="content-section">
          <h2>How to Organize Your Evidence Package</h2>
          <div class="org-steps">
            <div class="org-step">
              <div class="org-num">1</div>
              <div>
                <h3>Create a cover page / index</h3>
                <p>Start with a table of contents listing every exhibit (Exhibit A: Photos, Exhibit B: Communication Logs, etc.) so the officer can navigate quickly. Number every page.</p>
              </div>
            </div>
            <div class="org-step">
              <div class="org-num">2</div>
              <div>
                <h3>Organize chronologically within each pillar</h3>
                <p>Within each category, sort by date — oldest to newest. This shows the relationship's arc clearly. Label each item with the date and a brief description.</p>
              </div>
            </div>
            <div class="org-step">
              <div class="org-num">3</div>
              <div>
                <h3>Use tabs or labeled dividers</h3>
                <p>Physical packages benefit from tabbed dividers between sections. Digital packages (if applicable) should be in a single PDF with bookmarks. Make it easy for the officer to jump between categories.</p>
              </div>
            </div>
            <div class="org-step">
              <div class="org-num">4</div>
              <div>
                <h3>Include certified translations for everything non-English</h3>
                <p>Every foreign-language document — support letters, bank statements, social media screenshots — needs a complete English translation with the translator's certification attached.</p>
              </div>
            </div>
            <div class="org-step">
              <div class="org-num">5</div>
              <div>
                <h3>Write captions for photos</h3>
                <p>Don't submit bare photos. Under each photo (or on a separate caption sheet) note: date, location, and what the photo shows. "July 2023 — First visit to Rio de Janeiro" is far more useful than an unnamed file.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- FAQs -->
        <section id="faq" class="content-section">
          <h2>Frequently Asked Questions</h2>
          <div class="faq-list">
            <details class="faq-item">
              <summary>How much evidence is enough for a partner visa?</summary>
              <p>There's no fixed minimum, but officers look for evidence across multiple categories. A strong package typically includes 30–50 photos across multiple visits, 6–12 months of communication logs, travel receipts, and 2–4 support letters. Variety across all 4 pillars is more persuasive than a large amount of just one type.</p>
            </details>
            <details class="faq-item">
              <summary>Do I need evidence from all 4 pillars?</summary>
              <p>You don't need every subcategory, but having something from each of the 4 main pillars significantly strengthens your case. Officers look for corroboration across categories. If one pillar is genuinely weak (e.g., no financial transfers yet), compensate with stronger evidence in others and explain the gap in your cover letter.</p>
            </details>
            <details class="faq-item">
              <summary>What is the most important type of evidence?</summary>
              <p>No single type is automatically most important — officers evaluate the totality. However, multi-year communication logs + photos across multiple visits form the backbone of most strong applications. Third-party letters add significant weight because they provide independent corroboration from outside the couple.</p>
            </details>
            <details class="faq-item">
              <summary>Do LDR couples need more evidence than couples who live together?</summary>
              <p>Not necessarily more, but LDR couples need to be strategic. Communication logs are actually a strength — years of daily digital contact is compelling. Travel records become especially important since you can't show joint utility bills. The key is showing a consistent, long-term relationship despite the distance.</p>
            </details>
            <details class="faq-item">
              <summary>Should I translate foreign-language documents?</summary>
              <p>Yes — always. Any document not in English must have a complete, certified English translation attached. The translator must certify accuracy and competency to translate. This applies to support letters, bank statements, social media screenshots, and any other foreign-language evidence. Untranslated documents are effectively invisible to the officer.</p>
            </details>
            <details class="faq-item">
              <summary>Can social media be used as evidence?</summary>
              <p>Yes, as supplemental evidence. Public posts tagging each other, spanning multiple years, are useful. Screenshots should include the URL, timestamp, and profile names. Private DMs can be printed as communication logs. Social media alone is not sufficient — it supports the other pillars but shouldn't be your primary evidence.</p>
            </details>
          </div>
        </section>


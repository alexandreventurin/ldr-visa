---
import Base from '../layouts/Base.astro';
import SmartLink from '../components/SmartLink.astro';

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "K-1 Visa Checklist 2026: Complete Document List for Petitioner & Beneficiary",
    "description": "The complete K-1 fiancé visa document checklist — every form, certificate, and evidence item needed at every stage, from I-129F petition through the consular interview and arrival.",
    "url": "https://ldrvisa.org/k1-visa-checklist",
    "dateModified": "2026-04-29",
    "datePublished": "2026-04-29",
    "author": { "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org" },
    "publisher": {
      "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org",
      "logo": { "@type": "ImageObject", "url": "https://ldrvisa.org/favicon.svg" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://ldrvisa.org/k1-visa-checklist" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ldrvisa.org/" },
      { "@type": "ListItem", "position": 2, "name": "K-1 Visa", "item": "https://ldrvisa.org/k1-visa" },
      { "@type": "ListItem", "position": 3, "name": "K-1 Visa Checklist", "item": "https://ldrvisa.org/k1-visa-checklist" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What documents does the petitioner need for K-1?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The U.S. citizen petitioner needs to file Form I-129F with the following supporting documents: proof of U.S. citizenship (passport or naturalization certificate), birth certificate, evidence of in-person meeting within the past 2 years (photos, travel records, passport stamps), divorce or death certificates for any prior marriages, 6 or more photos of the couple together, Form G-1145 (optional for e-notification), and an I-134 Affidavit of Support with supporting financial documents (3 years of tax returns, recent pay stubs, and an employer letter). The beneficiary also submits some documents directly to the petitioner's package."
        }
      },
      {
        "@type": "Question",
        "name": "What does the beneficiary bring to the K-1 interview?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The beneficiary must bring to the consular interview: a valid passport, DS-160 confirmation page, interview appointment letter, original birth certificate with certified translation, police certificates from every country where they lived for 6 or more months as an adult, sealed medical exam results from the panel physician, I-134 Affidavit of Support from the petitioner, divorce or death certificates for any prior marriages, 20–30 photos of the couple together, additional relationship evidence (communication logs, travel records), and proof of the petitioner's U.S. citizenship."
        }
      },
      {
        "@type": "Question",
        "name": "Do K-1 documents need to be translated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Any document not in English must be accompanied by a certified English translation. The translation must include a certification statement from the translator confirming they are competent in both languages and that the translation is accurate. This applies to birth certificates, police certificates, divorce decrees, and any other foreign-language documents submitted to USCIS or the consulate."
        }
      },
      {
        "@type": "Question",
        "name": "How many photos do I need for K-1?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "USCIS requires at least 6 photos of the couple together as part of the I-129F petition. However, for the consular interview, you should bring 20–30 photos spanning multiple dates, locations, and occasions. Photos should show the couple in natural, everyday settings — not just posed photos. Include captions or labels with dates and locations on the back of each photo or on a separate sheet."
        }
      },
      {
        "@type": "Question",
        "name": "What is a police certificate and who needs one?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A police certificate (also called a criminal background check or police clearance) is an official document issued by the police or government authority of a country confirming whether the applicant has a criminal record there. The K-1 beneficiary must obtain a police certificate from every country where they have lived for 6 months or more since the age of 16. This includes their home country and any other countries where they have lived. The certificate must be recent (typically obtained within the past year) and translated into English if not already in English."
        }
      },
      {
        "@type": "Question",
        "name": "Can I submit digital copies of documents?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For the I-129F petition filed with USCIS, photocopies are generally acceptable — original documents are not required unless USCIS sends a Request for Evidence. However, for the consular interview, the beneficiary must bring original documents or certified copies (not plain photocopies). Always keep originals safe and bring both originals and clear copies to the interview. The DS-160 is completed and submitted electronically online."
        }
      }
    ]
  }
]);
---

<Base
  title="K-1 Visa Checklist 2026: Complete Document List (Petitioner & Beneficiary)"
  description="The complete K-1 fiancé visa document checklist — every form, certificate, and evidence item for all 4 stages: I-129F petition, NVC, consular interview, and after arrival. Printable and organized."
  schema={schema}
>

  <!-- Breadcrumb -->
  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="breadcrumb">
        <li><a href="/">Home</a></li>
        <li><SmartLink href="/k1-visa">K-1 Visa</SmartLink></li>
        <li aria-current="page">K-1 Visa Checklist</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="hero-badge">📋 Complete Checklist</div>
      <h1>K-1 Visa Checklist <span>2026</span></h1>
      <p class="hero-sub">Every document you need — petitioner and beneficiary — organized by stage. From the I-129F petition through the consular interview and first 90 days in the U.S.</p>
      <div class="summary-bar">
        <div class="sb-item">
          <span class="sb-num">4</span>
          <span class="sb-label">Stages</span>
        </div>
        <div class="sb-item">
          <span class="sb-num">40+</span>
          <span class="sb-label">Documents</span>
        </div>
        <div class="sb-item">
          <span class="sb-num">2026</span>
          <span class="sb-label">Updated</span>
        </div>
        <div class="sb-item">
          <span class="sb-num">✓</span>
          <span class="sb-label">Printable</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Main content -->
  <div class="container">
    <div class="content-sidebar-grid">

      <!-- MAIN COLUMN -->
      <main class="main-col">

        <!-- Overview -->
        <section id="overview" class="content-section">
          <h2>The 4 Stages of K-1 Documentation</h2>
          <p>The K-1 fiancé visa process has four distinct stages where documents are required. Missing items at any stage can cause delays of months or an outright denial. This checklist covers every document for both the <strong>U.S. citizen petitioner</strong> and the <strong>foreign national beneficiary</strong> at each stage.</p>

          <div class="stages-overview">
            <div class="stage-pill stage-1">
              <div class="stage-pill-num">1</div>
              <div>
                <div class="stage-pill-title">I-129F Petition</div>
                <div class="stage-pill-sub">Petitioner files in the U.S. — USCIS review takes 6–12 months</div>
              </div>
            </div>
            <div class="stage-pill stage-2">
              <div class="stage-pill-num">2</div>
              <div>
                <div class="stage-pill-title">NVC Processing</div>
                <div class="stage-pill-sub">National Visa Center forwards case to the U.S. embassy abroad</div>
              </div>
            </div>
            <div class="stage-pill stage-3">
              <div class="stage-pill-num">3</div>
              <div>
                <div class="stage-pill-title">Consular Interview</div>
                <div class="stage-pill-sub">Beneficiary attends interview at U.S. embassy or consulate</div>
              </div>
            </div>
            <div class="stage-pill stage-4">
              <div class="stage-pill-num">4</div>
              <div>
                <div class="stage-pill-title">After Arrival</div>
                <div class="stage-pill-sub">90-day window to marry and file for Adjustment of Status</div>
              </div>
            </div>
          </div>

          <div class="alert-box alert-teal">
            <div class="alert-icon">💡</div>
            <div>
              <strong>Tip: Start collecting documents early</strong>
              <p>Police certificates and certified translations can take weeks to obtain. Begin gathering beneficiary documents as soon as the I-129F is filed — don't wait for the interview appointment letter.</p>
            </div>
          </div>
        </section>

        <!-- Stage 1 -->
        <section id="stage-1" class="content-section">
          <div class="stage-header stage-header-1">
            <div class="stage-badge">Stage 1</div>
            <h2>I-129F Petition — Petitioner Files in the U.S.</h2>
          </div>
          <p>The U.S. citizen files Form I-129F with USCIS to begin the K-1 process. This packet is submitted entirely by the petitioner (not the beneficiary). USCIS will review the petition and, if approved, forward it to the National Visa Center.</p>

          <div class="two-col-checklist">
            <!-- Petitioner column -->
            <div class="checklist-column">
              <div class="col-header col-petitioner">
                <div class="col-icon">🇺🇸</div>
                <div>
                  <div class="col-title">Petitioner Documents</div>
                  <div class="col-sub">U.S. Citizen — filed with USCIS</div>
                </div>
              </div>
              <ul class="doc-checklist">
                <li class="doc-item">
                  <span class="doc-check"></span>
                  <div class="doc-text">
                    <strong>Form I-129F</strong>
                    <span>Petition for Alien Fiancé(e) — the core petition form</span>
                  </div>
                </li>
                <li class="doc-item">
                  <span class="doc-check"></span>
                  <div class="doc-text">
                    <strong>Form G-1145</strong>
                    <span>Optional — sign up for email/SMS notification of acceptance</span>
                  </div>
                </li>
                <li class="doc-item">
                  <span class="doc-check"></span>
                  <div class="doc-text">
                    <strong>Proof of U.S. citizenship</strong>
                    <span>Copy of U.S. passport, naturalization certificate, or birth certificate</span>
                  </div>
                </li>
                <li class="doc-item">
                  <span class="doc-check"></span>
                  <div class="doc-text">
                    <strong>Petitioner's birth certificate</strong>
                    <span>If born in the U.S. and using birth cert as citizenship proof</span>
                  </div>
                </li>
                <li class="doc-item">
                  <span class="doc-check"></span>
                  <div class="doc-text">
                    <strong>Divorce / death certificates</strong>
                    <span>For every prior marriage — must show marriage was legally terminated</span>
                  </div>
                </li>
                <li class="doc-item">
                  <span class="doc-check"></span>
                  <div class="doc-text">
                    <strong>6+ photos of the couple together</strong>
                    <span>Different dates and locations; note names, date, location on back</span>
                  </div>
                </li>
                <li class="doc-item">
                  <span class="doc-check"></span>
                  <div class="doc-text">
                    <strong>Evidence of in-person meeting</strong>
                    <span>Flight itineraries, passport stamps, hotel receipts, photos with timestamps — must be within 2 years of filing</span>
                  </div>
                </li>
                <li class="doc-item">
                  <span class="doc-check"></span>
                  <div class="doc-text">
                    <strong>Communication logs</strong>
                    <span>Screenshots of messages, call logs — showing ongoing relationship</span>
                  </div>
                </li>
                <li class="doc-item">
                  <span class="doc-check"></span>
                  <div class="doc-text">
                    <strong>Form I-134 — Affidavit of Support</strong>
                    <span>Declares petitioner's financial ability to support the beneficiary</span>
                  </div>
                </li>
                <li class="doc-item">
                  <span class="doc-check"></span>
                  <div class="doc-text">
                    <strong>3 most recent federal tax returns (Form 1040)</strong>
                    <span>Or IRS tax transcripts — shows income history</span>
                  </div>
                </li>
                <li class="doc-item">
                  <span class="doc-check"></span>
                  <div class="doc-text">
                    <strong>Recent pay stubs (3–6 months)</strong>
                    <span>Demonstrates current income</span>
                  </div>
                </li>
                <li class="doc-item">
                  <span class="doc-check"></span>
                  <div class="doc-text">
                    <strong>Employer letter</strong>
                    <span>Confirms current employment, position, and annual salary</span>
                  </div>
                </li>
                <li class="doc-item doc-item-optional">
                  <span class="doc-check check-optional"></span>
                  <div class="doc-text">
                    <strong>Criminal clearance / court records</strong>
                    <span class="doc-optional-badge">If applicable</span>
                    <span>Required if petitioner has any criminal history</span>
                  </div>
                </li>
                <li class="doc-item doc-item-optional">
                  <span class="doc-check check-optional"></span>
                  <div class="doc-text">
                    <strong>Joint sponsor's I-134 + financials</strong>
                    <span class="doc-optional-badge">If income is insufficient</span>
                    <span>A joint sponsor who independently meets the income threshold</span>
                  </div>
                </li>
              </ul>
            </div>

            <!-- Beneficiary column -->
            <div class="checklist-column">
              <div class="col-header col-beneficiary">
                <div class="col-icon">🌍</div>
                <div>
                  <div class="col-title">Beneficiary Documents</div>
                  <div class="col-sub">Foreign National — included in petitioner's packet</div>
                </div>
              </div>
              <ul class="doc-checklist">
                <li class="doc-item">
                  <span class="doc-check"></span>
                  <div class="doc-text">
                    <strong>Passport biographical page copy</strong>
                    <span>Clear copy of the main photo/data page of beneficiary's passport</span>
                  </div>
                </li>
                <li class="doc-item">
                  <span class="doc-check"></span>
                  <div class="doc-text">
                    <strong>Birth certificate</strong>
                    <span>With certified English translation if not in English</span>
                  </div>
                </li>
                <li class="doc-item">
                  <span class="doc-check"></span>
                  <div class="doc-text">
                    <strong>Photos of beneficiary</strong>
                    <span>Standard passport-style photo — check current USCIS specifications</span>
                  </div>
                </li>
                <li class="doc-item doc-item-optional">
                  <span class="doc-check check-optional"></span>
                  <div class="doc-text">
                    <strong>Prior marriage termination documents</strong>
                    <span class="doc-optional-badge">If applicable</span>
                    <span>Divorce decrees, death certificates, annulment orders — all with certified translations</span>
                  </div>
                </li>
              </ul>

              <div class="checklist-note">
                <div class="cn-icon">📌</div>
                <div>
                  <strong>Filing fee:</strong> The I-129F filing fee is <strong>$675</strong> (as of 2026). Pay by check, money order, or online if filing electronically. No fee for the beneficiary at this stage.
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Stage 2 -->
        <section id="stage-2" class="content-section">
          <div class="stage-header stage-header-2">
            <div class="stage-badge">Stage 2</div>
            <h2>NVC Processing — Case Forwarded to Embassy</h2>
          </div>
          <p>Once USCIS approves the I-129F, it forwards the case to the National Visa Center (NVC), which acts as a transfer hub. The NVC then sends the case to the appropriate U.S. embassy or consulate in the beneficiary's country. This stage requires action from the <strong>beneficiary</strong>.</p>

          <ul class="doc-checklist">
            <li class="doc-item">
              <span class="doc-check"></span>
              <div class="doc-text">
                <strong>DS-160 Online Nonimmigrant Visa Application</strong>
                <span>Completed and submitted online at ceac.state.gov — save the confirmation barcode page</span>
              </div>
            </li>
            <li class="doc-item">
              <span class="doc-check"></span>
              <div class="doc-text">
                <strong>MRV visa application fee payment</strong>
                <span>Currently $265 for K-1 visa — paid online before scheduling the interview appointment</span>
              </div>
            </li>
            <li class="doc-item">
              <span class="doc-check"></span>
              <div class="doc-text">
                <strong>Interview appointment scheduled</strong>
                <span>Book through the embassy's appointment scheduling system after paying MRV fee</span>
              </div>
            </li>
            <li class="doc-item">
              <span class="doc-check"></span>
              <div class="doc-text">
                <strong>Medical exam scheduled with approved panel physician</strong>
                <span>Must use a USCIS-designated civil surgeon or embassy-approved panel physician — find yours at travel.state.gov</span>
              </div>
            </li>
            <li class="doc-item">
              <span class="doc-check"></span>
              <div class="doc-text">
                <strong>Vaccination records gathered</strong>
                <span>Bring complete immunization records to the medical exam; missing vaccines must be administered at the exam</span>
              </div>
            </li>
            <li class="doc-item">
              <span class="doc-check"></span>
              <div class="doc-text">
                <strong>Police certificates requested</strong>
                <span>Begin requesting from every country of residence (6+ months as an adult) — these often take weeks to arrive</span>
              </div>
            </li>
          </ul>

          <div class="alert-box alert-teal">
            <div class="alert-icon">⏱️</div>
            <div>
              <strong>Start the medical exam and police certificates now</strong>
              <p>Don't wait until after you schedule the interview. Police certificates from some countries take 4–8 weeks, and the medical exam must be complete before your interview date.</p>
            </div>
          </div>
        </section>

        <!-- Stage 3 -->
        <section id="stage-3" class="content-section">
          <div class="stage-header stage-header-3">
            <div class="stage-badge">Stage 3</div>
            <h2>Consular Interview — The Big Day</h2>
          </div>
          <p>The beneficiary attends the interview at the U.S. embassy or consulate. This is the most document-intensive stage. <strong>Bring originals and clean copies of everything</strong>, organized in labeled folders. The officer will examine documents and may keep some originals.</p>

          <!-- Identity & Civil Documents -->
          <div class="interview-category">
            <h3 class="category-title">
              <span class="cat-icon">🪪</span> Identity &amp; Civil Documents
            </h3>
            <ul class="doc-checklist">
              <li class="doc-item">
                <span class="doc-check"></span>
                <div class="doc-text">
                  <strong>Valid passport</strong>
                  <span>Must be valid for at least 6 months beyond intended entry date; bring all expired passports too</span>
                </div>
              </li>
              <li class="doc-item">
                <span class="doc-check"></span>
                <div class="doc-text">
                  <strong>DS-160 confirmation page</strong>
                  <span>Printed confirmation barcode page from ceac.state.gov</span>
                </div>
              </li>
              <li class="doc-item">
                <span class="doc-check"></span>
                <div class="doc-text">
                  <strong>Interview appointment letter</strong>
                  <span>Printed confirmation of your scheduled interview date and time</span>
                </div>
              </li>
              <li class="doc-item">
                <span class="doc-check"></span>
                <div class="doc-text">
                  <strong>Birth certificate</strong>
                  <span>Original plus certified English translation; some embassies require an apostille</span>
                </div>
              </li>
              <li class="doc-item doc-item-optional">
                <span class="doc-check check-optional"></span>
                <div class="doc-text">
                  <strong>Divorce / death / annulment certificates</strong>
                  <span class="doc-optional-badge">If prior marriages</span>
                  <span>For every prior marriage of the beneficiary — original with certified English translation</span>
                </div>
              </li>
            </ul>
          </div>

          <!-- Police & Medical -->
          <div class="interview-category">
            <h3 class="category-title">
              <span class="cat-icon">🏥</span> Police Certificates &amp; Medical Exam
            </h3>
            <ul class="doc-checklist">
              <li class="doc-item">
                <span class="doc-check"></span>
                <div class="doc-text">
                  <strong>Police certificate(s) from every country of residence</strong>
                  <span>Required from each country where beneficiary lived 6+ months after age 16 — translated into English</span>
                </div>
              </li>
              <li class="doc-item">
                <span class="doc-check"></span>
                <div class="doc-text">
                  <strong>Medical exam results — sealed envelope</strong>
                  <span>Do NOT open the sealed envelope from the panel physician; hand it to the consular officer unopened</span>
                </div>
              </li>
              <li class="doc-item">
                <span class="doc-check"></span>
                <div class="doc-text">
                  <strong>Vaccination records</strong>
                  <span>Bring the original immunization records in case the officer requests them</span>
                </div>
              </li>
            </ul>
          </div>

          <!-- Financial Support -->
          <div class="interview-category">
            <h3 class="category-title">
              <span class="cat-icon">💰</span> Financial Support Documents
            </h3>
            <ul class="doc-checklist">
              <li class="doc-item">
                <span class="doc-check"></span>
                <div class="doc-text">
                  <strong>Form I-134 — Affidavit of Support (petitioner's)</strong>
                  <span>Original signed and notarized copy from the U.S. citizen petitioner</span>
                </div>
              </li>
              <li class="doc-item">
                <span class="doc-check"></span>
                <div class="doc-text">
                  <strong>Petitioner's most recent federal tax return</strong>
                  <span>Or IRS tax transcript; most embassies want last 1–3 years</span>
                </div>
              </li>
              <li class="doc-item">
                <span class="doc-check"></span>
                <div class="doc-text">
                  <strong>Petitioner's recent pay stubs</strong>
                  <span>Typically last 3–6 months of pay statements</span>
                </div>
              </li>
              <li class="doc-item">
                <span class="doc-check"></span>
                <div class="doc-text">
                  <strong>Petitioner's employer letter</strong>
                  <span>On company letterhead confirming employment, title, and annual salary</span>
                </div>
              </li>
              <li class="doc-item">
                <span class="doc-check"></span>
                <div class="doc-text">
                  <strong>Proof of petitioner's U.S. citizenship</strong>
                  <span>Copy of U.S. passport bio page or naturalization certificate</span>
                </div>
              </li>
            </ul>
          </div>

          <!-- Relationship Evidence -->
          <div class="interview-category">
            <h3 class="category-title">
              <span class="cat-icon">❤️</span> Relationship Evidence
            </h3>
            <ul class="doc-checklist">
              <li class="doc-item">
                <span class="doc-check"></span>
                <div class="doc-text">
                  <strong>20–30 photos of the couple together</strong>
                  <span>Across multiple dates, locations, and occasions — label each with date and location</span>
                </div>
              </li>
              <li class="doc-item">
                <span class="doc-check"></span>
                <div class="doc-text">
                  <strong>Communication logs</strong>
                  <span>WhatsApp message exports, call logs, email threads — showing regular ongoing contact</span>
                </div>
              </li>
              <li class="doc-item">
                <span class="doc-check"></span>
                <div class="doc-text">
                  <strong>Travel records (both parties)</strong>
                  <span>Flight itineraries, boarding passes, hotel bookings, passport stamps from visits</span>
                </div>
              </li>
              <li class="doc-item doc-item-optional">
                <span class="doc-check check-optional"></span>
                <div class="doc-text">
                  <strong>Support / reference letters</strong>
                  <span class="doc-optional-badge">Recommended</span>
                  <span>2–3 letters from friends or family who know the couple and can attest to the relationship</span>
                </div>
              </li>
              <li class="doc-item doc-item-optional">
                <span class="doc-check check-optional"></span>
                <div class="doc-text">
                  <strong>Gift receipts or money transfer records</strong>
                  <span class="doc-optional-badge">Helpful</span>
                  <span>Evidence of financial support or gifts sent between visits</span>
                </div>
              </li>
            </ul>
          </div>

          <div class="interview-tip-box">
            <div class="itb-icon">📁</div>
            <div>
              <strong>Interview Organization Tip</strong>
              <p>Organize documents in a tabbed binder or labeled folders in this order: Identity → Police/Medical → Financial → Relationship Evidence. Bring a complete set of copies in addition to originals so the officer can keep what they need without leaving you without copies.</p>
            </div>
          </div>
        </section>

        <!-- Stage 4 -->
        <section id="stage-4" class="content-section">
          <div class="stage-header stage-header-4">
            <div class="stage-badge">Stage 4</div>
            <h2>After Arrival — The 90-Day Window</h2>
          </div>
          <p>Once the K-1 visa is approved and the beneficiary enters the U.S., a strict <strong>90-day clock starts</strong>. You must marry within 90 days, then file for Adjustment of Status (AOS) to get a Green Card. Here's what needs to happen and in what order.</p>

          <div class="arrival-timeline">
            <div class="arrival-step">
              <div class="arrival-dot"></div>
              <div class="arrival-content">
                <h3>Immediately upon entry</h3>
                <ul class="doc-checklist compact">
                  <li class="doc-item">
                    <span class="doc-check"></span>
                    <div class="doc-text">
                      <strong>Apply for Social Security Number (SSN)</strong>
                      <span>Visit a Social Security Administration office — bring passport, K-1 visa, and I-94 arrival record</span>
                    </div>
                  </li>
                  <li class="doc-item">
                    <span class="doc-check"></span>
                    <div class="doc-text">
                      <strong>Save I-94 Arrival/Departure record</strong>
                      <span>Download from i94.cbp.dhs.gov — needed for AOS application</span>
                    </div>
                  </li>
                </ul>
              </div>
            </div>

            <div class="arrival-step">
              <div class="arrival-dot"></div>
              <div class="arrival-content">
                <h3>Within 90 days — Get married</h3>
                <ul class="doc-checklist compact">
                  <li class="doc-item">
                    <span class="doc-check"></span>
                    <div class="doc-text">
                      <strong>Obtain a marriage license</strong>
                      <span>From the county clerk's office in the state where you'll marry</span>
                    </div>
                  </li>
                  <li class="doc-item">
                    <span class="doc-check"></span>
                    <div class="doc-text">
                      <strong>Get legally married within 90 days of entry</strong>
                      <span>Missing the 90-day window means the beneficiary must leave the U.S. and start over</span>
                    </div>
                  </li>
                  <li class="doc-item">
                    <span class="doc-check"></span>
                    <div class="doc-text">
                      <strong>Obtain certified copies of marriage certificate</strong>
                      <span>Request 3–5 certified copies from the county clerk — you'll need them for AOS and other documents</span>
                    </div>
                  </li>
                  <li class="doc-item">
                    <span class="doc-check"></span>
                    <div class="doc-text">
                      <strong>Apply for state ID or driver's license</strong>
                      <span>Visit your state DMV; requirements vary by state</span>
                    </div>
                  </li>
                </ul>
              </div>
            </div>

            <div class="arrival-step">
              <div class="arrival-dot"></div>
              <div class="arrival-content">
                <h3>After marriage — File Adjustment of Status</h3>
                <p style="font-size: 0.875rem; color: var(--color-muted); margin-bottom: 1rem; line-height: 1.6;">File the AOS package with USCIS to apply for the Green Card. This is typically filed as a combined packet. See our complete <SmartLink href="/adjustment-of-status">Adjustment of Status guide</SmartLink> for the full checklist.</p>
                <ul class="doc-checklist compact">
                  <li class="doc-item">
                    <span class="doc-check"></span>
                    <div class="doc-text">
                      <strong>Form I-485</strong>
                      <span>Application to Register Permanent Residence (the main Green Card application)</span>
                    </div>
                  </li>
                  <li class="doc-item">
                    <span class="doc-check"></span>
                    <div class="doc-text">
                      <strong>Form I-864 — Affidavit of Support</strong>
                      <span>The legally binding support affidavit (replaces I-134 used at K-1 stage)</span>
                    </div>
                  </li>
                  <li class="doc-item">
                    <span class="doc-check"></span>
                    <div class="doc-text">
                      <strong>Form I-765 — Employment Authorization</strong>
                      <span>Work permit application — file concurrently with I-485</span>
                    </div>
                  </li>
                  <li class="doc-item">
                    <span class="doc-check"></span>
                    <div class="doc-text">
                      <strong>Form I-131 — Advance Parole</strong>
                      <span>Allows travel outside the U.S. while AOS is pending — file concurrently</span>
                    </div>
                  </li>
                  <li class="doc-item">
                    <span class="doc-check"></span>
                    <div class="doc-text">
                      <strong>Medical exam (Form I-693)</strong>
                      <span>Conducted by a USCIS-designated civil surgeon in the U.S. — sealed envelope submitted with I-485</span>
                    </div>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </section>

        <!-- Common Mistakes -->
        <section id="common-mistakes" class="content-section">
          <h2>Common Document Mistakes to Avoid</h2>
          <p>These errors are responsible for most K-1 delays and denials. Check each one carefully before filing or attending the interview.</p>

          <div class="mistakes-list">
            <div class="mistake-item">
              <div class="mistake-icon mistake-red">✗</div>
              <div>
                <h3>No certified translations for foreign-language documents</h3>
                <p>Every document not in English must include a certified translation. A bilingual friend's translation is <strong>not acceptable</strong> — the translator must certify they are competent and the translation is accurate. USCIS and consulates will reject untranslated or improperly translated documents.</p>
              </div>
            </div>

            <div class="mistake-item">
              <div class="mistake-icon mistake-red">✗</div>
              <div>
                <h3>Too few photos, or photos that look staged</h3>
                <p>Submitting 4–5 formal photos won't convince an officer. You need 20–30 candid photos spanning multiple visits, dates, and ordinary moments — at home, at restaurants, with each other's families. All-posed photos with no candid shots raise red flags.</p>
              </div>
            </div>

            <div class="mistake-item">
              <div class="mistake-icon mistake-red">✗</div>
              <div>
                <h3>Using outdated form versions</h3>
                <p>USCIS periodically releases new form editions. Using an outdated version of Form I-129F or I-134 will result in a rejection. Always download forms directly from uscis.gov immediately before filing — never use saved PDFs from months ago.</p>
              </div>
            </div>

            <div class="mistake-item">
              <div class="mistake-icon mistake-red">✗</div>
              <div>
                <h3>Missing police certificates from every required country</h3>
                <p>Many applicants only get a police certificate from their home country. You need one from <strong>every country</strong> where you lived for 6 or more months as an adult — including countries where you attended school, worked, or lived temporarily. Missing certificates are the most common 221(g) trigger.</p>
              </div>
            </div>

            <div class="mistake-item">
              <div class="mistake-icon mistake-red">✗</div>
              <div>
                <h3>Financial documents don't cover the required period</h3>
                <p>The I-134 should be supported by 3 years of tax returns and recent pay stubs. Submitting only one year, or submitting only bank statements without tax returns, is insufficient. If income varies significantly year-to-year, include an explanation letter.</p>
              </div>
            </div>

            <div class="mistake-item">
              <div class="mistake-icon mistake-red">✗</div>
              <div>
                <h3>Forgetting the I-134 for the consular interview</h3>
                <p>The I-134 Affidavit of Support is required again at the consular interview stage — it's not just for the USCIS petition. The beneficiary must bring a signed, notarized original from the petitioner to the interview. Many couples don't realize this is needed a second time.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- FAQ -->
        <section id="faq" class="content-section">
          <h2>Frequently Asked Questions</h2>
          <div class="faq-list">
            <details class="faq-item">
              <summary>What documents does the petitioner need for K-1?</summary>
              <p>The petitioner files Form I-129F with: proof of U.S. citizenship, birth certificate, evidence of in-person meeting (within 2 years of filing), 6+ couple photos, communication logs, I-134 Affidavit of Support, 3 years of tax returns, recent pay stubs, employer letter, and divorce/death certificates for any prior marriages. The beneficiary's passport copy and birth certificate are also included in the petition packet.</p>
            </details>
            <details class="faq-item">
              <summary>What does the beneficiary bring to the K-1 interview?</summary>
              <p>The beneficiary brings: valid passport, DS-160 confirmation, interview appointment letter, birth certificate (with certified translation), police certificates from every country of residence (6+ months), sealed medical exam results, I-134 from the petitioner (with financial documents), 20–30 couple photos, travel records, communication logs, and proof of petitioner's U.S. citizenship. Divorce/death certificates are required if there were prior marriages.</p>
            </details>
            <details class="faq-item">
              <summary>Do K-1 documents need to be translated?</summary>
              <p>Yes. Any document not in English must have a certified English translation. The translator must include a signed statement certifying their competence in both languages and the accuracy of the translation. This is required for USCIS and for the consulate. Machine translations (Google Translate) are not acceptable for official immigration purposes.</p>
            </details>
            <details class="faq-item">
              <summary>How many photos do I need for K-1?</summary>
              <p>USCIS requires at least 6 photos with the I-129F petition. For the consular interview, bring 20–30 photos spanning multiple visits, dates, and settings. Photos should be candid and natural — include outings, family gatherings, everyday moments. Label each photo on the back with the date and location. A variety of genuine, time-stamped photos is far more convincing than a few formal portraits.</p>
            </details>
            <details class="faq-item">
              <summary>What is a police certificate and who needs one?</summary>
              <p>A police certificate is an official government document confirming whether you have a criminal record in a particular country. The K-1 beneficiary must obtain one from every country where they have lived for 6 or more months since the age of 16. This includes their birth country and any other countries of residence — not just the country where they currently live. Start requesting certificates early as they can take weeks to arrive.</p>
            </details>
            <details class="faq-item">
              <summary>Can I submit digital copies of documents?</summary>
              <p>For USCIS (I-129F petition), photocopies are generally acceptable — originals are not required unless USCIS requests them via RFE. For the consular interview, bring original documents or certified copies, not plain photocopies. The DS-160 is submitted electronically. Never submit the only existing copy of any original document — keep originals and bring certified copies when possible.</p>
            </details>
          </div>
        </section>


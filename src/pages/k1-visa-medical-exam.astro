---
import Base from '../layouts/Base.astro';
import SmartLink from '../components/SmartLink.astro';

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "K-1 Visa Medical Exam: What to Expect, Cost & How to Prepare",
    "description": "Everything about the K-1 fiancé visa medical exam in 2026 — what's tested, which doctor to use, how much it costs by country, and how to prepare so you pass the first time.",
    "url": "https://ldrvisa.org/k1-visa-medical-exam",
    "dateModified": "2026-04-30",
    "datePublished": "2026-04-30",
    "author": { "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org" },
    "publisher": {
      "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org",
      "logo": { "@type": "ImageObject", "url": "https://ldrvisa.org/favicon.svg" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://ldrvisa.org/k1-visa-medical-exam" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ldrvisa.org/" },
      { "@type": "ListItem", "position": 2, "name": "K-1 Visa", "item": "https://ldrvisa.org/k1-visa" },
      { "@type": "ListItem", "position": 3, "name": "Medical Exam", "item": "https://ldrvisa.org/k1-visa-medical-exam" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Who performs the K-1 visa medical exam?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Only a physician designated by the U.S. embassy or consulate in your country — called a panel physician — is authorized to perform the K-1 visa medical exam. You cannot use your personal doctor or a random clinic. Find the official list of panel physicians at travel.state.gov or on your specific embassy's website."
        }
      },
      {
        "@type": "Question",
        "name": "How much does the K-1 visa medical exam cost?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The K-1 visa medical exam cost varies by country and panel physician. Typical ranges: Philippines $200–$350, Mexico $150–$250, United Kingdom $300–$450, Brazil $250–$400, India $100–$200, Australia $300–$500. These costs are paid directly to the panel physician clinic and are not included in the USCIS or embassy visa fees."
        }
      },
      {
        "@type": "Question",
        "name": "What vaccinations are required for the K-1 visa medical exam?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Required vaccinations for the K-1 visa medical exam include: MMR (measles, mumps, rubella), varicella (chickenpox), hepatitis A, hepatitis B, meningococcal, pneumococcal, influenza, polio, tetanus/diphtheria/pertussis (Td/Tdap), and COVID-19. If you have documentation of prior vaccination or immunity through blood titer test, you may not need to repeat them."
        }
      },
      {
        "@type": "Question",
        "name": "How long is the K-1 visa medical exam valid?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The K-1 visa medical exam results are valid for 6 months from the date of the examination. Your embassy interview must occur within this window, or you may need to redo part or all of the exam. Schedule your exam close to your expected interview date to avoid expiration."
        }
      },
      {
        "@type": "Question",
        "name": "Can a medical condition cause a K-1 visa denial?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, certain medical conditions are grounds for inadmissibility under U.S. immigration law. These include: communicable diseases of public health significance (active tuberculosis, syphilis, gonorrhea, Hansen's disease), lack of required vaccinations, certain physical or mental disorders associated with harmful behavior, and drug addiction. Many conditions that once caused bars no longer do — including HIV since 2010. Having a condition doesn't automatically mean denial; waivers are available for many situations."
        }
      },
      {
        "@type": "Question",
        "name": "Do I need a medical exam again for Adjustment of Status after the K-1?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. After marrying on a K-1 visa, you must file for Adjustment of Status (Form I-485). The AOS process requires a separate medical exam using Form I-693, performed by a USCIS-designated civil surgeon in the United States — not the panel physician abroad. This is a different exam from the one done for the K-1 visa. However, some vaccination records from the K-1 exam may be accepted, reducing the cost of the AOS exam."
        }
      }
    ]
  }
]);
---

<Base
  title="K-1 Visa Medical Exam: What to Expect, Cost & How to Prepare"
  description="Complete guide to the K-1 fiancé visa medical exam — panel physicians, what's tested, required vaccinations, costs by country, and how to pass the first time."
  schema={schema}
>


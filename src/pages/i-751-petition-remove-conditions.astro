---
import Base from '../layouts/Base.astro';
import SmartLink from '../components/SmartLink.astro';

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Form I-751 Petition to Remove Conditions on Residence 2026: Complete Guide",
    "description": "How to file Form I-751 to remove the 2-year conditions on your green card — filing window, required evidence, joint filing vs. waivers, USCIS processing times, and what to expect at interview.",
    "url": "https://ldrvisa.org/i-751-petition-remove-conditions",
    "dateModified": "2026-04-28",
    "datePublished": "2026-04-28",
    "author": { "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org" },
    "publisher": {
      "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org",
      "logo": { "@type": "ImageObject", "url": "https://ldrvisa.org/favicon.svg" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://ldrvisa.org/i-751-petition-remove-conditions" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ldrvisa.org/" },
      { "@type": "ListItem", "position": 2, "name": "Adjustment of Status", "item": "https://ldrvisa.org/adjustment-of-status" },
      { "@type": "ListItem", "position": 3, "name": "I-751 Remove Conditions", "item": "https://ldrvisa.org/i-751-petition-remove-conditions" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "When do I file Form I-751?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You must file Form I-751 during the 90-day window before your conditional green card expires — that is, between 21 and 24 months after you received it. Filing too early or too late can result in denial. If you miss the window, you must file late with a written explanation of why you did not file on time, and USCIS may still accept it with good cause shown."
        }
      },
      {
        "@type": "Question",
        "name": "What happens if I miss the I-751 filing window?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If you miss the 90-day filing window, USCIS may still accept a late I-751 if you include a written explanation with good cause. However, once your conditional green card expires and you have not filed or received an extension, you lose your lawful permanent resident status and may be placed in removal proceedings. File as soon as possible and include a detailed explanation of the delay."
        }
      },
      {
        "@type": "Question",
        "name": "Can I file I-751 without my spouse?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. If your marriage ended in divorce or annulment, your spouse died, you or your child were subjected to battery or extreme cruelty, or removal would cause extreme hardship, you can file I-751 on your own without your spouse's signature. These are called 'waiver' bases. You must file during the normal 90-day window (or explain a late filing) and provide strong evidence supporting your waiver basis."
        }
      },
      {
        "@type": "Question",
        "name": "What evidence do I need to file I-751?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "USCIS wants to see evidence that your marriage was entered in good faith and that you have lived together as a married couple. Strong evidence includes joint tax returns, joint bank account statements, joint lease or mortgage, utility bills in both names, insurance policies naming each other, birth certificates of children born to the marriage, and 20–30 photos together spanning the marriage. The more evidence of shared life you can show, the stronger your case."
        }
      },
      {
        "@type": "Question",
        "name": "How long does I-751 processing take in 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "As of 2026, USCIS is processing Form I-751 in approximately 24–36 months at most service centers. Upon filing, you receive an automatic 24-month extension of your conditional green card, which allows you to live and work legally while your petition is pending. USCIS has been issuing longer extension notices to cover the backlog."
        }
      },
      {
        "@type": "Question",
        "name": "Do I need to appear for an interview for I-751?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Not always. USCIS may waive the interview for I-751 joint petitions with strong documentary evidence. However, USCIS increasingly schedules interviews, especially if there are concerns about the marriage's bona fides or if the couple has been living apart. Waiver-based I-751 cases are more likely to require an interview. If called, both spouses should attend (for joint filings) with original documents and a clear joint timeline."
        }
      }
    ]
  }
]);
---

<Base
  title="Form I-751: Petition to Remove Conditions on Residence 2026 — Complete Guide"
  description="How to file Form I-751 to remove the 2-year conditions on your green card — filing window, evidence checklist, joint vs. waiver filing, processing time, and interview prep."
  schema={schema}
>

  <!-- Breadcrumb -->
  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="breadcrumb">
        <li><a href="/">Home</a></li>
        <li><SmartLink href="/adjustment-of-status">Adjustment of Status</SmartLink></li>
        <li aria-current="page">I-751 Remove Conditions</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="hero-badge">📋 Green Card Step 2</div>
      <h1>Form I-751: Petition to<br/><span>Remove Conditions on Residence</span></h1>
      <p class="hero-sub">If you received a 2-year conditional green card through marriage, you must file I-751 before it expires to become a permanent resident. Here's exactly how to do it right.</p>
      <div class="summary-bar">
        <div class="sb-item">
          <span class="sb-val">90 days</span>
          <span class="sb-label">Filing window before expiry</span>
        </div>
        <div class="sb-item">
          <span class="sb-val">$750</span>
          <span class="sb-label">Filing fee (2026)</span>
        </div>
        <div class="sb-item">
          <span class="sb-val">24–36 mo</span>
          <span class="sb-label">Current processing time</span>
        </div>
        <div class="sb-item">
          <span class="sb-val">Auto-extend</span>
          <span class="sb-label">18-mo extension on filing</span>
        </div>
      </div>
    </div>
  </section>

  <div class="container">
    <div class="content-sidebar-grid">

      <!-- MAIN -->
      <main class="main-col">

        <!-- What is I-751 -->
        <section id="overview" class="content-section">
          <h2>What Is the I-751 and Who Needs to File?</h2>
          <p>When a foreign national receives a green card through marriage to a U.S. citizen and the marriage is less than 2 years old at the time of approval, USCIS grants a <strong>conditional permanent residence</strong> — a 2-year green card (Form I-551 with a CR-1 code).</p>
          <p>The conditions exist to deter marriage fraud. To remove them and receive a full 10-year permanent green card, you must file <strong>Form I-751</strong> within a specific window before the conditional card expires.</p>

          <div class="who-grid">
            <div class="who-card who-yes">
              <div class="who-icon">✅</div>
              <h3>You MUST file I-751 if you have a:</h3>
              <ul>
                <li>2-year conditional green card (CR-1 code on the card)</li>
                <li>Card expiring within 90 days</li>
              </ul>
            </div>
            <div class="who-card who-no">
              <div class="who-icon">⏭️</div>
              <h3>You do NOT need I-751 if you have a:</h3>
              <ul>
                <li>10-year permanent green card (IR-1 code) — because your marriage was 2+ years old when approved</li>
                <li>Green card obtained through another basis (employment, asylum, etc.)</li>
              </ul>
            </div>
          </div>

          <div class="alert-box alert-info">
            <div class="alert-icon">💡</div>
            <div>
              <strong>CR-1 vs IR-1 — Know Your Card Code</strong>
              <p>Check the category on your green card. CR-1 = conditional (2-year, must file I-751). IR-1 = immediate relative (10-year, no I-751 needed). The code is printed on the front of your card below your name.</p>
            </div>
          </div>
        </section>

        <!-- Filing window -->
        <section id="filing-window" class="content-section">
          <h2>The Filing Window — Critical Dates</h2>
          <p>The I-751 filing window is strict. You must file during the <strong>90-day period immediately before your conditional green card expires</strong>.</p>

          <div class="timeline-visual">
            <div class="tv-item tv-past">
              <div class="tv-dot tv-dot-gray"></div>
              <div class="tv-label">Card issued</div>
              <div class="tv-sub">Day 0</div>
            </div>
            <div class="tv-line"></div>
            <div class="tv-item">
              <div class="tv-dot tv-dot-gray"></div>
              <div class="tv-label">21-month mark</div>
              <div class="tv-sub">Window opens</div>
            </div>
            <div class="tv-line tv-line-active"></div>
            <div class="tv-item tv-active">
              <div class="tv-dot tv-dot-green"></div>
              <div class="tv-label">File I-751 here</div>
              <div class="tv-sub">Months 21–24</div>
            </div>
            <div class="tv-line tv-line-active"></div>
            <div class="tv-item tv-danger">
              <div class="tv-dot tv-dot-red"></div>
              <div class="tv-label">Card expires</div>
              <div class="tv-sub">Month 24</div>
            </div>
            <div class="tv-line"></div>
            <div class="tv-item">
              <div class="tv-dot tv-dot-gray"></div>
              <div class="tv-label">Late filing risk</div>
              <div class="tv-sub">After month 24</div>
            </div>
          </div>

          <div class="window-cards">
            <div class="wc-card wc-green">
              <h3>✅ File on time (months 21–24)</h3>
              <p>USCIS accepts your petition and sends a receipt notice (I-797). This notice automatically extends your conditional residence for <strong>18 months</strong> while your case is pending. You can live and work legally during this time.</p>
            </div>
            <div class="wc-card wc-yellow">
              <h3>⚠️ File early (before month 21)</h3>
              <p>USCIS will reject the petition and return your filing fee. You must refile when the 90-day window opens. Set a calendar reminder for exactly 21 months after your card's expiry date.</p>
            </div>
            <div class="wc-card wc-red">
              <h3>🚫 File late (after month 24)</h3>
              <p>USCIS may accept a late filing if you include a written explanation with good cause (hospitalization, family emergency, etc.). Without a strong explanation, you risk loss of status and removal proceedings. File immediately and explain the delay thoroughly.</p>
            </div>
          </div>

          <div class="alert-box alert-warning" style="margin-top:1.25rem;">
            <div class="alert-icon">📅</div>
            <div>
              <strong>How to calculate your window</strong>
              <p>Look at the expiration date on your green card. Count back 90 days — that is the first day you can file. The last day to file on time is the card's expiration date itself. Example: card expires September 15, 2026 → file between June 17 and September 15, 2026.</p>
            </div>
          </div>
        </section>

        <!-- Joint vs waiver -->
        <section id="filing-types" class="content-section">
          <h2>Joint Filing vs. Waiver — Which Applies to You?</h2>

          <div class="filing-type-grid">
            <div class="ft-card ft-joint">
              <div class="ft-badge">Most Common</div>
              <h3>🤝 Joint Petition</h3>
              <p>Filed together with your U.S. citizen spouse. Both spouses must sign Form I-751. This is the standard path for couples who are still married and living together.</p>
              <ul>
                <li>Marriage is still intact</li>
                <li>Both spouses available to sign</li>
                <li>Strong evidence of shared life required</li>
                <li>Interview may or may not be required</li>
              </ul>
            </div>
            <div class="ft-card ft-waiver">
              <div class="ft-badge ft-badge-gray">Waiver Basis</div>
              <h3>📋 Waiver — File Without Spouse</h3>
              <p>You can file alone — without your spouse's signature — if one of the following applies to your situation:</p>
              <div class="waiver-reasons">
                <div class="wr-item">
                  <div class="wr-icon">💔</div>
                  <div>
                    <strong>Divorce or annulment</strong>
                    <p>Marriage legally terminated. Include divorce decree or annulment order. You may file during pending divorce proceedings and submit the final decree when issued.</p>
                  </div>
                </div>
                <div class="wr-item">
                  <div class="wr-icon">🕊️</div>
                  <div>
                    <strong>Spouse's death</strong>
                    <p>U.S. citizen spouse died during the conditional period. Include death certificate and evidence of a bona fide marriage.</p>
                  </div>
                </div>
                <div class="wr-item">
                  <div class="wr-icon">🛡️</div>
                  <div>
                    <strong>Battery or extreme cruelty (VAWA)</strong>
                    <p>You or your child were subjected to battery or extreme cruelty by the U.S. citizen spouse. Strong evidence required (police reports, protective orders, medical records, counselor statements).</p>
                  </div>
                </div>
                <div class="wr-item">
                  <div class="wr-icon">⚖️</div>
                  <div>
                    <strong>Extreme hardship</strong>
                    <p>Removal from the U.S. would result in extreme hardship. This is a high bar — requires detailed documentation of hardship factors (medical, financial, family ties, country conditions).</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="alert-box alert-warning" style="margin-top:1.25rem;">
            <div class="alert-icon">⚖️</div>
            <div>
              <strong>Waiver cases are more complex</strong>
              <p>Waiver-based I-751 filings are scrutinized more heavily, more likely to require an interview, and have higher denial rates. If you are filing on a waiver basis — especially divorce or cruelty — consulting an immigration attorney is strongly recommended.</p>
            </div>
          </div>
        </section>

        <!-- Evidence -->
        <section id="evidence" class="content-section">
          <h2>Evidence of a Bona Fide Marriage</h2>
          <p>The core question USCIS asks at I-751 is the same as at every prior stage: <em>Is this a genuine marriage?</em> Now you have 2 years of shared life to document. Submit as much of the following as you have:</p>

          <div class="evidence-cats">
            <div class="ev-cat ev-cat-top">
              <div class="ev-cat-header">
                <div class="ev-cat-icon">🏦</div>
                <h3>Financial Evidence <span class="ev-strength-badge badge-strong">Strongest</span></h3>
              </div>
              <div class="ev-items-list">
                <div class="ev-row"><span class="ev-check">✓</span><div><strong>Joint federal tax returns</strong> — Filed together as "married filing jointly." Most powerful single document.</div></div>
                <div class="ev-row"><span class="ev-check">✓</span><div><strong>Joint bank account statements</strong> — 12+ months of statements showing shared account with both names and regular transactions.</div></div>
                <div class="ev-row"><span class="ev-check">✓</span><div><strong>Joint credit card statements</strong> — Both names on the account, shared expenses.</div></div>
                <div class="ev-row"><span class="ev-check">✓</span><div><strong>Named as beneficiary</strong> — Life insurance, retirement accounts, pension — naming each other as primary beneficiary.</div></div>
              </div>
            </div>

            <div class="ev-cat">
              <div class="ev-cat-header">
                <div class="ev-cat-icon">🏠</div>
                <h3>Shared Residence <span class="ev-strength-badge badge-strong">Strongest</span></h3>
              </div>
              <div class="ev-items-list">
                <div class="ev-row"><span class="ev-check">✓</span><div><strong>Joint lease or mortgage</strong> — Both names on the lease agreement or mortgage statement.</div></div>
                <div class="ev-row"><span class="ev-check">✓</span><div><strong>Utility bills in both names</strong> — Electric, gas, internet, phone — showing the same address for both spouses.</div></div>
                <div class="ev-row"><span class="ev-check">✓</span><div><strong>Mail addressed to both spouses</strong> — Government correspondence, bank mail, subscriptions at the same address.</div></div>
              </div>
            </div>

            <div class="ev-cat">
              <div class="ev-cat-header">
                <div class="ev-cat-icon">📋</div>
                <h3>Legal &amp; Insurance Records <span class="ev-strength-badge badge-medium">Strong</span></h3>
              </div>
              <div class="ev-items-list">
                <div class="ev-row"><span class="ev-check">✓</span><div><strong>Joint auto or home insurance</strong> — Policy listing both spouses as insured.</div></div>
                <div class="ev-row"><span class="ev-check">✓</span><div><strong>Health insurance covering spouse</strong> — Employer health plan enrollment adding spouse as dependent.</div></div>
                <div class="ev-row"><span class="ev-check">✓</span><div><strong>Joint property ownership</strong> — Deed or vehicle title in both names.</div></div>
                <div class="ev-row"><span class="ev-check">✓</span><div><strong>Will or estate planning documents</strong> — Naming each other as heirs.</div></div>
              </div>
            </div>

            <div class="ev-cat">
              <div class="ev-cat-header">
                <div class="ev-cat-icon">👨‍👩‍👧</div>
                <h3>Children &amp; Family <span class="ev-strength-badge badge-medium">Strong</span></h3>
              </div>
              <div class="ev-items-list">
                <div class="ev-row"><span class="ev-check">✓</span><div><strong>Birth certificate of children</strong> — Children born to the marriage during the conditional period — among the strongest possible evidence.</div></div>
                <div class="ev-row"><span class="ev-check">✓</span><div><strong>Evidence of pregnancy</strong> — Medical records, ultrasound reports showing pregnancy during the conditional period.</div></div>
                <div class="ev-row"><span class="ev-check">✓</span><div><strong>School records listing both parents</strong> — Children's school enrollment forms, emergency contact forms naming both spouses.</div></div>
              </div>
            </div>

            <div class="ev-cat">
              <div class="ev-cat-header">
                <div class="ev-cat-icon">📸</div>
                <h3>Relationship Documentation <span class="ev-strength-badge badge-medium">Good</span></h3>
              </div>
              <div class="ev-items-list">
                <div class="ev-row"><span class="ev-check">✓</span><div><strong>Photos spanning the conditional period</strong> — 20–30 photos from different dates and occasions: holidays, travel, family events, everyday life.</div></div>
                <div class="ev-row"><span class="ev-check">✓</span><div><strong>Travel records together</strong> — Flights, hotel bookings, or itineraries showing joint travel during the marriage.</div></div>
                <div class="ev-row"><span class="ev-check">✓</span><div><strong>Support letters</strong> — 2–3 letters from friends or family who have witnessed the couple living together and know the marriage is genuine.</div></div>
              </div>
            </div>
          </div>

          <div class="alert-box alert-info" style="margin-top:1.25rem;">
            <div class="alert-icon">📊</div>
            <div>
              <strong>Quantity and variety both matter</strong>
              <p>USCIS adjudicators look for evidence that spans the full 2-year conditional period — not just recent documents. Include items from throughout the marriage. A joint tax return from Year 1 + bank statements from Year 2 + current lease tells a continuous story. A single lease with nothing else raises questions.</p>
            </div>
          </div>
        </section>

        <!-- How to file -->
        <section id="how-to-file" class="content-section">
          <h2>How to File Form I-751 — Step by Step</h2>

          <div class="steps-list">
            <div class="step-item">
              <div class="step-circle">1</div>
              <div>
                <h3>Download and complete Form I-751</h3>
                <p>Download the current version of Form I-751 from uscis.gov (always use the current edition — outdated versions are rejected). Complete all sections. For joint petitions, both spouses sign Part 5. For waiver petitions, check the appropriate waiver box in Part 3.</p>
              </div>
            </div>
            <div class="step-item">
              <div class="step-circle">2</div>
              <div>
                <h3>Gather your evidence package</h3>
                <p>Organize your evidence chronologically. Create a cover page listing each exhibit (Exhibit A: Joint Tax Returns, Exhibit B: Bank Statements, etc.). Label and date every document. Include certified translations for any non-English documents.</p>
              </div>
            </div>
            <div class="step-item">
              <div class="step-circle">3</div>
              <div>
                <h3>Prepare payment</h3>
                <p>The filing fee is <strong>$750</strong> (as of 2026). Pay by check (payable to "U.S. Department of Homeland Security"), money order, or online if filing electronically. Do not send cash. Biometrics are included in the filing fee — no separate payment needed.</p>
              </div>
            </div>
            <div class="step-item">
              <div class="step-circle">4</div>
              <div>
                <h3>Mail to the correct USCIS address</h3>
                <p>The mailing address depends on whether you are filing by USPS or a courier (UPS/FedEx). Check uscis.gov/i-751 for the current filing address — it changes periodically. Send via certified mail and keep the tracking number.</p>
                <div class="address-note">
                  <strong>Include in your package:</strong> Completed I-751, filing fee, copy of both sides of your conditional green card, copy of your marriage certificate, and all evidence exhibits.
                </div>
              </div>
            </div>
            <div class="step-item">
              <div class="step-circle">5</div>
              <div>
                <h3>Receive receipt notice (Form I-797)</h3>
                <p>USCIS sends a receipt notice within 2–4 weeks. This I-797 notice <strong>automatically extends your conditional green card for 18 months</strong>. Keep this notice — it is proof of your lawful status and work authorization during processing.</p>
              </div>
            </div>
            <div class="step-item">
              <div class="step-circle">6</div>
              <div>
                <h3>Biometrics appointment</h3>
                <p>USCIS schedules a biometrics appointment at your local Application Support Center (ASC). Bring your I-797 receipt notice and valid photo ID. Fingerprints, photo, and signature are taken. Attend as scheduled — missing biometrics delays processing.</p>
              </div>
            </div>
            <div class="step-item">
              <div class="step-circle">7</div>
              <div>
                <h3>Interview (if scheduled) or direct approval</h3>
                <p>USCIS may waive the interview for strong joint petitions. If an interview is required, you'll receive a notice to appear at your local USCIS field office. Both spouses attend for joint petitions. Bring original documents and be prepared to answer questions about your shared life.</p>
              </div>
            </div>
            <div class="step-item">
              <div class="step-circle">8</div>
              <div>
                <h3>10-year green card produced and mailed</h3>
                <p>Upon approval, USCIS produces your new 10-year permanent resident card (IR-1 code) and mails it to your address on file. Update your address with USCIS (Form AR-11) if you move during processing.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Processing time -->
        <section id="processing" class="content-section">
          <h2>I-751 Processing Times 2026</h2>
          <p>USCIS is currently processing I-751 petitions in <strong>24–36 months</strong> at most service centers. The backlog has grown significantly since 2020. Here's what to expect at each stage:</p>

          <table class="info-table">
            <thead>
              <tr><th>Stage</th><th>Typical Wait</th><th>Notes</th></tr>
            </thead>
            <tbody>
              <tr>
                <td>Receipt notice (I-797)</td>
                <td>2–6 weeks</td>
                <td>Automatic 18-month extension of conditional card</td>
              </tr>
              <tr>
                <td>Biometrics appointment</td>
                <td>1–4 months after receipt</td>
                <td>Scheduled at local ASC</td>
              </tr>
              <tr>
                <td>RFE (if issued)</td>
                <td>Varies — 87-day response window</td>
                <td>Request for additional evidence — respond completely</td>
              </tr>
              <tr>
                <td>Interview notice (if required)</td>
                <td>12–30 months after filing</td>
                <td>Not all cases require interview</td>
              </tr>
              <tr>
                <td>Approval notice</td>
                <td>24–36 months after filing</td>
                <td>Varies significantly by service center</td>
              </tr>
              <tr>
                <td>10-year green card production</td>
                <td>2–4 weeks after approval</td>
                <td>Mailed to address on file</td>
              </tr>
            </tbody>
          </table>

          <div class="alert-box alert-info" style="margin-top:1.25rem;">
            <div class="alert-icon">🔄</div>
            <div>
              <strong>18-month extension not enough? USCIS issues additional extensions.</strong>
              <p>Given the current backlog, USCIS has been issuing additional automatic extension notices beyond the initial 18 months for cases that remain pending. If your extension is about to expire and your case is still pending, USCIS will typically send an updated extension letter. Check uscis.gov for the latest extension policies.</p>
            </div>
          </div>
        </section>

        <!-- Interview prep -->
        <section id="interview" class="content-section">
          <h2>I-751 Interview Preparation</h2>
          <p>If USCIS schedules an interview, it takes place at your local USCIS field office. The officer's goal is to verify that your marriage is genuine and that you have truly been living as a married couple.</p>

          <h3>Who attends?</h3>
          <div class="interview-attend">
            <div class="ia-item ia-yes">
              <div class="ia-icon">✅</div>
              <div><strong>Joint filing:</strong> Both spouses must attend. Officers may interview you together and separately — this is normal and not a red flag.</div>
            </div>
            <div class="ia-item ia-caution">
              <div class="ia-icon">⚠️</div>
              <div><strong>Waiver filing:</strong> Only the conditional resident attends. Bring all waiver evidence and be prepared to explain the circumstances in detail.</div>
            </div>
          </div>

          <h3 style="margin-top:1.5rem;">Common interview questions</h3>
          <div class="iq-grid">
            <div class="iq-item"><div class="iq-icon">🏠</div><span>Current address and how long you've lived there together</span></div>
            <div class="iq-item"><div class="iq-icon">💼</div><span>Both spouses' employers and work schedules</span></div>
            <div class="iq-item"><div class="iq-icon">💰</div><span>Who pays which bills, joint vs. separate accounts</span></div>
            <div class="iq-item"><div class="iq-icon">🚗</div><span>Vehicles owned, who drives what</span></div>
            <div class="iq-item"><div class="iq-icon">👨‍👩‍👧</div><span>Family members' names, birthdays, where they live</span></div>
            <div class="iq-item"><div class="iq-icon">📺</div><span>Daily routines, shared hobbies, social activities</span></div>
            <div class="iq-item"><div class="iq-icon">🏥</div><span>Each other's doctors, medications, health history</span></div>
            <div class="iq-item"><div class="iq-icon">✈️</div><span>Trips taken together, upcoming plans</span></div>
          </div>

          <h3 style="margin-top:1.5rem;">Documents to bring to the interview</h3>
          <div class="doc-bring">
            <div class="db-item"><span class="db-check">✓</span><div>Original conditional green card (even if expired)</div></div>
            <div class="db-item"><span class="db-check">✓</span><div>I-797 receipt notice and any extension notices</div></div>
            <div class="db-item"><span class="db-check">✓</span><div>Valid passport</div></div>
            <div class="db-item"><span class="db-check">✓</span><div>Marriage certificate (original)</div></div>
            <div class="db-item"><span class="db-check">✓</span><div>Joint tax returns (most recent 2 years)</div></div>
            <div class="db-item"><span class="db-check">✓</span><div>Joint bank account statements (6–12 months)</div></div>
            <div class="db-item"><span class="db-check">✓</span><div>Lease or mortgage in both names</div></div>
            <div class="db-item"><span class="db-check">✓</span><div>Utility bills or insurance in both names</div></div>
            <div class="db-item"><span class="db-check">✓</span><div>Photos together (printed, with captions)</div></div>
            <div class="db-item"><span class="db-check">✓</span><div>Any additional evidence submitted with petition</div></div>
          </div>
        </section>

        <!-- Common mistakes -->
        <section id="mistakes" class="content-section">
          <h2>Common I-751 Mistakes to Avoid</h2>
          <div class="mistakes-list">
            <div class="mistake-item">
              <div class="mistake-num">01</div>
              <div>
                <h3>Filing outside the 90-day window</h3>
                <p>Too early = rejection and return of fee. Too late = potential loss of status. Set a calendar alarm for exactly 21 months after your card's expiry date. Do not rely on memory.</p>
              </div>
            </div>
            <div class="mistake-item">
              <div class="mistake-num">02</div>
              <div>
                <h3>Submitting weak or one-sided evidence</h3>
                <p>Only submitting photos and a joint lease — with no financial evidence — raises flags. USCIS wants corroboration across multiple categories. Joint tax returns + bank accounts + lease + insurance is a far stronger package than any one item alone.</p>
              </div>
            </div>
            <div class="mistake-item">
              <div class="mistake-num">03</div>
              <div>
                <h3>Not updating your address with USCIS</h3>
                <p>If you move during the processing period (which can be 2–3 years), you must file Form AR-11 within 10 days. Interview and approval notices go to the address on file — missing them because you moved is a serious problem.</p>
              </div>
            </div>
            <div class="mistake-item">
              <div class="mistake-num">04</div>
              <div>
                <h3>Using an outdated form version</h3>
                <p>USCIS periodically updates Form I-751. Always download the current version directly from uscis.gov before filing. Outdated versions are automatically rejected.</p>
              </div>
            </div>
            <div class="mistake-item">
              <div class="mistake-num">05</div>
              <div>
                <h3>Filing separately without a valid waiver basis</h3>
                <p>A conditional resident cannot simply choose to file alone because the marriage is struggling. You need a legally recognized waiver basis (divorce, death, cruelty, extreme hardship). Filing without a valid basis leads to denial.</p>
              </div>
            </div>
            <div class="mistake-item">
              <div class="mistake-num">06</div>
              <div>
                <h3>Not including copies of both sides of the green card</h3>
                <p>USCIS requires a copy of the front and back of your conditional green card with your I-751 package. Forgetting this simple requirement can delay processing or trigger an RFE.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- After approval -->
        <section id="after-approval" class="content-section">
          <h2>After I-751 Approval — Path to Citizenship</h2>
          <p>Once your I-751 is approved and you receive your 10-year permanent green card, you are a full lawful permanent resident. Here's what comes next on the path to citizenship:</p>

          <div class="path-steps">
            <div class="path-item">
              <div class="path-circle path-done">✓</div>
              <div>
                <strong>Conditional green card (CR-1)</strong>
                <p>2-year card — the stage you're resolving with I-751.</p>
              </div>
            </div>
            <div class="path-connector"></div>
            <div class="path-item">
              <div class="path-circle path-current">★</div>
              <div>
                <strong>I-751 approved → 10-year green card (IR-1)</strong>
                <p>You are now a permanent resident with no conditions. Valid for 10 years, renewable.</p>
              </div>
            </div>
            <div class="path-connector"></div>
            <div class="path-item">
              <div class="path-circle path-next">3</div>
              <div>
                <strong>Eligible for citizenship after 3 years</strong>
                <p>Spouses of U.S. citizens can apply for naturalization (Form N-400) after just 3 years of permanent residence — not the standard 5. You must have been married to and living with your U.S. citizen spouse for those 3 years.</p>
              </div>
            </div>
            <div class="path-connector"></div>
            <div class="path-item">
              <div class="path-circle path-next">🇺🇸</div>
              <div>
                <strong>U.S. citizenship</strong>
                <p>Pass the naturalization interview and civics test, take the oath — you are a U.S. citizen. The I-864 Affidavit of Support obligation ends here.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- FAQ -->
        <section id="faq" class="content-section">
          <h2>Frequently Asked Questions</h2>
          <div class="faq-list">
            <details class="faq-item">
              <summary>When do I file Form I-751?</summary>
              <p>During the 90-day window before your conditional green card expires — between 21 and 24 months after the card was issued. Calculate by looking at the expiration date on your card and counting back 90 days. That is the first day you can file; the expiration date itself is the last day to file on time.</p>
            </details>
            <details class="faq-item">
              <summary>What happens if I miss the I-751 filing window?</summary>
              <p>File as soon as possible with a written explanation of good cause for the delay. USCIS may still accept a late filing. If your conditional green card has expired and you have not filed, you are in an undocumented status and risk removal proceedings. Do not wait — file immediately and explain the circumstances thoroughly.</p>
            </details>
            <details class="faq-item">
              <summary>Can I file I-751 without my spouse?</summary>
              <p>Yes, if you qualify for a waiver: your marriage ended in divorce or annulment, your spouse died, you or your child were subjected to battery or extreme cruelty, or removal would cause extreme hardship. Each basis requires specific documentation. Waiver cases are more complex and an immigration attorney is strongly recommended.</p>
            </details>
            <details class="faq-item">
              <summary>What evidence do I need for I-751?</summary>
              <p>Joint tax returns, joint bank account statements, joint lease or mortgage, utility bills in both names, insurance policies, photos spanning the marriage, and support letters from people who know the couple. The more categories of evidence you can provide — especially financial and residential — the stronger your petition. Joint tax returns are typically the single most persuasive document.</p>
            </details>
            <details class="faq-item">
              <summary>How long does I-751 processing take in 2026?</summary>
              <p>Approximately 24–36 months at most USCIS service centers as of 2026. When you file, you receive an automatic 18-month extension of your conditional green card. USCIS has been issuing additional extension notices for cases pending beyond the initial extension period. You can live and work legally throughout the processing period with your receipt notice.</p>
            </details>
            <details class="faq-item">
              <summary>Do I need to attend an interview for I-751?</summary>
              <p>Not necessarily — USCIS may waive the interview for joint petitions with strong documentary evidence. However, USCIS is increasingly scheduling interviews, especially if the couple has been living apart or if there are any concerns about the marriage's bona fides. Waiver-based cases almost always require an interview. If called, both spouses attend for joint filings; bring originals of all submitted documents.</p>
            </details>
          </div>
        </section>


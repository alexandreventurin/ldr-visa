---
import Base from '../layouts/Base.astro';
import SmartLink from '../components/SmartLink.astro';

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Conditional Green Card 2026: What It Is, the I-751 Window, and Everything That Comes Next",
    "description": "Everything international couples need to know about the 2-year conditional green card — why USCIS issues it, who gets it, the I-751 filing window (months 21–24), evidence requirements, processing times, and the path to a permanent 10-year card.",
    "url": "https://ldrvisa.org/conditional-green-card",
    "dateModified": "2026-04-30",
    "datePublished": "2026-04-30",
    "author": { "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org" },
    "publisher": {
      "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org",
      "logo": { "@type": "ImageObject", "url": "https://ldrvisa.org/favicon.svg" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://ldrvisa.org/conditional-green-card" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ldrvisa.org/" },
      { "@type": "ListItem", "position": 2, "name": "Green Card Through Marriage", "item": "https://ldrvisa.org/green-card-through-marriage" },
      { "@type": "ListItem", "position": 3, "name": "Conditional Green Card", "item": "https://ldrvisa.org/conditional-green-card" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is a conditional green card?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A conditional green card (also called a CR-1 card or 2-year green card) is a Lawful Permanent Resident card issued when a foreign national's marriage to a U.S. citizen was less than 2 years old at the time of approval. It grants the same rights as a permanent green card — work authorization, travel, re-entry — but expires after 2 years and requires filing Form I-751 to remove the conditions and receive a full 10-year permanent resident card."
        }
      },
      {
        "@type": "Question",
        "name": "Who gets a conditional green card vs. a 10-year green card?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "USCIS looks at how long the couple has been married at the time the green card is approved — not when the petition was filed. If the marriage is less than 2 years old at approval, the foreign spouse receives a conditional (2-year) green card with a CR-1 or CR-6 category code. If the marriage is 2 or more years old at approval, the foreign spouse receives a 10-year permanent green card with an IR-1 or IF-6 category code and does not need to file I-751."
        }
      },
      {
        "@type": "Question",
        "name": "When do I file Form I-751 to remove conditions?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You must file Form I-751 during the 90-day window immediately before your conditional green card expires — that is, between the 21st and 24th month after the card was issued. You cannot file before the 21-month mark (USCIS will reject it and return your fee). Filing after the expiration date requires a late-filing explanation. Upon filing on time, you receive an automatic 24-month extension of your conditional residence while the petition is pending."
        }
      },
      {
        "@type": "Question",
        "name": "What happens if I miss the I-751 filing window?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If you miss the 90-day window (months 21–24), file as soon as possible with a written explanation showing good cause for the delay — such as a serious illness, family emergency, or natural disaster. USCIS may still accept a late filing. However, if your conditional green card has expired and you have no pending I-751 or extension, you are in an undocumented status and risk removal proceedings. File immediately. An immigration attorney can help you draft the strongest possible late-filing explanation."
        }
      },
      {
        "@type": "Question",
        "name": "Can I work and travel with a conditional green card?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. A conditional green card is a real Permanent Resident Card — it is simply time-limited. With it you can work anywhere in the U.S. without employer sponsorship, travel internationally and re-enter the U.S. as a returning resident, and live anywhere in the country. The same applies during I-751 processing — your I-797 receipt notice serves as evidence of your continued lawful status and work authorization."
        }
      },
      {
        "@type": "Question",
        "name": "How long does it take to get a permanent 10-year green card after filing I-751?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "As of 2026, USCIS is processing Form I-751 in approximately 24–36 months at most service centers. When you file, you receive an automatic 24-month extension of your conditional green card, which is enough to cover most cases given current processing times. USCIS has been issuing additional extension notices for cases that remain pending beyond the initial extension period. You can live and work legally throughout the entire processing period."
        }
      }
    ]
  }
]);
---

<Base
  title="Conditional Green Card 2026: What It Is, the I-751 Window & Everything Next"
  description="Everything international couples need to know about the 2-year conditional green card — why USCIS issues it, who gets it, the I-751 filing window (months 21–24), evidence, processing times, and the path to a 10-year card."
  schema={schema}
>

  <style>
    /* Breadcrumb */
    .breadcrumb-bar { background: var(--color-surface); border-bottom: 1px solid var(--color-border); padding: 10px 0; }
    .breadcrumb { display: flex; align-items: center; gap: 8px; list-style: none; font-size: 0.8125rem; color: var(--color-muted); flex-wrap: wrap; }
    .breadcrumb li:not(:last-child)::after { content: '/'; margin-left: 8px; }
    .breadcrumb a { color: var(--color-accent); }

    /* Hero */
    .page-hero { padding: 56px 0 48px; text-align: center; background: linear-gradient(180deg, #f0fdfa 0%, #fff 100%); border-bottom: 1px solid var(--color-border); }
    .hero-badge { display: inline-flex; align-items: center; gap: 6px; background: #ccfbf1; color: #0f766e; font-size: 0.8125rem; font-weight: 600; padding: 6px 14px; border-radius: 999px; margin-bottom: 20px; }
    .page-hero h1 { font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800; letter-spacing: -0.03em; line-height: 1.15; margin-bottom: 16px; }
    .page-hero h1 span { color: #0d9488; }
    .hero-sub { font-size: 1.0625rem; color: var(--color-muted); max-width: 640px; margin: 0 auto 36px; line-height: 1.7; }

    /* Card sequence hero visual */
    .card-sequence { display: flex; align-items: center; justify-content: center; gap: 0; max-width: 680px; margin: 0 auto; flex-wrap: wrap; }
    .card-visual { border-radius: 12px; padding: 20px 24px; text-align: center; min-width: 180px; border: 2px solid; position: relative; }
    .card-visual.card-conditional { background: linear-gradient(135deg, #134e4a 0%, #0f766e 100%); border-color: #0d9488; color: #fff; }
    .card-visual.card-permanent { background: linear-gradient(135deg, #1e3a5f 0%, #1d4ed8 100%); border-color: #3b82f6; color: #fff; }
    .card-type-label { font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.75; margin-bottom: 6px; }
    .card-main-label { font-size: 1.25rem; font-weight: 800; letter-spacing: -0.02em; line-height: 1.1; margin-bottom: 4px; }
    .card-sub-label { font-size: 0.75rem; opacity: 0.8; }
    .card-badge { position: absolute; top: -10px; left: 50%; transform: translateX(-50%); font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 3px 10px; border-radius: 4px; white-space: nowrap; }
    .card-conditional .card-badge { background: #fef3c7; color: #b45309; }
    .card-permanent .card-badge { background: #dbeafe; color: #1d4ed8; }
    .card-arrow-wrap { display: flex; flex-direction: column; align-items: center; padding: 0 8px; min-width: 120px; text-align: center; }
    .card-arrow { font-size: 1.5rem; color: #0d9488; line-height: 1; }
    .card-arrow-label { font-size: 0.7rem; font-weight: 700; color: #0f766e; margin-top: 4px; background: #ccfbf1; border: 1px solid #99f6e4; border-radius: 6px; padding: 4px 10px; line-height: 1.4; }

    /* Summary bar */
    .summary-bar { display: flex; justify-content: center; flex-wrap: wrap; max-width: 680px; margin: 32px auto 0; border: 1px solid #99f6e4; border-radius: 12px; overflow: hidden; background: #fff; }
    .sb-item { flex: 1; min-width: 130px; padding: 16px 20px; text-align: center; border-right: 1px solid #99f6e4; }
    .sb-item:last-child { border-right: none; }
    .sb-val { display: block; font-size: 1.25rem; font-weight: 800; color: #0d9488; letter-spacing: -0.02em; line-height: 1; }
    .sb-label { display: block; font-size: 0.75rem; color: var(--color-muted); margin-top: 4px; line-height: 1.3; }

    /* Layout */
    .content-sidebar-grid { display: grid; grid-template-columns: 1fr 300px; gap: 48px; padding: 48px 0 80px; align-items: start; }
    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.5rem; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 2px solid var(--color-border); }
    .content-section h3 { font-size: 1.125rem; font-weight: 700; margin: 1.5rem 0 0.625rem; }
    .content-section p { color: var(--color-muted); line-height: 1.7; margin-bottom: 0.75rem; }

    /* Alert boxes */
    .alert-box { display: flex; gap: 12px; border-radius: 10px; padding: 1rem 1.25rem; margin: 1rem 0; }
    .alert-info { background: var(--color-accent-light, #eff6ff); border: 1px solid #bfdbfe; }
    .alert-teal { background: #f0fdfa; border: 1px solid #99f6e4; }
    .alert-warning { background: #fffbeb; border: 1px solid #fde68a; }
    .alert-danger { background: #fef2f2; border: 1px solid #fecaca; }
    .alert-icon { font-size: 1.25rem; flex-shrink: 0; margin-top: 2px; }
    .alert-box strong { display: block; font-weight: 700; margin-bottom: 4px; font-size: 0.9375rem; }
    .alert-box p { font-size: 0.875rem; color: var(--color-muted); margin: 0; line-height: 1.6; }

    /* Who gets what */
    .who-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 1.25rem 0; }
    .who-card { border-radius: 12px; padding: 1.25rem; border: 1px solid var(--color-border); }
    .who-conditional { background: #f0fdfa; border-color: #99f6e4; }
    .who-permanent { background: var(--color-surface); }
    .who-icon { font-size: 1.5rem; margin-bottom: 8px; }
    .who-card h3 { font-size: 0.9375rem; font-weight: 700; margin-bottom: 10px; }
    .who-card ul { list-style: none; display: flex; flex-direction: column; gap: 6px; margin: 0; }
    .who-card li { font-size: 0.8375rem; color: var(--color-muted); padding-left: 1.1rem; position: relative; line-height: 1.5; }
    .who-card li::before { content: '·'; position: absolute; left: 0; color: #0d9488; font-weight: 700; font-size: 1rem; }

    /* Paths table */
    .paths-table-wrap { overflow-x: auto; margin: 1.25rem 0; }
    .paths-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; border: 1px solid var(--color-border); border-radius: 10px; overflow: hidden; min-width: 500px; }
    .paths-table th { background: #f0fdfa; padding: 10px 14px; text-align: left; font-weight: 700; border-bottom: 2px solid #99f6e4; color: #134e4a; }
    .paths-table td { padding: 10px 14px; border-bottom: 1px solid var(--color-border); color: var(--color-muted); vertical-align: top; line-height: 1.5; }
    .paths-table tr:last-child td { border-bottom: none; }
    .paths-table .cell-highlight { font-weight: 700; color: #0d9488; }
    .paths-table .cell-blue { font-weight: 700; color: #2563eb; }

    /* I-751 window timeline */
    .window-timeline { margin: 1.5rem 0; }
    .wt-track { display: flex; align-items: stretch; border-radius: 10px; overflow: hidden; border: 1px solid var(--color-border); }
    .wt-seg { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 16px 10px; text-align: center; font-size: 0.8125rem; }
    .wt-seg-label { font-weight: 700; font-size: 0.8125rem; line-height: 1.2; margin-bottom: 4px; }
    .wt-seg-sub { font-size: 0.7125rem; opacity: 0.85; line-height: 1.3; }
    .wt-wait { background: #f9fafb; border-right: 1px solid var(--color-border); color: var(--color-muted); flex: 3; }
    .wt-window { background: #0f766e; color: #fff; flex: 1; position: relative; }
    .wt-window::before { content: 'FILE I-751 HERE'; position: absolute; top: -10px; left: 50%; transform: translateX(-50%); font-size: 0.6rem; font-weight: 800; letter-spacing: 0.1em; background: #fef3c7; color: #92400e; padding: 2px 8px; border-radius: 4px; white-space: nowrap; }
    .wt-expired { background: #fef2f2; border-left: 1px solid #fecaca; color: #dc2626; flex: 1; }
    .wt-labels { display: flex; margin-top: 6px; }
    .wt-label-item { text-align: center; font-size: 0.7rem; color: var(--color-muted); font-weight: 600; }
    .wt-label-item:nth-child(1) { flex: 3; }
    .wt-label-item:nth-child(2) { flex: 1; }
    .wt-label-item:nth-child(3) { flex: 1; }

    /* Filing window cards */
    .window-cards { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; margin: 1.25rem 0; }
    .wc-card { border-radius: 10px; padding: 1.125rem; }
    .wc-green { background: #f0fdf4; border: 1px solid #86efac; }
    .wc-yellow { background: #fffbeb; border: 1px solid #fde68a; }
    .wc-red { background: #fef2f2; border: 1px solid #fecaca; }
    .wc-card h3 { font-size: 0.9rem; font-weight: 700; margin-bottom: 8px; }
    .wc-card p { font-size: 0.8375rem; color: var(--color-muted); margin: 0; line-height: 1.55; }

    /* Joint vs waiver */
    .filing-type-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 1.25rem 0; }
    .ft-card { border-radius: 12px; padding: 1.5rem; border: 1px solid var(--color-border); position: relative; }
    .ft-joint { background: #f0fdf4; border-color: #86efac; }
    .ft-waiver { background: var(--color-surface); }
    .ft-badge { position: absolute; top: -10px; left: 16px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; background: #0d9488; color: #fff; padding: 3px 10px; border-radius: 4px; }
    .ft-badge-gray { background: #6b7280; }
    .ft-card h3 { font-size: 1.0625rem; font-weight: 700; margin-bottom: 8px; }
    .ft-card > p { font-size: 0.875rem; color: var(--color-muted); line-height: 1.6; margin-bottom: 12px; }
    .ft-card > ul { list-style: none; display: flex; flex-direction: column; gap: 5px; margin: 0; }
    .ft-card li { font-size: 0.8375rem; color: var(--color-muted); padding-left: 1.1rem; position: relative; line-height: 1.5; }
    .ft-card li::before { content: '·'; position: absolute; left: 0; color: #0d9488; font-weight: 700; font-size: 1rem; }

    /* Waiver reasons */
    .waiver-reasons { display: flex; flex-direction: column; gap: 8px; margin-top: 10px; }
    .wr-item { display: flex; gap: 10px; align-items: flex-start; background: #fff; border: 1px solid var(--color-border); border-radius: 8px; padding: 10px 12px; }
    .wr-icon { font-size: 1rem; flex-shrink: 0; margin-top: 1px; }
    .wr-item strong { font-size: 0.875rem; display: block; margin-bottom: 2px; }
    .wr-item p { font-size: 0.8rem; color: var(--color-muted); margin: 0; line-height: 1.5; }

    /* Evidence categories */
    .evidence-cats { display: flex; flex-direction: column; gap: 14px; margin: 1.25rem 0; }
    .ev-cat { border: 1px solid var(--color-border); border-radius: 12px; overflow: hidden; }
    .ev-cat-top { border-color: #99f6e4; }
    .ev-cat-header { display: flex; align-items: center; gap: 10px; padding: 0.875rem 1.25rem; background: var(--color-surface); border-bottom: 1px solid var(--color-border); }
    .ev-cat-top .ev-cat-header { background: #f0fdfa; border-color: #99f6e4; }
    .ev-cat-icon { font-size: 1.25rem; }
    .ev-cat-header h3 { font-size: 0.9375rem; font-weight: 700; margin: 0; display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .ev-strength-badge { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; padding: 2px 7px; border-radius: 4px; }
    .badge-strong { background: #dcfce7; color: #15803d; }
    .badge-good { background: #fef3c7; color: #b45309; }
    .badge-helpful { background: #ede9fe; color: #6d28d9; }
    .ev-items-list { padding: 0.25rem 0; }
    .ev-row { display: flex; align-items: flex-start; gap: 12px; padding: 0.75rem 1.25rem; border-bottom: 1px solid var(--color-border); font-size: 0.875rem; }
    .ev-row:last-child { border-bottom: none; }
    .ev-check { flex-shrink: 0; width: 20px; height: 20px; background: #dcfce7; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; color: #16a34a; font-weight: 700; margin-top: 1px; }
    .ev-row strong { display: block; margin-bottom: 2px; color: var(--color-text); }
    .ev-row div { color: var(--color-muted); line-height: 1.5; }

    /* Processing table */
    .info-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; border: 1px solid var(--color-border); border-radius: 10px; overflow: hidden; margin: 1.25rem 0; }
    .info-table th { background: #f0fdfa; padding: 10px 14px; text-align: left; font-weight: 700; border-bottom: 2px solid #99f6e4; color: #134e4a; }
    .info-table td { padding: 10px 14px; border-bottom: 1px solid var(--color-border); color: var(--color-muted); vertical-align: top; line-height: 1.5; }
    .info-table tr:last-child td { border-bottom: none; }

    /* Rights & restrictions */
    .rights-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin: 1.25rem 0; }
    .rights-card { border-radius: 10px; padding: 1.125rem; border: 1px solid var(--color-border); }
    .rights-yes { background: #f0fdf4; border-color: #86efac; }
    .rights-no { background: #fef2f2; border-color: #fecaca; }
    .rights-card-header { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
    .rights-card-icon { font-size: 1.25rem; }
    .rights-card-title { font-weight: 700; font-size: 0.9375rem; }
    .rights-list { list-style: none; display: flex; flex-direction: column; gap: 6px; margin: 0; }
    .rights-list li { font-size: 0.8375rem; color: var(--color-muted); padding-left: 1.1rem; position: relative; line-height: 1.5; }
    .rights-list.yes-list li::before { content: '✓'; position: absolute; left: 0; color: #16a34a; font-weight: 700; font-size: 0.75rem; }
    .rights-list.no-list li::before { content: '✗'; position: absolute; left: 0; color: #dc2626; font-weight: 700; font-size: 0.75rem; }

    /* CTA mid-page */
    .cta-mid { background: linear-gradient(135deg, #f0fdfa 0%, #ccfbf1 100%); border: 1px solid #99f6e4; border-radius: 16px; padding: 2rem; margin: 2rem 0; text-align: center; }
    .cta-mid h3 { font-size: 1.25rem; font-weight: 800; margin-bottom: 8px; color: #134e4a; }
    .cta-mid p { font-size: 0.9375rem; color: #0f766e; margin-bottom: 1.25rem; line-height: 1.6; }
    .cta-btn-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    .btn-primary { display: inline-flex; align-items: center; gap: 6px; background: #0f766e; color: #fff; font-weight: 700; font-size: 0.9375rem; padding: 12px 24px; border-radius: 8px; text-decoration: none; transition: background 0.15s; }
    .btn-primary:hover { background: #0d9488; }
    .btn-secondary { display: inline-flex; align-items: center; gap: 6px; background: #fff; color: #0f766e; font-weight: 700; font-size: 0.9375rem; padding: 12px 24px; border-radius: 8px; text-decoration: none; border: 2px solid #0f766e; transition: background 0.15s; }
    .btn-secondary:hover { background: #f0fdfa; }

    /* Path to citizenship steps */
    .path-steps { display: flex; flex-direction: column; gap: 0; margin: 1.25rem 0; }
    .path-item { display: flex; gap: 16px; align-items: flex-start; padding: 1rem 1.25rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 10px; }
    .path-connector { width: 2px; height: 20px; background: #0d9488; margin-left: calc(1.25rem + 17px); }
    .path-circle { flex-shrink: 0; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.875rem; }
    .path-done { background: #dcfce7; color: #15803d; }
    .path-active { background: #0d9488; color: #fff; }
    .path-pending { background: #f0fdfa; color: #0f766e; border: 2px solid #99f6e4; }
    .path-future { background: var(--color-accent-light, #eff6ff); color: #1d4ed8; }
    .path-item strong { display: block; font-size: 0.9375rem; margin-bottom: 4px; }
    .path-item p { font-size: 0.8375rem; color: var(--color-muted); margin: 0; line-height: 1.55; }

    /* FAQ */
    .faq-list { display: flex; flex-direction: column; border: 1px solid var(--color-border); border-radius: 10px; overflow: hidden; margin: 1rem 0; }
    .faq-item { border-bottom: 1px solid var(--color-border); }
    .faq-item:last-child { border-bottom: none; }
    .faq-item summary { padding: 1rem 1.25rem; font-weight: 600; cursor: pointer; font-size: 0.9375rem; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
    .faq-item summary::after { content: '+'; color: var(--color-accent); font-size: 1.25rem; font-weight: 300; flex-shrink: 0; }
    .faq-item[open] summary::after { content: '−'; }
    .faq-item p { padding: 0 1.25rem 1rem; color: var(--color-muted); font-size: 0.9rem; line-height: 1.7; margin: 0; }

    /* Dark CTA */
    .cta-dark { background: #134e4a; border-radius: 16px; padding: 2.5rem; color: #fff; margin-top: 2rem; text-align: center; }
    .cta-dark h2 { font-size: 1.5rem; font-weight: 800; color: #fff; margin-bottom: 10px; border: none; padding: 0; }
    .cta-dark p { color: #99f6e4; font-size: 1rem; margin-bottom: 1.5rem; line-height: 1.6; }
    .cta-dark-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    .btn-white { display: inline-flex; align-items: center; gap: 6px; background: #fff; color: #134e4a; font-weight: 700; font-size: 0.9375rem; padding: 13px 28px; border-radius: 8px; text-decoration: none; transition: background 0.15s; }
    .btn-white:hover { background: #ccfbf1; }

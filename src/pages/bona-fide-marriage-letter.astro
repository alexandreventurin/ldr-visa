        }
      },
      {
        "@type": "Question",
        "name": "Who should write the bona fide marriage letter?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "There are two types. The couple's own statement is written by the petitioner and/or beneficiary describing their relationship history in their own words. Third-party support letters are written by friends, family members, or colleagues who have personally observed the couple's relationship — either in person or through regular contact over time."
        }

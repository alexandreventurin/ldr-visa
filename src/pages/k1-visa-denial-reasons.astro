---
import Base from '../layouts/Base.astro';
import SmartLink from '../components/SmartLink.astro';

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "K-1 Visa Denial Reasons 2026: Why Applications Get Rejected & How to Avoid It",
    "description": "The most common K-1 fiancé visa denial reasons — from bona fide relationship issues to financial requirements — and exactly what to do to prevent or overcome each one.",
    "url": "https://ldrvisa.org/k1-visa-denial-reasons",
    "dateModified": "2026-04-27",
    "datePublished": "2026-04-27",
    "author": { "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org" },
    "publisher": {
      "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org",
      "logo": { "@type": "ImageObject", "url": "https://ldrvisa.org/favicon.svg" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://ldrvisa.org/k1-visa-denial-reasons" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ldrvisa.org/" },
      { "@type": "ListItem", "position": 2, "name": "K-1 Visa", "item": "https://ldrvisa.org/k1-visa" },
      { "@type": "ListItem", "position": 3, "name": "K-1 Visa Denial Reasons", "item": "https://ldrvisa.org/k1-visa-denial-reasons" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the most common reason for K-1 visa denial?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The most common reason for K-1 visa denial is failure to prove a bona fide relationship — that is, officers are not convinced the couple has a genuine romantic relationship and intends to actually marry. This is typically addressed by submitting stronger evidence: photos together, communication logs, travel records, and statements from people who know the couple."
        }
      },
      {
        "@type": "Question",
        "name": "Can a K-1 visa be denied at the interview?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. The K-1 visa can be denied at the embassy consular interview if the officer is not satisfied with relationship evidence, if the petitioner does not meet income requirements, if the beneficiary has a disqualifying criminal or health record, or if documents are missing or inconsistent. Most denials at this stage result in a 221(g) administrative processing hold rather than an outright refusal."
        }
      },
      {
        "@type": "Question",
        "name": "What does 221(g) refusal mean for a K-1 visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A 221(g) is an administrative processing notice — it is not a final denial. It means the consular officer needs additional information or documents before approving the visa. You must submit the requested documents promptly (usually within one year) or the case may be cancelled. Most 221(g) cases are resolved once the missing evidence is provided."
        }
      },
      {
        "@type": "Question",
        "name": "Can you reapply after a K-1 visa denial?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. If your K-1 visa was denied, you can file a new I-129F petition from scratch and address the reason for denial. If the denial was a 221(g) administrative hold, you respond with the requested documents rather than refiling. If denied under INA 214(b) (failure to prove immigrant intent is not an issue for K-1), or INA 212 grounds, consult an immigration attorney about your specific situation."
        }
      },
      {
        "@type": "Question",
        "name": "Does a K-1 visa denial affect future immigration applications?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A K-1 denial itself does not permanently bar future applications, but the reasons for denial matter. A denial based on fraud findings or certain criminal grounds can create lasting immigration bars. A simple 221(g) or evidence-based denial generally does not affect future petitions if properly addressed."
        }
      },
      {
        "@type": "Question",
        "name": "What income is required for a K-1 visa sponsor?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The petitioner must earn at least 100% of the federal poverty guideline for their household size. For 2026, that is approximately $15,650 for a household of 2. However, USCIS and consular officers prefer to see income at 125% of the poverty level or higher. If income is insufficient, a joint sponsor or assets can be used."
        }
      }
    ]
  }
]);
---

<Base
  title="K-1 Visa Denial Reasons 2026: Why Applications Get Rejected & How to Fix It"
  description="The most common K-1 fiancé visa denial reasons explained — bona fide relationship, income, criminal bars, interview mistakes — and how to prevent or overcome each one."
  schema={schema}
>

  <!-- Breadcrumb -->
  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="breadcrumb">
        <li><a href="/">Home</a></li>
        <li><SmartLink href="/k1-visa">K-1 Visa</SmartLink></li>
        <li aria-current="page">Denial Reasons</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="hero-badge">⚠️ K-1 Visa Guide</div>
      <h1>K-1 Visa Denial Reasons<br/><span>& How to Avoid Them</span></h1>
      <p class="hero-sub">Thousands of K-1 applications are denied every year — often for preventable reasons. Here's exactly why denials happen and what to do about each one.</p>
      <div class="denial-summary-bar">
        <div class="dsb-item">
          <span class="dsb-num">~15%</span>
          <span class="dsb-label">Overall denial rate</span>
        </div>
        <div class="dsb-item">
          <span class="dsb-num">#1</span>
          <span class="dsb-label">Reason: weak relationship proof</span>
        </div>
        <div class="dsb-item">
          <span class="dsb-num">221(g)</span>
          <span class="dsb-label">Most common interview outcome</span>
        </div>
        <div class="dsb-item">
          <span class="dsb-num">✓ Fixable</span>
          <span class="dsb-label">Most denials are preventable</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Main content -->
  <div class="container">
    <div class="content-sidebar-grid">

      <!-- MAIN COLUMN -->
      <main class="main-col">

        <!-- Intro -->
        <section id="overview" class="content-section">
          <h2>Why K-1 Visas Get Denied</h2>
          <p>A K-1 fiancé visa can be denied at two stages: during USCIS petition review (I-129F) or at the embassy consular interview. Most denials happen at the interview stage — and most are preventable with proper preparation and documentation.</p>
          <p>Understanding the exact reason your application could fail gives you a blueprint for building a bulletproof petition. Below we break down every major denial category, how common it is, and the specific fix.</p>

          <div class="alert-box alert-warning">
            <div class="alert-icon">📋</div>
            <div>
              <strong>USCIS vs. Consular Denial</strong>
              <p>USCIS can deny the I-129F petition outright (rare). The consulate can deny at interview via a 221(g) hold (most common) or a formal refusal under a specific INA ground. Each requires a different response strategy.</p>
            </div>
          </div>
        </section>

        <!-- Top denial reasons -->
        <section id="top-reasons" class="content-section">
          <h2>The 8 Most Common K-1 Denial Reasons</h2>

          <!-- Reason 1 -->
          <div class="denial-card" id="reason-relationship">
            <div class="denial-header">
              <div class="denial-num">01</div>
              <div>
                <h3>Failure to Prove a Bona Fide Relationship</h3>
                <span class="denial-freq freq-high">Very Common</span>
              </div>
            </div>
            <p>This is the #1 reason K-1 applications fail. USCIS and consular officers must be convinced your relationship is genuine — not an arrangement to obtain immigration benefits. If your evidence is thin, vague, or inconsistent, expect a denial or a heavy burden of proof at interview.</p>
            <div class="denial-signals">
              <h4>🚩 Red Flags That Trigger Scrutiny</h4>
              <ul>
                <li>No photos together or only a handful from one trip</li>
                <li>Relationship started after only a few days of in-person contact</li>
                <li>Large age gap with no explanation</li>
                <li>Communication records missing or inconsistent</li>
                <li>Different stories about how/when you met</li>
                <li>No evidence of ongoing communication between visits</li>
              </ul>
            </div>
            <div class="denial-fix">
              <h4>✅ The Fix</h4>
              <p>Submit a comprehensive relationship package: 30–50 curated photos across different dates and locations, complete communication logs (WhatsApp exports, call logs), all travel itineraries and passport stamps, love letters or voice messages, and 2–3 support letters from people who know you as a couple. See our full <SmartLink href="/bona-fide-marriage">bona fide marriage evidence guide</SmartLink>.</p>
            </div>
          </div>

          <!-- Reason 2 -->
          <div class="denial-card" id="reason-income">
            <div class="denial-header">
              <div class="denial-num">02</div>
              <div>
                <h3>Petitioner Does Not Meet Income Requirement</h3>
                <span class="denial-freq freq-high">Very Common</span>
              </div>
            </div>
            <p>The U.S. citizen petitioner must demonstrate they can financially support the fiancé(e) without government assistance. If income falls below the federal poverty guideline threshold, USCIS or the consulate will deny.</p>
            <div class="income-table-wrap">
              <table class="info-table">
                <thead>
                  <tr><th>Household Size</th><th>100% Poverty Line</th><th>125% (Recommended)</th></tr>
                </thead>
                <tbody>
                  <tr><td>2 people</td><td>$20,440</td><td>$25,550</td></tr>
                  <tr><td>3 people</td><td>$25,820</td><td>$32,275</td></tr>
                  <tr><td>4 people</td><td>$31,200</td><td>$39,000</td></tr>
                  <tr><td>5 people</td><td>$36,580</td><td>$45,725</td></tr>
                </tbody>
              </table>
              <p class="table-note">2026 federal poverty guidelines (contiguous U.S.). Alaska and Hawaii have higher thresholds.</p>
            </div>
            <div class="denial-fix">
              <h4>✅ The Fix</h4>
              <p>Submit 3 years of tax returns, recent pay stubs, and an employment letter. If income is insufficient, add a joint sponsor who meets the requirement independently, or show assets worth 5× the shortfall. The Affidavit of Support (I-134 at K-1 stage) must account for your full household including any dependents. See our <SmartLink href="/affidavit-of-support">Affidavit of Support guide</SmartLink> for details.</p>
            </div>
          </div>

          <!-- Reason 3 -->
          <div class="denial-card" id="reason-meeting">
            <div class="denial-header">
              <div class="denial-num">03</div>
              <div>
                <h3>Couple Has Not Met in Person Within 2 Years</h3>
                <span class="denial-freq freq-medium">Common</span>
              </div>
            </div>
            <p>K-1 law requires the couple to have met in person within 2 years of filing the I-129F petition. Online-only relationships don't qualify unless a waiver is granted on religious or extreme hardship grounds.</p>
            <div class="denial-fix">
              <h4>✅ The Fix</h4>
              <p>Meet before filing — even one visit counts. Document it thoroughly: passport stamps, flight tickets, hotel bookings, and photos with timestamps. If meeting is genuinely impossible due to extreme hardship or cultural/religious custom (e.g., the foreign national's culture prohibits unmarried couples meeting), file for a waiver with Form I-129F Part 4 and provide detailed evidence.</p>
            </div>
          </div>

          <!-- Reason 4 -->
          <div class="denial-card" id="reason-criminal">
            <div class="denial-header">
              <div class="denial-num">04</div>
              <div>
                <h3>Criminal History (Adam Walsh Act / CIMT / Drug Offenses)</h3>
                <span class="denial-freq freq-medium">Common</span>
              </div>
            </div>
            <p>USCIS scrutinizes the petitioner's criminal history. Under the Adam Walsh Child Protection and Safety Act, a U.S. citizen convicted of a "specified offense against a minor" is automatically prohibited from petitioning for a K-1 visa. Other criminal records can trigger inadmissibility grounds for the beneficiary.</p>
            <div class="two-col-list">
              <div>
                <h4>Petitioner (U.S. Citizen)</h4>
                <ul>
                  <li>Any conviction for a specified offense against a minor — <strong>absolute bar</strong></li>
                  <li>Domestic violence convictions — heavy scrutiny</li>
                  <li>Certain felony convictions — may trigger denial</li>
                </ul>
              </div>
              <div>
                <h4>Beneficiary (Foreign National)</h4>
                <ul>
                  <li>Crimes involving moral turpitude (CIMT)</li>
                  <li>Drug offenses</li>
                  <li>Crimes with 5+ year sentences</li>
                  <li>Trafficking or prostitution history</li>
                </ul>
              </div>
            </div>
            <div class="denial-fix">
              <h4>✅ The Fix</h4>
              <p>Disclose all criminal history on the petition — hiding it is far worse than the record itself. For beneficiary inadmissibility, an I-601 waiver of inadmissibility may be available for non-permanent bars. For petitioner Adam Walsh bars, there is <strong>no waiver</strong> — the prohibition is absolute. Consult an immigration attorney before filing if criminal history is involved.</p>
            </div>
          </div>

          <!-- Reason 5 -->
          <div class="denial-card" id="reason-fraud">
            <div class="denial-header">
              <div class="denial-num">05</div>
              <div>
                <h3>Misrepresentation or Fraud</h3>
                <span class="denial-freq freq-medium">Common</span>
              </div>
            </div>
            <p>Any willful misrepresentation of a material fact on an immigration application can result in permanent inadmissibility under INA §212(a)(6)(C)(i). This includes lying about prior marriages, criminal history, prior visa denials, or the nature of the relationship.</p>
            <div class="alert-box alert-danger">
              <div class="alert-icon">🚫</div>
              <div>
                <strong>This is serious</strong>
                <p>A fraud finding — even for small omissions — can bar the beneficiary from the U.S. for life. Officers are trained to spot inconsistencies and will compare answers across all forms and interviews.</p>
              </div>
            </div>
            <div class="denial-fix">
              <h4>✅ The Fix</h4>
              <p>Be completely honest on every form. If you made a mistake on a prior application, consult an attorney about how to address it proactively. Consistent, truthful documentation is your best protection. Both the petitioner and beneficiary should prepare identical factual timelines of the relationship before the interview.</p>
            </div>
          </div>

          <!-- Reason 6 -->
          <div class="denial-card" id="reason-health">
            <div class="denial-header">
              <div class="denial-num">06</div>
              <div>
                <h3>Medical / Health-Related Inadmissibility</h3>
                <span class="denial-freq freq-low">Less Common</span>
              </div>
            </div>
            <p>The beneficiary must pass a medical exam by a USCIS-designated civil surgeon or panel physician. Certain conditions can trigger inadmissibility: communicable diseases of public health significance, failure to show proof of required vaccinations, or a physical or mental disorder with associated harmful behavior.</p>
            <div class="denial-fix">
              <h4>✅ The Fix</h4>
              <p>Schedule the medical exam with an embassy-approved panel physician early — not at the last minute. Bring vaccination records and obtain any missing vaccines before the exam. For mental health history, having treating physician letters explaining the condition is stable and non-threatening helps. Most health conditions are not grounds for denial; the specific list is published by the CDC.</p>
            </div>
          </div>

          <!-- Reason 7 -->
          <div class="denial-card" id="reason-prior-marriage">
            <div class="denial-header">
              <div class="denial-num">07</div>
              <div>
                <h3>Prior Marriages Not Legally Terminated</h3>
                <span class="denial-freq freq-medium">Common</span>
              </div>
            </div>
            <p>Both parties must be legally free to marry. If a prior marriage was not properly dissolved — through divorce, annulment, or death — the K-1 petition will be denied because the couple cannot legally marry within 90 days of arrival.</p>
            <div class="denial-fix">
              <h4>✅ The Fix</h4>
              <p>Obtain certified copies of all divorce decrees, death certificates, or annulment orders for every prior marriage of both parties. If your foreign partner's prior divorce isn't recognized under U.S. law (some foreign divorces aren't), consult an immigration attorney before filing. Include these documents with your I-129F package and bring originals plus certified translations to the interview.</p>
            </div>
          </div>

          <!-- Reason 8 -->
          <div class="denial-card" id="reason-interview">
            <div class="denial-header">
              <div class="denial-num">08</div>
              <div>
                <h3>Poor Interview Performance / Inconsistent Answers</h3>
                <span class="denial-freq freq-high">Very Common</span>
              </div>
            </div>
            <p>The consular interview is where many K-1 visas are lost — not because the relationship isn't real, but because the applicant is unprepared, nervous, or gives answers that don't match the petition. Officers look for inconsistencies between what was submitted on paper and what the beneficiary says in person.</p>
            <div class="denial-signals">
              <h4>🚩 Common Interview Mistakes</h4>
              <ul>
                <li>Not knowing the petitioner's address, job, or family details</li>
                <li>Inconsistent answers about how/when you met or got engaged</li>
                <li>Unable to describe the relationship timeline coherently</li>
                <li>Bringing incomplete or disorganized documents</li>
                <li>Looking unprepared or unsure about plans to marry</li>
              </ul>
            </div>
            <div class="denial-fix">
              <h4>✅ The Fix</h4>
              <p>Prep with our complete <SmartLink href="/k1-visa-interview">K-1 visa interview guide</SmartLink>. Both partners should create a shared written timeline of the relationship and review it together before the interview. The beneficiary should memorize the petitioner's address, employer, and key family details. Organize documents in labeled folders matching the interview checklist.</p>
            </div>
          </div>
        </section>

        <!-- 221(g) deep dive -->
        <section id="221g" class="content-section">
          <h2>Understanding the 221(g) — The Most Common "Denial"</h2>
          <p>Most K-1 applicants who receive a negative outcome at the interview don't get an outright refusal — they get a <strong>221(g) administrative processing notice</strong>. Understanding what this means is critical.</p>

          <div class="outcome-grid">
            <div class="outcome-card outcome-hold">
              <div class="outcome-icon">📋</div>
              <h3>221(g) Administrative Hold</h3>
              <p><strong>What it means:</strong> Case is paused — not denied. Officer needs more documents or security clearance.</p>
              <p><strong>What to do:</strong> Provide exactly what was requested, as quickly as possible. Follow up if no response in 60 days.</p>
              <p><strong>Timeline:</strong> Resolves in weeks to months depending on what's needed.</p>
              <div class="outcome-badge badge-yellow">Not a Final Denial</div>
            </div>
            <div class="outcome-card outcome-deny">
              <div class="outcome-icon">🚫</div>
              <h3>Hard Refusal (INA 212/214)</h3>
              <p><strong>What it means:</strong> Visa formally refused under a specific ground of inadmissibility or ineligibility.</p>
              <p><strong>What to do:</strong> Consult an immigration attorney. May need to file a waiver or refile with stronger evidence.</p>
              <p><strong>Timeline:</strong> Requires a new petition or waiver process.</p>
              <div class="outcome-badge badge-red">Final — Action Required</div>
            </div>
          </div>

          <h3 style="margin-top: 2rem;">Common 221(g) Requests</h3>
          <div class="checklist-block">
            <div class="cl-item"><span class="cl-icon">📁</span><div><strong>Additional relationship evidence</strong> — More photos, communication records, or support letters</div></div>
            <div class="cl-item"><span class="cl-icon">💰</span><div><strong>Updated financial documents</strong> — Recent pay stubs, tax return, bank statements</div></div>
            <div class="cl-item"><span class="cl-icon">📋</span><div><strong>Police certificates</strong> — From countries where the applicant lived for 6+ months as an adult</div></div>
            <div class="cl-item"><span class="cl-icon">🔍</span><div><strong>Security clearance processing</strong> — Background check that requires more time (no action needed — just wait)</div></div>
            <div class="cl-item"><span class="cl-icon">📄</span><div><strong>Corrected or missing forms</strong> — DS-160 errors, missing signatures, or incomplete medical exam</div></div>
          </div>
        </section>

        <!-- USCIS-level denials -->
        <section id="uscis-denial" class="content-section">
          <h2>USCIS-Level I-129F Denials</h2>
          <p>Less common than consular denials, USCIS can reject the I-129F petition for the following reasons:</p>

          <table class="info-table">
            <thead>
              <tr><th>Denial Reason</th><th>USCIS Basis</th><th>Response</th></tr>
            </thead>
            <tbody>
              <tr>
                <td>Adam Walsh Act bar</td>
                <td>INA §204(a)(1)(A)(viii)</td>
                <td>No waiver — absolute bar</td>
              </tr>
              <tr>
                <td>Prior K-1 abuse / multiple petitions</td>
                <td>INA §204(a)(2)</td>
                <td>Show good cause; attorney required</td>
              </tr>
              <tr>
                <td>Couple has not met in person</td>
                <td>INA §101(a)(15)(K)</td>
                <td>Meet and refile, or file waiver</td>
              </tr>
              <tr>
                <td>Not legally free to marry</td>
                <td>INA §101(a)(15)(K)</td>
                <td>Resolve prior marriage, then refile</td>
              </tr>
              <tr>
                <td>Insufficient evidence of genuine relationship</td>
                <td>INA §204(b)</td>
                <td>Refile with substantially stronger evidence package</td>
              </tr>
              <tr>
                <td>Petitioner not a U.S. citizen</td>
                <td>INA §101(a)(15)(K)</td>
                <td>Only citizens may petition; consider CR-1</td>
              </tr>
            </tbody>
          </table>

          <div class="alert-box alert-info" style="margin-top: 1.5rem;">
            <div class="alert-icon">💡</div>
            <div>
              <strong>USCIS RFE vs. Denial</strong>
              <p>Before a full denial, USCIS usually issues a Request for Evidence (RFE) giving you 87 days to respond with missing information. A denial only comes if you don't respond adequately to the RFE. <strong>Always respond to every RFE completely and on time.</strong></p>
            </div>
          </div>
        </section>

        <!-- After denial -->
        <section id="after-denial" class="content-section">
          <h2>What to Do After a K-1 Denial</h2>

          <div class="steps-list">
            <div class="step-item">
              <div class="step-circle">1</div>
              <div>
                <h3>Understand the Exact Reason</h3>
                <p>Read the denial notice carefully. USCIS decisions cite the specific INA section. Consular 221(g) notices list what documents are needed. A hard refusal will state the specific ground of inadmissibility. You cannot fix what you don't understand.</p>
              </div>
            </div>
            <div class="step-item">
              <div class="step-circle">2</div>
              <div>
                <h3>Consult an Immigration Attorney</h3>
                <p>For anything beyond a straightforward 221(g) document request, get professional advice before taking action. An attorney can assess whether a waiver, appeal, or new filing is the right path — and prevent you from making the situation worse.</p>
              </div>
            </div>
            <div class="step-item">
              <div class="step-circle">3</div>
              <div>
                <h3>For 221(g): Submit Exactly What Was Requested</h3>
                <p>Don't guess — provide precisely what the officer listed. Include a cover letter referencing your case number, organize documents clearly, and submit within the timeframe given (usually one year before the case is administratively closed).</p>
              </div>
            </div>
            <div class="step-item">
              <div class="step-circle">4</div>
              <div>
                <h3>For USCIS Denial: Consider Motion to Reopen or New Filing</h3>
                <p>A Motion to Reopen (Form I-290B) asks USCIS to reconsider based on new evidence. This is time-sensitive (typically 33 days). Alternatively, filing a new I-129F petition from scratch with stronger evidence is often the cleaner path for evidence-based denials.</p>
              </div>
            </div>
            <div class="step-item">
              <div class="step-circle">5</div>
              <div>
                <h3>Address the Root Cause Before Refiling</h3>
                <p>Don't just refile with the same weak application. If denied for lack of relationship evidence, build a much stronger package before refiling. If denied for income, secure a joint sponsor first. Fix the underlying problem — don't just repeat the attempt.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Prevention checklist -->
        <section id="prevention" class="content-section">
          <h2>K-1 Denial Prevention Checklist</h2>
          <p>Use this checklist before filing to eliminate the most common denial triggers:</p>

          <div class="prevention-grid">
            <div class="prev-cat">
              <h3>📸 Relationship Evidence</h3>
              <ul class="check-list">
                <li>30–50 photos together across multiple dates/locations</li>
                <li>6–12 months of communication logs (WhatsApp, email)</li>
                <li>All flight tickets and hotel records for visits</li>
                <li>Passport stamps matching visit dates</li>
                <li>2–3 support letters from friends/family who know the couple</li>
                <li>Engagement photo with date and location</li>
              </ul>
            </div>
            <div class="prev-cat">
              <h3>💰 Financial Documents</h3>
              <ul class="check-list">
                <li>3 most recent federal tax returns (1040)</li>
                <li>3 most recent pay stubs</li>
                <li>Letter from employer confirming job and salary</li>
                <li>Bank statements (3–6 months)</li>
                <li>Joint sponsor documents if income is borderline</li>
                <li>Evidence of assets if income is insufficient</li>
              </ul>
            </div>
            <div class="prev-cat">
              <h3>📄 Legal Documents</h3>
              <ul class="check-list">
                <li>Divorce decree / death certificate for any prior marriage (both parties)</li>
                <li>Certified translations for all foreign-language documents</li>
                <li>Police certificates from all countries lived in as adult</li>
                <li>Birth certificates for both parties</li>
                <li>U.S. citizen's passport or naturalization certificate</li>
              </ul>
            </div>
            <div class="prev-cat">
              <h3>🏥 Medical & Interview</h3>
              <ul class="check-list">
                <li>Schedule medical exam with embassy-approved panel physician</li>
                <li>Bring complete vaccination records to medical exam</li>
                <li>Prepare shared relationship timeline (both partners)</li>
                <li>Know petitioner's address, employer, salary, family members</li>
                <li>Practice common interview questions together</li>
                <li>Organize documents in labeled folders before interview</li>
              </ul>
            </div>
          </div>
        </section>

        <!-- FAQs -->
        <section id="faq" class="content-section">
          <h2>Frequently Asked Questions</h2>
          <div class="faq-list">
            <details class="faq-item">
              <summary>What is the most common reason for K-1 visa denial?</summary>
              <p>The most common reason is failure to prove a bona fide relationship. Officers are not convinced the relationship is genuine. Fix this by submitting a comprehensive evidence package: photos, communication logs, travel records, and support letters — not just a few items.</p>
            </details>
            <details class="faq-item">
              <summary>Can a K-1 visa be denied at the interview?</summary>
              <p>Yes. The embassy consular interview is where most K-1 denials occur. The officer may issue a 221(g) administrative hold (most common) requiring additional documents, or issue a formal refusal under a specific inadmissibility ground. Preparation and organized documentation significantly reduce interview denial risk.</p>
            </details>
            <details class="faq-item">
              <summary>What does a 221(g) refusal mean?</summary>
              <p>A 221(g) is not a final denial — it's an administrative processing notice. The officer needs more information or documents. You respond with exactly what was requested. Most 221(g) cases are resolved once the required evidence is submitted. The case may be cancelled if you don't respond within about one year.</p>
            </details>
            <details class="faq-item">
              <summary>Can you reapply after a K-1 visa denial?</summary>
              <p>Yes. For 221(g) holds, respond with the requested documents rather than refiling. For outright denials, you can file a new I-129F after addressing the reason for denial. Consult an attorney to determine whether a Motion to Reopen, a waiver, or a new filing is the right approach for your situation.</p>
            </details>
            <details class="faq-item">
              <summary>Does a K-1 denial affect future immigration applications?</summary>
              <p>A denial itself does not create a permanent bar, but the reasons for it matter. Fraud findings or certain criminal grounds can permanently affect immigration eligibility. Simple evidence-based or 221(g) denials generally don't bar future petitions if properly addressed. Always disclose prior denials honestly on future applications.</p>
            </details>
            <details class="faq-item">
              <summary>What income is required for a K-1 visa sponsor?</summary>
              <p>The petitioner must meet 100% of the federal poverty guideline for their household size (about $20,440 for a household of 2 in 2026). Consular officers and USCIS prefer 125% or higher. If income falls short, a joint sponsor or documented assets can bridge the gap.</p>
            </details>
          </div>

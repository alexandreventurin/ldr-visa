---
import Base from '../layouts/Base.astro';
import SmartLink from '../components/SmartLink.astro';

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "CR-1 Visa Checklist 2026: Complete Document List for Spousal Visa",
    "description": "The complete CR-1 spousal visa document checklist — every form and document needed for the petitioner, NVC, consular interview, and after arrival, organized by stage.",
    "url": "https://ldrvisa.org/cr1-visa-checklist",
    "dateModified": "2026-04-29",
    "datePublished": "2026-04-29",
    "author": { "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org" },
    "publisher": {
      "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org",
      "logo": { "@type": "ImageObject", "url": "https://ldrvisa.org/favicon.svg" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://ldrvisa.org/cr1-visa-checklist" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ldrvisa.org/" },
      { "@type": "ListItem", "position": 2, "name": "CR-1 Visa", "item": "https://ldrvisa.org/cr1-visa" },
      { "@type": "ListItem", "position": 3, "name": "CR-1 Visa Checklist", "item": "https://ldrvisa.org/cr1-visa-checklist" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What documents does the petitioner need to file Form I-130 for a CR-1 visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The U.S. citizen or lawful permanent resident petitioner must submit: completed Form I-130, Form G-1145 (optional, for e-notification), a copy of their U.S. passport or naturalization certificate, a copy of the marriage certificate, divorce or death certificates for any prior marriages, and the $675 filing fee. If filing abroad at a U.S. embassy or consulate, the process differs slightly."
        }
      },
      {
        "@type": "Question",
        "name": "What does the CR-1 beneficiary bring to the consular interview?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The CR-1 beneficiary must bring to the consular interview: a valid passport, DS-260 immigrant visa application confirmation, the NVC interview appointment letter, original birth certificate with certified translation, police certificates from every country lived in for 6+ months after age 16, the sealed medical exam envelope from the panel physician, I-864 Affidavit of Support (signed by petitioner), all civil documents (marriage certificate, divorce decrees if applicable), and photos of the couple as relationship evidence."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between the I-130 and I-130A?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Form I-130 is the Petition for Alien Relative filed by the petitioner (U.S. citizen or LPR) to establish the qualifying relationship. Form I-130A is a supplemental form that the beneficiary (the foreign spouse) must complete. Both forms are submitted together in the same package to USCIS."
        }
      },
      {
        "@type": "Question",
        "name": "Do CR-1 visa documents need to be translated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. All documents in a language other than English must be accompanied by a certified English translation. The translator must certify that they are competent to translate and that the translation is accurate. USCIS and the National Visa Center (NVC) will not accept untranslated foreign-language documents."
        }
      },
      {
        "@type": "Question",
        "name": "What is the I-864 Affidavit of Support and who needs to file it?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Form I-864 is the Affidavit of Support Under Section 213A. It is required for all immigrant visa applications, including CR-1. The petitioner (and any joint sponsors) must complete it to demonstrate that the immigrant will not become a public charge. The petitioner must show income at or above 125% of the federal poverty guideline for their household size. This is a legally binding contract."
        }
      },
      {
        "@type": "Question",
        "name": "How many photos do I need for the CR-1 visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For the I-130 petition, you typically submit a set of photos as evidence of the bona fide marriage — aim for 20–30 photos showing the couple together across different dates, locations, and occasions. For passport-style photos required for the DS-260 and medical exam, you need 2 standard U.S. visa photos (2x2 inches, white background). More relationship photos submitted with the I-864 package at NVC strengthen the case."
        }
      }
    ]
  }
]);
---

<Base
  title="CR-1 Visa Checklist 2026: Complete Document List for Every Stage"
  description="The complete CR-1 spousal visa checklist — every document for I-130 petition, NVC processing, consular interview, and after arrival. Organized by stage, printable."
  schema={schema}
>

  <!-- Breadcrumb -->
  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="breadcrumb">
        <li><a href="/">Home</a></li>
        <li><SmartLink href="/cr1-visa">CR-1 Visa</SmartLink></li>
        <li aria-current="page">CR-1 Visa Checklist</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="hero-badge">📋 Complete Checklist</div>
      <h1>CR-1 Spousal Visa Checklist <span>2026</span></h1>
      <p class="hero-sub">Every document you need — from the I-130 petition through the consular interview and arrival — organized by stage so nothing gets missed.</p>
      <div class="summary-bar">
        <div class="sb-item">
          <span class="sb-val">4</span>
          <span class="sb-label">Stages covered</span>
        </div>
        <div class="sb-item">
          <span class="sb-val">45+</span>
          <span class="sb-label">Documents listed</span>
        </div>
        <div class="sb-item">
          <span class="sb-val">2026</span>
          <span class="sb-label">Updated guidance</span>
        </div>
        <div class="sb-item">
          <span class="sb-val">✓</span>
          <span class="sb-label">Printable checklist</span>
        </div>
      </div>
    </div>
  </section>

  <div class="container">
    <div class="content-sidebar-grid">

      <!-- MAIN -->
      <main class="main-col">

        <!-- Overview -->
        <section id="overview" class="content-section">
          <h2>CR-1 Visa: 4 Document Stages</h2>
          <p>The CR-1 spousal visa process has four distinct stages, each requiring a different set of documents. Missing a single required item can mean delays, a Request for Evidence (RFE), or a denial at the consular interview. Use this checklist to prepare each package completely before submission.</p>

          <div class="stage-overview-grid">
            <div class="sog-card">
              <div class="sog-num">01</div>
              <h3>I-130 Petition</h3>
              <p>Petitioner files in the U.S. to establish the spousal relationship. USCIS reviews and approves.</p>
              <div class="sog-time">~12–18 months</div>
            </div>
            <div class="sog-card">
              <div class="sog-num">02</div>
              <h3>NVC Processing</h3>
              <p>National Visa Center collects financial documents, DS-260 form, and civil documents from both parties.</p>
              <div class="sog-time">~1–4 months</div>
            </div>
            <div class="sog-card">
              <div class="sog-num">03</div>
              <h3>Consular Interview</h3>
              <p>Beneficiary attends interview at U.S. embassy or consulate in their home country.</p>
              <div class="sog-time">~1–2 months</div>
            </div>
            <div class="sog-card">
              <div class="sog-num">04</div>
              <h3>After Arrival</h3>
              <p>Enter U.S. on CR-1 visa. Green card is mailed automatically. File I-751 after ~2 years.</p>
              <div class="sog-time">~2–4 weeks for card</div>
            </div>
          </div>

          <div class="alert-box alert-info">
            <div class="alert-icon">💡</div>
            <div>
              <strong>CR-1 vs K-1 document differences</strong>
              <p>The CR-1 is for couples already married. Unlike K-1, you file I-130 (not I-129F), the beneficiary enters as a permanent resident immediately, and you submit the I-864 (not I-134) as the financial sponsor form. No 90-day marriage deadline after arrival.</p>
            </div>
          </div>
        </section>

        <!-- Stage 1: I-130 -->
        <section id="stage1" class="content-section">
          <h2>Stage 1 — Form I-130 Petition</h2>
          <p>The petitioner (U.S. citizen or lawful permanent resident) files this package with USCIS to prove a qualifying spousal relationship. File at the USCIS Lockbox facility for your state, or through the USCIS online portal.</p>

          <div class="stage-col-grid">
            <div class="stage-col">
              <div class="col-header col-petitioner">
                <div class="col-icon">🇺🇸</div>
                <h3>Petitioner Documents</h3>
                <div class="col-sub">U.S. citizen or LPR</div>
              </div>
              <div class="checklist-items">
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Form I-130</strong> — Petition for Alien Relative (current edition from uscis.gov)</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Form I-130A</strong> — Supplemental information for spouse beneficiary (completed by beneficiary, submitted with I-130)</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Form G-1145</strong> — E-notification of acceptance (optional, for email/text notification)</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Proof of U.S. citizenship</strong> — Copy of U.S. passport bio page, U.S. birth certificate, or naturalization certificate (Form N-550/N-570)</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Proof of LPR status</strong> — If petitioner is a green card holder: copy of both sides of green card (I-551)</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Marriage certificate</strong> — Certified copy with certified English translation if not in English</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Divorce/death certificates</strong> — For every prior marriage of the petitioner (certified copies + translations)</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Passport-style photos</strong> — 2 photos of petitioner (2×2 in., white background, taken within 6 months)</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Filing fee</strong> — $675 (Form I-130 fee as of 2026). Pay by check, money order, or online</div>
                </div>
                <div class="cl-item cl-item-optional">
                  <div class="cl-box cl-box-opt"></div>
                  <div><strong>Evidence of bona fide marriage</strong> — Photos together, joint financial docs, communication records. Not strictly required at I-130 stage but strengthens the petition</div>
                </div>
              </div>
            </div>

            <div class="stage-col">
              <div class="col-header col-beneficiary">
                <div class="col-icon">🌍</div>
                <h3>Beneficiary Documents</h3>
                <div class="col-sub">Foreign spouse (submitted with I-130)</div>
              </div>
              <div class="checklist-items">
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Passport bio page copy</strong> — Valid passport, copy of photo page</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Birth certificate</strong> — Certified copy with certified English translation</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Divorce/death certificates</strong> — Certified copies for any prior marriages of beneficiary</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Passport-style photos</strong> — 2 photos of beneficiary (2×2 in., white background)</div>
                </div>
              </div>

              <div class="fee-note">
                <div class="fn-icon">💳</div>
                <div>
                  <strong>I-130 Filing Fee: $675</strong>
                  <p>Made payable to "U.S. Department of Homeland Security." Do not send cash. Check uscis.gov for current fee amounts — fees can change.</p>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Stage 2: NVC -->
        <section id="stage2" class="content-section">
          <h2>Stage 2 — NVC Processing</h2>
          <p>Once USCIS approves the I-130, the case is sent to the National Visa Center (NVC). The NVC collects fees, financial support documents, and civil documents from both parties before scheduling the consular interview.</p>

          <div class="nvc-grid">
            <div class="nvc-col">
              <div class="nvc-col-header">
                <span class="nvc-step-badge">2A</span>
                <h3>Petitioner Submits</h3>
              </div>
              <div class="checklist-items">
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Affidavit of Support — Form I-864</strong> — Legally binding financial support contract. Must show income ≥ 125% federal poverty guideline</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Federal tax returns</strong> — Most recent 3 years (IRS transcripts or signed copies with all schedules and W-2s)</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Recent pay stubs</strong> — Most recent 6 months</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Employer letter</strong> — On company letterhead confirming employment, job title, and annual salary</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Bank statements</strong> — Most recent 6–12 months showing account balance</div>
                </div>
                <div class="cl-item cl-item-optional">
                  <div class="cl-box cl-box-opt"></div>
                  <div><strong>Joint sponsor I-864</strong> — If petitioner's income is insufficient; joint sponsor completes their own I-864 with their financial docs</div>
                </div>
                <div class="cl-item cl-item-optional">
                  <div class="cl-box cl-box-opt"></div>
                  <div><strong>I-864EZ</strong> — Simplified version of I-864 if petitioner has only W-2 income and no dependents</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>NVC Immigrant Visa fee</strong> — $325 per beneficiary (pay through ceac.state.gov)</div>
                </div>
              </div>
            </div>

            <div class="nvc-col">
              <div class="nvc-col-header">
                <span class="nvc-step-badge nvc-step-b">2B</span>
                <h3>Beneficiary Submits</h3>
              </div>
              <div class="checklist-items">
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>DS-260 Online Immigrant Visa Application</strong> — Completed online at ceac.state.gov. Detailed application about background, travel history, and family</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Birth certificate</strong> — Original or certified copy with certified English translation</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Marriage certificate</strong> — Certified copy with certified English translation</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Divorce/death certificates</strong> — For each prior marriage (certified + translated)</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Police certificates</strong> — From every country the beneficiary lived in for 6+ months after age 16. Some countries: check embassy-specific requirements</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Military records</strong> — If beneficiary served in the armed forces</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Adoption records</strong> — If beneficiary was adopted</div>
                </div>
              </div>

              <div class="alert-box alert-warning" style="margin-top:1rem;">
                <div class="alert-icon">📅</div>
                <div>
                  <strong>Medical exam — schedule early</strong>
                  <p style="font-size:0.8rem;">The medical exam must be done by a USCIS-approved panel physician in the beneficiary's country. Results are valid for 2 years. Schedule it after NVC requests — not too early. Bring vaccination records.</p>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Stage 3: Interview -->
        <section id="stage3" class="content-section">
          <h2>Stage 3 — Consular Interview Documents</h2>
          <p>This is the most document-intensive stage. The beneficiary attends the interview at the U.S. embassy or consulate. Bring originals of everything — plus photocopies of each document organized in a labeled folder.</p>

          <div class="interview-tip">
            <span class="it-icon">💼</span>
            <div><strong>Pro tip:</strong> Organize documents in labeled tabbed folders matching the categories below. Bring originals + 1 photocopy of each. The officer will keep some originals, so do not bring irreplaceable documents without having copies secured at home.</div>
          </div>

          <div class="interview-doc-cats">

            <div class="idc-cat">
              <div class="idc-header idc-identity">
                <span class="idc-icon">🪪</span>
                <h3>Identity &amp; Travel Documents</h3>
              </div>
              <div class="checklist-items idc-items">
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Valid passport</strong> — Must be valid for at least 6 months beyond intended entry date. Bring the passport + all old passports if previously issued.</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>DS-260 confirmation page</strong> — The barcode page printed from ceac.state.gov after submitting your DS-260</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>NVC interview appointment letter</strong> — The official appointment notice from the embassy</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Passport-style photos</strong> — 2 photos (2×2 in., white background, taken within 6 months) — even if submitted before, bring fresh ones</div>
                </div>
              </div>
            </div>

            <div class="idc-cat">
              <div class="idc-header idc-civil">
                <span class="idc-icon">📄</span>
                <h3>Civil Documents</h3>
              </div>
              <div class="checklist-items idc-items">
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Birth certificate</strong> — Original certified copy with certified English translation</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Marriage certificate</strong> — Original certified copy with certified English translation</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Divorce decrees / death certificates</strong> — For ALL prior marriages of both petitioner and beneficiary (certified + translated)</div>
                </div>
                <div class="cl-item cl-item-optional">
                  <div class="cl-box cl-box-opt"></div>
                  <div><strong>Adoption records</strong> — If beneficiary was adopted</div>
                </div>
                <div class="cl-item cl-item-optional">
                  <div class="cl-box cl-box-opt"></div>
                  <div><strong>Name change documents</strong> — Court order or legal document if beneficiary uses a different name</div>
                </div>
              </div>
            </div>

            <div class="idc-cat">
              <div class="idc-header idc-police">
                <span class="idc-icon">🚔</span>
                <h3>Police &amp; Medical Certificates</h3>
              </div>
              <div class="checklist-items idc-items">
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Police certificate(s)</strong> — From every country the beneficiary lived in for 6+ months after age 16. Check the embassy's specific requirements — some countries use a central registry, others require local certificates</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Medical exam results — sealed envelope</strong> — Completed by a USCIS-approved panel physician. Do NOT open the sealed envelope — the embassy opens it at the interview</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Vaccination records</strong> — Bring your immunization record to show the panel physician at the medical exam; bring a copy to the interview as backup</div>
                </div>
              </div>
            </div>

            <div class="idc-cat">
              <div class="idc-header idc-financial">
                <span class="idc-icon">💰</span>
                <h3>Financial Support Documents</h3>
              </div>
              <div class="checklist-items idc-items">
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Form I-864 Affidavit of Support</strong> — Original signed by petitioner. This is the version prepared for NVC — same document brought to interview</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Petitioner's most recent tax return</strong> — IRS transcript or signed 1040 with W-2s</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Recent pay stubs</strong> — Last 3–6 months of petitioner's pay stubs</div>
                </div>
                <div class="cl-item cl-item-optional">
                  <div class="cl-box cl-box-opt"></div>
                  <div><strong>Joint sponsor I-864</strong> — If used, bring signed original + their financial documents</div>
                </div>
              </div>
            </div>

            <div class="idc-cat">
              <div class="idc-header idc-relationship">
                <span class="idc-icon">💑</span>
                <h3>Relationship Evidence</h3>
              </div>
              <div class="checklist-items idc-items">
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Photos of the couple</strong> — 20–30 printed photos spanning the relationship and marriage: wedding, travel, holidays, everyday life. Include captions with dates and locations</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Communication records</strong> — WhatsApp chat exports, call logs, email threads — showing ongoing contact throughout the relationship</div>
                </div>
                <div class="cl-item">
                  <div class="cl-box"></div>
                  <div><strong>Travel records</strong> — Flight tickets, hotel bookings, passport stamps from visits together</div>
                </div>
                <div class="cl-item cl-item-optional">
                  <div class="cl-box cl-box-opt"></div>
                  <div><strong>Joint financial evidence</strong> — Joint bank account, joint lease, or shared bills if couple has been living together</div>
                </div>
                <div class="cl-item cl-item-optional">
                  <div class="cl-box cl-box-opt"></div>
                  <div><strong>Support letters</strong> — 2–3 letters from friends or family who know the couple and can attest to the genuine nature of the marriage</div>
                </div>
              </div>
            </div>

          </div>
        </section>

        <!-- Stage 4: After Arrival -->
        <section id="stage4" class="content-section">
          <h2>Stage 4 — After Arrival in the U.S.</h2>
          <p>When you enter the U.S. on a CR-1 visa, you are already a conditional permanent resident. Your immigrant visa serves as evidence of LPR status for the first year. The green card (I-551) is mailed to your U.S. address automatically within a few weeks of entry.</p>

          <div class="arrival-timeline">
            <div class="at-item">
              <div class="at-circle at-entry">✈️</div>
              <div class="at-content">
                <h3>Upon Entry</h3>
                <div class="checklist-items">
                  <div class="cl-item">
                    <div class="cl-box cl-box-done"></div>
                    <div><strong>Passport stamped at POE</strong> — CBP officer stamps your passport. This stamp + visa serves as temporary proof of LPR status</div>
                  </div>
                  <div class="cl-item">
                    <div class="cl-box cl-box-done"></div>
                    <div><strong>Pay USCIS Immigrant Fee</strong> — $220 fee paid at pay.gov within 1 year of entry. Required to receive your green card</div>
                  </div>
                  <div class="cl-item">
                    <div class="cl-box cl-box-done"></div>
                    <div><strong>Confirm mailing address with USCIS</strong> — Ensure USCIS has your correct U.S. address for green card delivery</div>
                  </div>
                </div>
              </div>
            </div>

            <div class="at-connector"></div>

            <div class="at-item">
              <div class="at-circle at-weeks">📬</div>
              <div class="at-content">
                <h3>First 2–4 Weeks</h3>
                <div class="checklist-items">
                  <div class="cl-item">
                    <div class="cl-box cl-box-done"></div>
                    <div><strong>Receive conditional green card (CR-1)</strong> — Mailed to your U.S. address. Valid for 2 years. Keep in a safe place.</div>
                  </div>
                  <div class="cl-item">
                    <div class="cl-box cl-box-done"></div>
                    <div><strong>Apply for Social Security Number</strong> — Visit your local SSA office with passport and green card</div>
                  </div>
                  <div class="cl-item">
                    <div class="cl-box cl-box-done"></div>
                    <div><strong>Get state ID or driver's license</strong> — Requires green card, SSN, and proof of address</div>
                  </div>
                </div>
              </div>
            </div>

            <div class="at-connector"></div>

            <div class="at-item">
              <div class="at-circle at-iyear">📋</div>
              <div class="at-content">
                <h3>~21 Months After Green Card</h3>
                <div class="checklist-items">
                  <div class="cl-item">
                    <div class="cl-box cl-box-done"></div>
                    <div><strong>File Form I-751</strong> — Petition to Remove Conditions on Residence. File during the 90-day window before the CR-1 card expires. See our <SmartLink href="/i-751-petition-remove-conditions">I-751 guide</SmartLink>.</div>
                  </div>
                  <div class="cl-item">
                    <div class="cl-box cl-box-done"></div>
                    <div><strong>Pay I-751 filing fee</strong> — $750 (2026). Submit with evidence of ongoing bona fide marriage</div>
                  </div>
                </div>
              </div>
            </div>

            <div class="at-connector"></div>

            <div class="at-item">
              <div class="at-circle at-citizen">🇺🇸</div>
              <div class="at-content">
                <h3>3 Years After Green Card — Citizenship Eligible</h3>
                <div class="checklist-items">
                  <div class="cl-item">
                    <div class="cl-box cl-box-done"></div>
                    <div><strong>File Form N-400</strong> — Naturalization application. Spouses of U.S. citizens qualify after 3 years of LPR status (not the standard 5)</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Translation rules -->
        <section id="translations" class="content-section">
          <h2>Document Translation Requirements</h2>
          <p>Every document not in English must be accompanied by a certified English translation. Here's exactly what that means:</p>

          <div class="trans-cards">
            <div class="trans-card trans-required">
              <div class="tc-icon">✅</div>
              <h3>What "Certified Translation" Means</h3>
              <ul>
                <li>Any person can translate the document — they do not need to be a licensed translator</li>
                <li>The translator must sign a certification statement: "I certify that I am competent to translate [language] into English and that this translation is accurate and complete"</li>
                <li>The certification must include the translator's name, address, date, and signature</li>
                <li>Machine translations (Google Translate) are <strong>not acceptable</strong> without human certification</li>
              </ul>
            </div>
            <div class="trans-card trans-tips">
              <div class="tc-icon">💡</div>
              <h3>Translation Tips</h3>
              <ul>
                <li>Use a professional translation service for complex legal documents (birth certificates, divorce decrees)</li>
                <li>Keep original documents — USCIS/consulate may keep the translation but return the original</li>
                <li>Translate every field on the document, including stamps, seals, and notary marks</li>
                <li>One translator per document is sufficient — you do not need multiple certified translators</li>
                <li>For police certificates: check whether the embassy requires a specific certified translator or notary</li>
              </ul>
            </div>
          </div>
        </section>

        <!-- Common mistakes -->
        <section id="mistakes" class="content-section">
          <h2>Common Checklist Mistakes That Cause Delays</h2>
          <div class="mistakes-grid">
            <div class="mistake-card">
              <div class="mk-num">01</div>
              <h3>Using an outdated I-130 form version</h3>
              <p>USCIS updates forms periodically. Submitting a prior version gets the entire package rejected. Always download from uscis.gov immediately before filing.</p>
            </div>
            <div class="mistake-card">
              <div class="mk-num">02</div>
              <h3>Missing police certificates from all countries</h3>
              <p>Many applicants forget they lived in a second country (for college, work, or travel) for 6+ months. Every country counts — omitting one triggers an RFE or interview denial.</p>
            </div>
            <div class="mistake-card">
              <div class="mk-num">03</div>
              <h3>Opening the sealed medical exam envelope</h3>
              <p>The panel physician gives you a sealed medical envelope to bring to the interview. If you open it, the results are invalid — you'll need a new medical exam.</p>
            </div>
            <div class="mistake-card">
              <div class="mk-num">04</div>
              <h3>I-864 income below 125% poverty line</h3>
              <p>The most common NVC rejection. The I-864 requires 125% of the federal poverty guideline for the petitioner's household size. If income is borderline, add a joint sponsor before filing.</p>
            </div>
            <div class="mistake-card">
              <div class="mk-num">05</div>
              <h3>Forgetting prior marriages of either spouse</h3>
              <p>Both petitioner and beneficiary must disclose and document every prior marriage. An undisclosed prior marriage discovered at interview can result in a fraud finding.</p>
            </div>
            <div class="mistake-card">
              <div class="mk-num">06</div>
              <h3>Insufficient relationship evidence</h3>
              <p>Officers look for evidence that the marriage is genuine — not just a marriage certificate. Thin photo evidence or no financial ties raises flags. Submit evidence across multiple categories.</p>
            </div>
          </div>
        </section>

        <!-- FAQ -->
        <section id="faq" class="content-section">
          <h2>Frequently Asked Questions</h2>
          <div class="faq-list">
            <details class="faq-item">
              <summary>What documents does the petitioner need to file Form I-130?</summary>
              <p>The petitioner files: completed Form I-130 + I-130A, proof of U.S. citizenship or LPR status, a certified copy of the marriage certificate with translation, divorce/death certificates for any prior marriages, passport-style photos of both petitioner and beneficiary, and the $675 filing fee. Optional but helpful: evidence of a bona fide marriage (photos, financial ties).</p>
            </details>
            <details class="faq-item">
              <summary>What does the CR-1 beneficiary bring to the consular interview?</summary>
              <p>Bring: valid passport, DS-260 confirmation page, NVC appointment letter, original birth certificate with certified translation, marriage certificate, police certificates from all countries lived in for 6+ months after age 16, sealed medical exam envelope, Form I-864 from petitioner, recent financial documents, and 20–30 relationship photos. Organize in labeled folders — originals plus photocopies.</p>
            </details>
            <details class="faq-item">
              <summary>What is the difference between Form I-130 and I-130A?</summary>
              <p>Form I-130 is filed by the petitioner to establish the qualifying spousal relationship. Form I-130A is a supplemental form completed by the beneficiary (the foreign spouse) providing additional biographical information. Both are submitted together in the same package to USCIS at filing.</p>
            </details>
            <details class="faq-item">
              <summary>Do CR-1 visa documents need to be translated?</summary>
              <p>Yes — all documents not in English must have a certified English translation attached. The translator certifies their competence and the accuracy of the translation with their signature, name, address, and date. Professional translation services are recommended for complex legal documents. Machine translations alone are not acceptable.</p>
            </details>
            <details class="faq-item">
              <summary>What is the I-864 and who must file it?</summary>
              <p>Form I-864 (Affidavit of Support Under Section 213A) is a legally binding contract in which the petitioner commits to financially support the immigrant. It is required for all CR-1 immigrant visa applications. The petitioner must show income at or above 125% of the federal poverty guideline for their household size. If income is insufficient, a joint sponsor completes a separate I-864 with their own financial documentation.</p>
            </details>
            <details class="faq-item">
              <summary>How many photos do I need for the CR-1 visa?</summary>
              <p>Two categories: (1) Passport-style photos — 2 per person (2×2 in., white background) for official applications and the medical exam. (2) Relationship evidence photos — 20–30 printed photos of the couple together at different dates, locations, and events. Include captions with dates and locations. The more genuine and varied the evidence, the stronger the case.</p>
            </details>
          </div>
        </section>


  .qa-num { color: var(--color-accent); font-weight: 800; font-size: 0.875rem; flex-shrink: 0; min-width: 28px; }
  .qa-a { padding: 14px 18px 14px 58px; background: #fff; border-top: 1px solid var(--color-border); }
  .qa-answer-label { font-size: 0.75rem; font-weight: 700; color: #16a34a; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px; }
  .qa-a p { font-size: 0.9375rem; color: #374151; line-height: 1.65; margin: 0; }

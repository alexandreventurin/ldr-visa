---
import Base from '../layouts/Base.astro';
import SmartLink from '../components/SmartLink.astro';

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Marriage Green Card Interview Questions 2026: 60+ Q&As to Prepare You",
    "description": "Every question you'll face at your AOS or consular marriage green card interview — organized by category, with what officers are really testing and how to answer confidently.",
    "url": "https://ldrvisa.org/marriage-green-card-interview-questions",
    "datePublished": "2026-04-30",
    "dateModified": "2026-04-30",
    "author": { "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org" },
    "publisher": {
      "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org",
      "logo": { "@type": "ImageObject", "url": "https://ldrvisa.org/favicon.svg" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://ldrvisa.org/marriage-green-card-interview-questions" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ldrvisa.org/" },
      { "@type": "ListItem", "position": 2, "name": "Green Card Through Marriage", "item": "https://ldrvisa.org/green-card-through-marriage" },
      { "@type": "ListItem", "position": 3, "name": "Interview Questions", "item": "https://ldrvisa.org/marriage-green-card-interview-questions" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Do both spouses attend the marriage green card interview?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For an Adjustment of Status (AOS) interview at a USCIS local office, both spouses must attend together. For a CR-1 consular interview at a U.S. embassy abroad, only the foreign spouse attends — the U.S. citizen does not go to the embassy. In both cases, the interviewing officer may ask each spouse questions separately to compare answers."
        }
      },
      {
        "@type": "Question",
        "name": "What is a Stokes interview and why does it happen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A Stokes interview (sometimes called a marriage fraud interview) is a separate-rooms interview where USCIS questions each spouse independently and compares answers. It typically happens when an officer has concerns about the legitimacy of the marriage — red flags like a very short marriage before filing, large age gaps, no shared language, or suspiciously thin evidence. If your answers diverge on key questions, the officer may issue a Request for Evidence or deny the petition. Real couples almost always have some discrepancies on minor details; what matters is consistency on major facts."
        }
      },
      {
        "@type": "Question",
        "name": "What happens if our answers don't match at the interview?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Minor discrepancies on small details are completely normal — genuine couples don't have memorized identical answers for every question. Officers expect some variation. If an answer diverges, calmly explain: 'We may remember it differently. What I recall is...' The concern is major factual contradictions — wrong spouse's birthday, completely different accounts of how you met, different addresses. Those trigger follow-up. Small differences in details like what you ate at a restaurant or the exact shade of your wedding flowers do not."
        }
      },
      {
        "@type": "Question",
        "name": "How long does the marriage green card interview take?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Standard AOS interviews at USCIS typically last 30–60 minutes. Consular CR-1 interviews are often shorter, around 15–30 minutes. If the officer has questions or concerns, the interview can run longer. A Stokes separate-rooms interview may take 1–2 hours total since both spouses are questioned independently and answers are compared."
        }
      },
      {
        "@type": "Question",
        "name": "What documents should I bring to the marriage green card interview?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For an AOS interview: your USCIS appointment notice, both spouses' passports, your marriage certificate, joint financial documents (bank statements, tax returns, leases), photos together, any prior divorce decrees, and the I-485, I-130, and I-864 petitions. For a CR-1 consular interview: passport, DS-260 confirmation, I-797 approval notice, medical exam envelope, birth certificate, marriage certificate, financial documents, and relationship evidence. Organize everything in a labeled tabbed folder."
        }
      },
      {
        "@type": "Question",
        "name": "Can a marriage green card be denied at the interview?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, though outright denials at the interview are not the most common outcome. More frequently, an officer will issue a Request for Evidence (RFE) asking for more proof of the marriage's legitimacy, or place the case in administrative processing. Actual denials happen when the officer finds the marriage fraudulent, a spouse is inadmissible for another reason, or there are serious inconsistencies. Consulting an immigration attorney before the interview significantly reduces the risk of a denial."
        }
      }
    ]
  }
]);
---

<Base
  title="Marriage Green Card Interview Questions 2026: 60+ Q&As to Prepare You"
  description="Every question you'll face at your AOS or consular marriage green card interview — organized by category, with what officers are really testing and how to answer confidently."
  schema={schema}
>

  <style>
    /* ── Color theme: Purple/violet ── */
    :root {
      --vi: #6d28d9;
      --vi-light: #ede9fe;
      --vi-dark: #4c1d95;
      --vi-border: #c4b5fd;
      --vi-mid: #7c3aed;
    }

    /* Breadcrumb */
    .breadcrumb-bar { background: #faf5ff; border-bottom: 1px solid var(--vi-border); padding: 10px 0; }
    .breadcrumb { display: flex; align-items: center; gap: 8px; list-style: none; font-size: 0.8125rem; color: #6b7280; flex-wrap: wrap; margin: 0; padding: 0; }
    .breadcrumb li:not(:last-child)::after { content: '/'; margin-left: 8px; color: #9ca3af; }
    .breadcrumb a { color: var(--vi); text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }

    /* Container */
    .container { max-width: 1120px; margin: 0 auto; padding: 0 24px; }

    /* Hero */
    .page-hero {
      padding: 60px 0 52px;
      text-align: center;
      background: linear-gradient(160deg, #f5f3ff 0%, #ede9fe 40%, #faf5ff 100%);
      border-bottom: 1px solid var(--vi-border);
    }
    .hero-badge {
      display: inline-block;
      background: var(--vi-light);
      color: var(--vi);
      font-size: 0.775rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 4px 14px;
      border-radius: 20px;
      margin-bottom: 18px;
      border: 1px solid var(--vi-border);
    }
    .page-hero h1 {
      font-size: clamp(1.875rem, 4.5vw, 3rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1.12;
      margin-bottom: 18px;
      color: #1e1b4b;
    }
    .page-hero h1 span { color: var(--vi); }
    .hero-sub {
      font-size: 1.0625rem;
      color: #4b5563;
      max-width: 640px;
      margin: 0 auto 32px;
      line-height: 1.75;
    }
    .hero-reassure {
      display: inline-block;
      background: #ecfdf5;
      color: #065f46;
      border: 1px solid #a7f3d0;
      border-radius: 8px;
      padding: 10px 20px;
      font-size: 0.9375rem;
      font-weight: 600;
      margin-bottom: 32px;
    }

    /* Stats bar */
    .stats-bar {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0;
      border: 1px solid var(--vi-border);
      border-radius: 12px;
      overflow: hidden;
      max-width: 720px;
      margin: 0 auto;
      background: #fff;
    }
    .stat-item {
      flex: 1;
      min-width: 130px;
      padding: 16px 20px;
      text-align: center;
      border-right: 1px solid var(--vi-border);
    }
    .stat-item:last-child { border-right: none; }
    .stat-num { display: block; font-size: 1.375rem; font-weight: 800; color: var(--vi); letter-spacing: -0.02em; line-height: 1; }
    .stat-label { display: block; font-size: 0.75rem; color: #6b7280; margin-top: 4px; line-height: 1.35; }

    /* Layout */
    .content-wrap {
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 52px;
      padding: 52px 0 88px;
      align-items: start;
    }
    .main-col { min-width: 0; }

    /* Sections */
    .content-section { margin-bottom: 3.25rem; }
    .content-section h2 {
      font-size: 1.5625rem;
      font-weight: 800;
      letter-spacing: -0.025em;
      margin-bottom: 1rem;
      padding-bottom: 0.625rem;
      border-bottom: 2px solid var(--vi-border);
      color: var(--vi-dark);
    }
    .content-section h3 { font-size: 1.0625rem; font-weight: 700; margin: 1.5rem 0 0.625rem; color: #1e1b4b; }
    .content-section p { color: #4b5563; line-height: 1.75; margin-bottom: 0.875rem; }
    .section-intro { font-size: 1rem; color: #4b5563; margin-bottom: 1.5rem; line-height: 1.75; }

    /* Interview type comparison */
    .interview-compare {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin: 1.5rem 0;
    }
    .interview-card {
      border-radius: 12px;
      padding: 1.375rem 1.5rem;
      border: 2px solid;
    }
    .interview-card.aos {
      background: #f5f3ff;
      border-color: var(--vi-border);
    }
    .interview-card.consular {
      background: #eff6ff;
      border-color: #bfdbfe;
    }
    .ic-label {
      font-size: 0.725rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding: 3px 10px;
      border-radius: 20px;
      display: inline-block;
      margin-bottom: 10px;
    }
    .ic-label.aos { background: var(--vi-light); color: var(--vi); }
    .ic-label.consular { background: #dbeafe; color: #1d4ed8; }
    .interview-card h3 { font-size: 1.0625rem; font-weight: 800; margin: 0 0 12px; color: #1e1b4b; }
    .ic-row {
      display: flex;
      gap: 8px;
      font-size: 0.85rem;
      margin-bottom: 7px;
      align-items: flex-start;
      line-height: 1.5;
    }
    .ic-row-label { font-weight: 700; color: #374151; flex-shrink: 0; min-width: 90px; }
    .ic-row-val { color: #4b5563; }

    /* Q&A cards */
    .qa-category-label {
      font-size: 0.775rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--vi);
      margin-bottom: 0.875rem;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .qa-category-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--vi-border);
    }
    .qa-card {
      border: 1px solid var(--vi-border);
      border-radius: 10px;
      padding: 1rem 1.25rem;
      margin-bottom: 10px;
      background: #faf8ff;
      transition: border-color 0.2s, background 0.2s;
    }
    .qa-card:hover { border-color: var(--vi); background: #f5f3ff; }
    .qa-q {
      font-weight: 700;
      font-size: 0.9375rem;
      color: var(--vi-dark);
      margin-bottom: 6px;
      line-height: 1.45;
      display: flex;
      gap: 8px;
      align-items: flex-start;
    }
    .qa-q::before {
      content: 'Q';
      flex-shrink: 0;
      background: var(--vi);
      color: #fff;
      font-size: 0.7rem;
      font-weight: 800;
      padding: 2px 6px;
      border-radius: 4px;
      margin-top: 1px;
    }
    .qa-hint {
      font-size: 0.845rem;
      color: #6b7280;
      line-height: 1.65;
      padding-left: 26px;
    }

    /* Stokes section */
    .stokes-box {
      background: #fef9c3;
      border: 2px solid #fde047;
      border-radius: 12px;
      padding: 1.5rem 1.75rem;
      margin: 1.5rem 0;
    }
    .stokes-box h3 { font-size: 1.125rem; font-weight: 800; color: #713f12; margin: 0 0 10px; }
    .stokes-box p { color: #713f12; font-size: 0.9rem; line-height: 1.7; margin-bottom: 0.625rem; }
    .stokes-box p:last-child { margin-bottom: 0; }
    .stokes-badge {
      display: inline-block;
      background: #fde047;
      color: #713f12;
      font-size: 0.725rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      padding: 3px 10px;
      border-radius: 4px;
      margin-bottom: 12px;
    }

    /* Stokes tips */
    .stokes-tips { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 14px; }
    .stokes-tip {
      background: #fff;
      border: 1px solid #fde047;
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 0.845rem;
      color: #713f12;
      line-height: 1.55;
    }
    .stokes-tip strong { display: block; font-weight: 700; margin-bottom: 3px; }

    /* CTA mid-page */
    .cta-mid {
      background: var(--vi-dark);
      border-radius: 14px;
      padding: 1.75rem 2rem;
      margin: 2rem 0;
      color: #fff;
      display: flex;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }
    .cta-mid-text { flex: 1; min-width: 200px; }
    .cta-mid-text h3 { font-size: 1.125rem; font-weight: 800; margin: 0 0 6px; color: #fff; }
    .cta-mid-text p { font-size: 0.9rem; color: #ddd6fe; margin: 0; line-height: 1.6; }
    .cta-mid-btn {
      display: inline-block;
      background: #a78bfa;
      color: #1e1b4b;
      font-weight: 700;
      font-size: 0.9rem;
      padding: 12px 22px;
      border-radius: 8px;
      text-decoration: none;
      white-space: nowrap;
      transition: background 0.2s;
    }
    .cta-mid-btn:hover { background: #c4b5fd; }

    /* Red flags */
    .red-flags-list { display: flex; flex-direction: column; gap: 10px; margin: 1.25rem 0; }
    .red-flag-item {
      display: flex;
      gap: 12px;
      align-items: flex-start;
      background: #fff5f5;
      border: 1px solid #fecaca;
      border-radius: 8px;
      padding: 12px 16px;
    }
    .rf-icon { font-size: 1.125rem; flex-shrink: 0; margin-top: 1px; }
    .rf-title { font-weight: 700; font-size: 0.9375rem; color: #991b1b; margin-bottom: 3px; }
    .rf-desc { font-size: 0.845rem; color: #4b5563; line-height: 1.6; }

    /* Evidence checklist */
    .evidence-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 1.25rem 0; }
    .evidence-cat {
      background: #faf8ff;
      border: 1px solid var(--vi-border);
      border-radius: 10px;
      padding: 1.25rem;
    }
    .evidence-cat h3 {
      font-size: 0.9375rem;
      font-weight: 700;
      margin: 0 0 0.75rem;
      color: var(--vi-dark);
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .evidence-list { list-style: none; display: flex; flex-direction: column; gap: 7px; margin: 0; padding: 0; }
    .evidence-list li {
      font-size: 0.8375rem;
      color: #4b5563;
      padding-left: 1.375rem;
      position: relative;
      line-height: 1.5;
    }
    .evidence-list li::before {
      content: '✓';
      position: absolute;
      left: 0;
      color: var(--vi);
      font-weight: 800;
    }

    /* Day-of tips */
    .tips-grid { display: flex; flex-direction: column; gap: 1rem; }
    .tip-item {
      display: flex;
      gap: 14px;
      align-items: flex-start;
      padding: 1rem 1.25rem;
      background: #faf8ff;
      border: 1px solid var(--vi-border);
      border-radius: 10px;
    }
    .tip-num {
      flex-shrink: 0;
      width: 36px;
      height: 36px;
      background: var(--vi);
      color: #fff;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      font-size: 0.875rem;
      margin-top: 1px;
    }
    .tip-item strong { display: block; font-size: 0.9375rem; font-weight: 700; color: #1e1b4b; margin-bottom: 4px; }
    .tip-item p { font-size: 0.875rem; color: #6b7280; margin: 0; line-height: 1.65; }

    /* Answer mismatch */
    .mismatch-box {
      background: #f5f3ff;
      border: 1px solid var(--vi-border);
      border-radius: 12px;
      padding: 1.5rem 1.75rem;
      margin: 1.25rem 0;
    }
    .mismatch-box h3 { font-size: 1rem; font-weight: 800; color: var(--vi-dark); margin: 0 0 8px; }
    .mismatch-box p { font-size: 0.9rem; color: #4b5563; line-height: 1.7; margin-bottom: 0.625rem; }
    .mismatch-box p:last-child { margin-bottom: 0; }

    /* Outcomes */
    .outcome-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; margin: 1.25rem 0; }
    .outcome-card { border-radius: 12px; padding: 1.375rem; border: 1px solid; }
    .outcome-card.approved { background: #f0fdf4; border-color: #bbf7d0; }
    .outcome-card.mail { background: #eff6ff; border-color: #bfdbfe; }
    .outcome-card.rfe { background: #fffbeb; border-color: #fde68a; }
    .outcome-card.denied { background: #fff5f5; border-color: #fecaca; }
    .outcome-icon { font-size: 1.5rem; margin-bottom: 0.625rem; }
    .outcome-card h3 { font-size: 0.9375rem; font-weight: 800; margin: 0 0 0.625rem; }
    .outcome-card.approved h3 { color: #065f46; }
    .outcome-card.mail h3 { color: #1e40af; }
    .outcome-card.rfe h3 { color: #92400e; }
    .outcome-card.denied h3 { color: #991b1b; }
    .outcome-card p { font-size: 0.8125rem; color: #4b5563; line-height: 1.55; margin-bottom: 0.5rem; }
    .outcome-badge {
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      padding: 3px 8px;
      border-radius: 4px;
      display: inline-block;
      margin-top: 4px;
    }
    .badge-green { background: #dcfce7; color: #166534; }
    .badge-blue { background: #dbeafe; color: #1e40af; }
    .badge-yellow { background: #fef3c7; color: #b45309; }
    .badge-red { background: #fee2e2; color: #b91c1c; }

    /* FAQ */
    .faq-list {
      display: flex;
      flex-direction: column;
      border: 1px solid var(--vi-border);
      border-radius: 12px;
      overflow: hidden;
    }
    .faq-item { border-bottom: 1px solid var(--vi-border); }
    .faq-item:last-child { border-bottom: none; }
    .faq-item summary {
      padding: 1rem 1.375rem;
      font-weight: 600;
      cursor: pointer;
      font-size: 0.9375rem;
      list-style: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: #1e1b4b;
      background: #faf8ff;
      transition: background 0.15s;
    }
    .faq-item summary:hover { background: #f5f3ff; }
    .faq-item summary::after { content: '+'; color: var(--vi); font-size: 1.375rem; font-weight: 300; flex-shrink: 0; margin-left: 12px; }
    .faq-item[open] summary::after { content: '−'; }
    .faq-item p { padding: 0 1.375rem 1.125rem; color: #4b5563; font-size: 0.9rem; line-height: 1.75; margin: 0; }

    /* Alert */
    .alert-box { display: flex; gap: 12px; border-radius: 10px; padding: 1rem 1.25rem; margin: 1.25rem 0; }
    .alert-info { background: var(--vi-light); border: 1px solid var(--vi-border); }
    .alert-warning { background: #fffbeb; border: 1px solid #fde68a; }
    .alert-success { background: #ecfdf5; border: 1px solid #a7f3d0; }
    .alert-icon { font-size: 1.25rem; flex-shrink: 0; margin-top: 2px; }
    .alert-box strong { display: block; font-weight: 700; margin-bottom: 4px; font-size: 0.9375rem; }
    .alert-box p { font-size: 0.875rem; color: #4b5563; margin: 0; line-height: 1.65; }

    /* Related guides */
    .related-guides { margin-top: 2.5rem; padding-top: 2rem; border-top: 2px solid var(--vi-border); }
    .related-guides h2 { font-size: 1.25rem; font-weight: 800; margin-bottom: 1rem; color: var(--vi-dark); border: none; padding: 0; }
    .related-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }

    /* CTA bottom */
    .cta-bottom {
      background: var(--vi-dark);
      border-radius: 16px;
      padding: 2.25rem 2.5rem;
      margin-top: 3rem;
      text-align: center;
      color: #fff;
    }
    .cta-bottom h2 { font-size: 1.5rem; font-weight: 800; margin: 0 0 12px; color: #fff; border: none; padding: 0; }
    .cta-bottom p { color: #ddd6fe; font-size: 0.9375rem; max-width: 520px; margin: 0 auto 20px; line-height: 1.7; }
    .cta-bottom-btn {
      display: inline-block;
      background: #a78bfa;
      color: #1e1b4b;
      font-weight: 800;
      font-size: 1rem;
      padding: 14px 28px;
      border-radius: 10px;
      text-decoration: none;
      transition: background 0.2s;
    }
    .cta-bottom-btn:hover { background: #c4b5fd; }

    /* Sidebar */
    .sidebar {
      position: sticky;
      top: 80px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
    .sidebar-card {
      background: #fff;
      border: 1px solid var(--vi-border);
      border-radius: 12px;
      overflow: hidden;
    }
    .sidebar-card-title {
      padding: 12px 18px;
      font-size: 0.8125rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--vi);
      border-bottom: 1px solid var(--vi-border);
      background: var(--vi-light);
    }
    .sidebar-link {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 9px 18px;
      font-size: 0.875rem;
      color: #374151;
      text-decoration: none;
      border-bottom: 1px solid #f3f4f6;
      transition: background 0.15s, color 0.15s;
    }
    .sidebar-link:last-child { border-bottom: none; }
    .sidebar-link:hover { background: var(--vi-light); color: var(--vi); }
    .sidebar-link span { color: #9ca3af; font-size: 0.8rem; }

    /* Prep checklist in sidebar */
    .prep-checklist { padding: 14px 18px; display: flex; flex-direction: column; gap: 8px; }
    .prep-item {
      display: flex;
      gap: 10px;
      align-items: flex-start;
      font-size: 0.845rem;

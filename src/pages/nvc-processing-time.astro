---
import Base from '../layouts/Base.astro';
import SmartLink from '../components/SmartLink.astro';

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "NVC Processing Time 2026: How Long Does NVC Take?",
    "description": "Current NVC processing times for 2026 — how long each stage takes after USCIS approval, what speeds it up or slows it down, and how to check your case status.",
    "url": "https://ldrvisa.org/nvc-processing-time",
    "dateModified": "2026-04-29",
    "datePublished": "2026-04-29",
    "author": { "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org" },
    "publisher": {
      "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org",
      "logo": { "@type": "ImageObject", "url": "https://ldrvisa.org/favicon.svg" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://ldrvisa.org/nvc-processing-time" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ldrvisa.org/" },
      { "@type": "ListItem", "position": 2, "name": "NVC Processing Time", "item": "https://ldrvisa.org/nvc-processing-time" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How long does NVC processing take in 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "NVC processing typically takes 3–6 months in 2026 for CR-1 spousal visas. This covers the time from when NVC receives your approved I-130 from USCIS to when they schedule your immigrant visa interview at the embassy. The main stages are: fee invoice generation (2–6 weeks), fee payment and document submission (2–4 weeks), NVC document review (4–12 weeks), and interview scheduling (2–6 weeks after case completion)."
        }
      },
      {
        "@type": "Question",
        "name": "What is the NVC and what do they do?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The National Visa Center (NVC) is a processing center run by the U.S. Department of State. After USCIS approves your immigrant visa petition, NVC receives the case and manages the transition from USCIS to the U.S. embassy or consulate in your country. They collect visa fees, review supporting documents, run preliminary eligibility checks, and schedule the immigrant visa interview."
        }
      },
      {
        "@type": "Question",
        "name": "How do I check my NVC case status?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You can check your NVC case status at ceac.state.gov using your NVC case number (format: XXX2024000000). You can also log into the Consular Electronic Application Center (CEAC) portal to see your document checklist status and whether NVC has completed your case. NVC also contacts you by email when your case moves to a new stage."
        }
      },
      {
        "@type": "Question",
        "name": "What can delay NVC processing?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Common NVC delays include: missing or incomplete documents (NVC sends an RFE and waits for your response), civil documents requiring official translation, financial documents not meeting the poverty guideline threshold, police certificates that have expired (must be less than 12 months old for most countries), and NVC processing backlogs. Administrative processing (221(g)) after the interview can add weeks or months."
        }
      },
      {
        "@type": "Question",
        "name": "Does NVC processing time differ for K-1 vs CR-1?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. The K-1 fiancé visa does not go through NVC — after USCIS approves the I-129F petition, the case goes directly to the U.S. embassy abroad. Only immigrant visas (CR-1, IR-1, F-2A family preference) go through NVC. K-1 petitions skip the NVC stage entirely, which is one reason K-1 total processing can sometimes be faster."
        }
      },
      {
        "@type": "Question",
        "name": "What is 'Case Initiated' at NVC?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "\"Case Initiated\" is the first CEAC status after USCIS transfers your approved I-130 to NVC. It means NVC has received the case and created your file. Within 2–6 weeks of this status, NVC will generate your fee invoice and send instructions to pay the immigrant visa application fee ($325) and, for CR-1 cases, the Affidavit of Support fee ($120)."
        }
      }
    ]
  }
]);
---

<Base
  title="NVC Processing Time 2026: How Long Does NVC Take?"
  description="Current NVC processing times for 2026 — stage-by-stage breakdown, what causes delays, how to check your case status, and tips to move faster."
  schema={schema}
>

<style>

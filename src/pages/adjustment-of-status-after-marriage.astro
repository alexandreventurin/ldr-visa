---
import Base from '../layouts/Base.astro';
import SmartLink from '../components/SmartLink.astro';

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Adjustment of Status After Marriage 2026: AOS for Married Couples Guide",
    "description": "How to file Adjustment of Status (I-485) after marrying a U.S. citizen — eligibility, required forms, fees, timeline, EAD/Advance Parole, and what happens at the AOS interview.",
    "url": "https://ldrvisa.org/adjustment-of-status-after-marriage",
    "datePublished": "2026-04-28",
    "dateModified": "2026-04-28",
    "author": { "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org" },
    "publisher": {
      "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org",
      "logo": { "@type": "ImageObject", "url": "https://ldrvisa.org/favicon.svg" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://ldrvisa.org/adjustment-of-status-after-marriage" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ldrvisa.org/" },
      { "@type": "ListItem", "position": 2, "name": "Adjustment of Status", "item": "https://ldrvisa.org/adjustment-of-status" },
      { "@type": "ListItem", "position": 3, "name": "After Marriage", "item": "https://ldrvisa.org/adjustment-of-status-after-marriage" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Can I work while my Adjustment of Status is pending?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes — but only once USCIS approves your Employment Authorization Document (EAD, Form I-765). You can file Form I-765 concurrently with your I-485 at no additional cost. EADs typically arrive within 3–6 months of filing. Until your EAD is approved and in hand, you are not authorized to work based on a pending I-485 alone."
        }
      },
      {
        "@type": "Question",
        "name": "Can I travel outside the U.S. while my Adjustment of Status is pending?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Not without Advance Parole. If you leave the U.S. while your I-485 is pending and you do not have an approved Advance Parole document (Form I-131), USCIS will consider your I-485 abandoned and your case will be closed. File Form I-131 at the same time as your I-485 to protect your ability to travel. Wait until the Advance Parole card is physically in hand before boarding any international flight."
        }
      },
      {
        "@type": "Question",
        "name": "How long does Adjustment of Status take after marriage in 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The total AOS timeline for spouses of U.S. citizens in 2026 is approximately 12–24 months from filing to green card approval, depending on the USCIS field office, application volume, and whether any RFEs or additional processing is required. EAD and Advance Parole cards typically arrive within 3–6 months, allowing the applicant to work and travel while the full case is pending."
        }
      },
      {
        "@type": "Question",
        "name": "What if I entered the U.S. on a tourist visa — can I still file for AOS?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Generally yes, if you were lawfully inspected and admitted and you married a U.S. citizen. Immediate relatives of U.S. citizens are not barred from adjusting status simply because they entered on a nonimmigrant visa such as a B-1/B-2 tourist visa, as long as they were admitted — not visa-waiver (VWP) entrants. Visa Waiver Program entrants can generally only adjust status if they are an immediate relative. The key requirement is that you were lawfully admitted or paroled — not that you entered on a specific visa category."
        }
      },
      {
        "@type": "Question",
        "name": "What if my I-485 is denied?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If your I-485 is denied, USCIS will send a denial notice explaining the reason. You may be able to file a Motion to Reopen (I-290B) within 33 days if there was a legal or factual error. If the denial was for inadmissibility, an I-601 waiver may be available for certain grounds. In some cases, you may be referred to immigration court for removal proceedings, where an immigration judge can review your case. Consult an immigration attorney immediately after any I-485 denial."
        }
      },
      {
        "@type": "Question",
        "name": "Do I need a lawyer for Adjustment of Status after marriage?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Not legally required, but strongly recommended if you have any complicating factors: prior removal orders, criminal history, previous visa overstays, prior denials, or health-related inadmissibility grounds. Many straightforward AOS cases — especially for couples who entered lawfully on a K-1 and simply need to adjust — are handled successfully without an attorney. If your situation is clean and simple, USCIS instructions and guides like this one are sufficient. When in doubt, a consultation with an immigration attorney (typically $150–$300) is money well spent."
        }
      }
    ]
  }
]);
---

<Base
  title="Adjustment of Status After Marriage 2026: AOS for Married Couples Guide"
  description="How to file Adjustment of Status (I-485) after marrying a U.S. citizen — eligibility, required forms, fees, timeline, EAD/Advance Parole, and what happens at the AOS interview."
  schema={schema}
>

  <!-- Breadcrumb -->
  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="breadcrumb">
        <li><a href="/">Home</a></li>
        <li><SmartLink href="/adjustment-of-status">Adjustment of Status</SmartLink></li>
        <li aria-current="page">After Marriage</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="hero-badge">Green Card Guide</div>
      <h1>Adjustment of Status<br/><span>After Marriage</span></h1>
      <p class="hero-sub">How to file Form I-485 and get your green card after marrying a U.S. citizen — forms, fees, timeline, EAD, Advance Parole, and interview prep all in one place.</p>
      <div class="aos-summary-bar">
        <div class="asb-item">
          <span class="asb-num">File Together</span>
          <span class="asb-label">I-130 + I-485 concurrent</span>
        </div>
        <div class="asb-item">
          <span class="asb-num">12–24 mo</span>
          <span class="asb-label">Typical total timeline</span>
        </div>
        <div class="asb-item">
          <span class="asb-num">EAD Included</span>
          <span class="asb-label">Work while waiting</span>
        </div>
        <div class="asb-item">
          <span class="asb-num">1 Interview</span>
          <span class="asb-label">Local USCIS field office</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Main content -->
  <div class="container">
    <div class="content-sidebar-grid">

      <!-- MAIN COLUMN -->
      <main class="main-col">

        <!-- Who can file -->
        <section id="eligibility" class="content-section">
          <h2>Who Can File AOS After Marriage</h2>
          <p>Adjustment of Status (AOS) lets an eligible foreign national obtain a U.S. green card without leaving the country. After marrying a U.S. citizen, the foreign spouse qualifies as an <strong>immediate relative</strong> — meaning there is no visa number wait, no annual cap, and no queue. You can file as soon as you are married.</p>

          <p>To be eligible for AOS after marriage, you must meet all of the following:</p>

          <div class="eligibility-grid">
            <div class="elig-item elig-yes">
              <div class="elig-icon">✓</div>
              <div>
                <strong>Married to a U.S. citizen</strong>
                <p>The petitioner must be a U.S. citizen — not a Lawful Permanent Resident (LPR). Spouses of LPRs have a different, longer process (F2A preference category with visa wait times).</p>
              </div>
            </div>
            <div class="elig-item elig-yes">
              <div class="elig-icon">✓</div>
              <div>
                <strong>Inspected and admitted or paroled into the U.S.</strong>
                <p>You must have entered the U.S. lawfully — through a port of entry where a CBP officer reviewed your documents. Individuals who entered without inspection (EWI) generally cannot adjust status inside the U.S.</p>
              </div>
            </div>
            <div class="elig-item elig-yes">
              <div class="elig-icon">✓</div>
              <div>
                <strong>Not subject to certain bars to adjustment</strong>
                <p>Bars include: prior deportation or removal orders, certain criminal grounds, immigration fraud, prior AOS denials on inadmissibility grounds, and failure to maintain continuous lawful status (with some exceptions for immediate relatives).</p>
              </div>
            </div>
            <div class="elig-item elig-yes">
              <div class="elig-icon">✓</div>
              <div>
                <strong>Admissible to the United States</strong>
                <p>You must be admissible, or eligible for a waiver of any inadmissibility ground. Common grounds include certain health conditions, criminal history, prior immigration violations, and public charge concerns (addressed by I-864).</p>
              </div>
            </div>
          </div>

          <div class="alert-box alert-teal" style="margin-top: 1.5rem;">
            <div class="alert-icon">💍</div>
            <div>
              <strong>K-1 Visa Holders: Special Rule</strong>
              <p>If you entered on a K-1 fiancé visa, you <strong>must marry your U.S. citizen petitioner within 90 days</strong> of entry. After the marriage, you file I-485 — and you do <em>not</em> need a separate I-130 petition because the approved I-129F serves the same function. K-1 holders also cannot marry anyone other than the original petitioner and still adjust status on the K-1.</p>
            </div>
          </div>
        </section>

        <!-- K-1 vs direct AOS -->
        <section id="paths" class="content-section">
          <h2>K-1 Path vs. Direct AOS Path</h2>
          <p>There are two main ways to get a green card after marrying a U.S. citizen, depending on where you are when you marry.</p>

          <div class="path-grid">
            <div class="path-card path-k1">
              <div class="path-label">K-1 Fiancé Path</div>
              <div class="path-steps">
                <div class="path-step">File I-129F petition</div>
                <div class="path-arrow">↓</div>
                <div class="path-step">K-1 visa interview abroad</div>
                <div class="path-arrow">↓</div>
                <div class="path-step">Enter U.S. on K-1 visa</div>
                <div class="path-arrow">↓</div>
                <div class="path-step">Marry within 90 days</div>
                <div class="path-arrow">↓</div>
                <div class="path-step path-highlight">File I-485 (no I-130 needed)</div>
                <div class="path-arrow">↓</div>
                <div class="path-step">AOS interview → Green card</div>
              </div>
              <div class="path-note">Best when: couple is not yet married and fiancé(e) is outside the U.S.</div>
            </div>
            <div class="path-card path-direct">
              <div class="path-label">Already in U.S. Path</div>
              <div class="path-steps">
                <div class="path-step">Currently in U.S. (any valid status)</div>
                <div class="path-arrow">↓</div>
                <div class="path-step">Marry U.S. citizen</div>
                <div class="path-arrow">↓</div>
                <div class="path-step path-highlight">File I-130 + I-485 concurrently</div>
                <div class="path-arrow">↓</div>
                <div class="path-step">Biometrics + EAD/AP</div>
                <div class="path-arrow">↓</div>
                <div class="path-step">AOS interview → Green card</div>
              </div>
              <div class="path-note">Best when: couple is already married and foreign spouse is in the U.S.</div>
            </div>
          </div>

          <div class="alert-box alert-info" style="margin-top: 1.5rem;">
            <div class="alert-icon">✈️</div>
            <div>
              <strong>Outside the U.S.? Consider CR-1/IR-1 Consular Processing</strong>
              <p>If the foreign spouse is outside the U.S., the alternative to AOS is consular processing — filing I-130 with USCIS, having it transferred to a U.S. embassy, and attending a visa interview abroad. The result is a CR-1 or IR-1 immigrant visa that becomes a green card upon entry. See our <SmartLink href="/cr1-visa">CR-1 visa guide</SmartLink> for details.</p>
            </div>
          </div>
        </section>

        <!-- Forms required -->
        <section id="forms" class="content-section">
          <h2>Forms Required for AOS After Marriage</h2>
          <p>Most couples file the following forms as a single package to USCIS. Filing together reduces fees and speeds up EAD and Advance Parole approval.</p>

          <table class="info-table">
            <thead>
              <tr><th>Form</th><th>Purpose</th><th>Fee (2026)</th><th>Notes</th></tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>I-485</strong></td>
                <td>Application to Register Permanent Residence (main AOS form)</td>
                <td><strong>$1,440</strong></td>
                <td>The core filing. Includes biometrics fee.</td>
              </tr>
              <tr>
                <td><strong>I-130</strong></td>
                <td>Petition for Alien Relative (establishes relationship)</td>
                <td><strong>$675</strong></td>
                <td>Not needed for K-1 holders — approved I-129F serves this purpose.</td>
              </tr>
              <tr>
                <td><strong>I-864</strong></td>
                <td>Affidavit of Support (sponsor's financial commitment)</td>
                <td><strong>$0</strong></td>
                <td>Required from U.S. citizen spouse. Joint sponsor may be added if needed.</td>
              </tr>
              <tr>
                <td><strong>I-765</strong></td>
                <td>Application for Employment Authorization (EAD)</td>
                <td><strong>$0</strong></td>
                <td>Free when filed concurrently with I-485. File separately costs $520.</td>
              </tr>
              <tr>
                <td><strong>I-131</strong></td>
                <td>Application for Travel Document (Advance Parole)</td>
                <td><strong>$0</strong></td>
                <td>Free when filed concurrently with I-485. Allows international travel while AOS is pending.</td>
              </tr>
              <tr>
                <td><strong>I-693</strong></td>
                <td>Medical Examination (completed by USCIS-designated civil surgeon)</td>
                <td><strong>~$200–$500</strong></td>
                <td>Civil surgeon sets their own fee. Must be sealed and submitted unopened.</td>
              </tr>
            </tbody>
          </table>

          <div class="fee-note-box">
            <strong>Total Government Fees:</strong> ~$2,115 for non-K-1 filers (I-485 + I-130) or ~$1,440 for K-1 holders. Plus civil surgeon fee (~$200–$500). EAD and Advance Parole are free when filed with I-485.
          </div>
        </section>

        <!-- Step-by-step process -->
        <section id="process" class="content-section">
          <h2>Step-by-Step AOS Process</h2>

          <div class="steps-list">
            <div class="step-item">
              <div class="step-circle">1</div>
              <div>
                <h3>File I-130 + I-485 Concurrently (or I-485 Alone)</h3>
                <p>Assemble your complete package: I-130 (if not already approved), I-485, I-864, I-765, I-131, I-693, civil documents, and supporting evidence. Mail to the correct USCIS lockbox based on your state of residence. K-1 holders skip I-130 and file I-485 with a copy of their approved I-129F.</p>
              </div>
            </div>
            <div class="step-item">
              <div class="step-circle">2</div>
              <div>
                <h3>Receive Receipt Notices (Form I-797C)</h3>
                <p>USCIS sends a receipt notice (Form I-797C) for each form filed — typically within 2–4 weeks of receipt. Keep these: the I-485 receipt notice is proof of pending status. You can use it alongside a valid foreign passport or an expired EAD for some purposes while waiting.</p>
              </div>
            </div>
            <div class="step-item">
              <div class="step-circle">3</div>
              <div>
                <h3>Biometrics Appointment (ASC)</h3>
                <p>USCIS schedules you for a biometrics appointment at an Application Support Center (ASC). You provide fingerprints, a photograph, and a signature. This takes about 15 minutes. Bring your receipt notice and a government-issued photo ID. Biometrics are used for background checks.</p>
              </div>
            </div>
            <div class="step-item">
              <div class="step-circle">4</div>
              <div>
                <h3>EAD and Advance Parole Card Received</h3>
                <p>USCIS mails a combo card (EAD + Advance Parole on one card) approximately 3–6 months after filing. Once you receive this card, you are authorized to work and, with the Advance Parole designation, to travel internationally without abandoning your AOS case.</p>
              </div>
            </div>
            <div class="step-item">
              <div class="step-circle">5</div>
              <div>
                <h3>Respond to Any RFE (If Issued)</h3>
                <p>USCIS may issue a Request for Evidence (RFE) asking for additional documentation — more relationship evidence, updated financial documents, or a new medical exam if the I-693 has expired. Respond completely and within the deadline (typically 87 days). An incomplete or late RFE response leads to denial.</p>
              </div>
            </div>
            <div class="step-item">
              <div class="step-circle">6</div>
              <div>
                <h3>AOS Interview at Local USCIS Field Office</h3>
                <p>USCIS schedules an interview at your local field office. Both the U.S. citizen spouse and the applicant typically attend. The officer reviews relationship evidence, verifies form accuracy, and assesses admissibility. Bring the complete document package. Most approvals happen at the interview.</p>
              </div>
            </div>
            <div class="step-item">
              <div class="step-circle">7</div>
              <div>
                <h3>Green Card Approval and Card Production</h3>
                <p>After approval, USCIS updates the case status online and mails the green card (Form I-551) within 2–4 weeks. The card is valid for 2 years (conditional) or 10 years (permanent) depending on how long you have been married at the time of approval.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Timeline -->
        <section id="timeline" class="content-section">
          <h2>AOS Timeline After Marriage (2026 Estimates)</h2>
          <p>Processing times vary by USCIS field office and individual circumstances. These are typical ranges based on 2026 data.</p>

          <table class="info-table timeline-table">
            <thead>
              <tr><th>Stage</th><th>Estimated Time</th><th>Notes</th></tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>Receipt notices</strong></td>
                <td>2–4 weeks</td>
                <td>Confirms USCIS received your package</td>
              </tr>
              <tr>
                <td><strong>Biometrics appointment</strong></td>
                <td>1–3 months after filing</td>
                <td>ASC appointment for fingerprints and photo</td>
              </tr>
              <tr>
                <td><strong>EAD + Advance Parole</strong></td>
                <td>3–6 months after filing</td>
                <td>Combo card; work and travel authorization</td>
              </tr>
              <tr>
                <td><strong>Interview scheduling</strong></td>
                <td>8–18 months after filing</td>
                <td>Varies significantly by field office</td>
              </tr>
              <tr>
                <td><strong>Post-interview decision</strong></td>
                <td>Same day or within weeks</td>
                <td>Most approvals happen at the interview</td>
              </tr>
              <tr>
                <td><strong>Green card in mail</strong></td>
                <td>2–4 weeks after approval</td>
                <td>Physical card mailed to home address</td>
              </tr>
              <tr class="timeline-total">
                <td><strong>Total</strong></td>
                <td><strong>~12–24 months</strong></td>
                <td>From filing to green card in hand</td>
              </tr>
            </tbody>
          </table>

          <p style="margin-top: 1rem;">Check current processing times for your specific field office on the <a href="https://egov.uscis.gov/processing-times/" target="_blank" rel="noopener">USCIS processing times tool</a>.</p>
        </section>

        <!-- EAD and Advance Parole -->
        <section id="ead-ap" class="content-section">
          <h2>EAD and Advance Parole While AOS Is Pending</h2>
          <p>Two of the most important benefits of a pending I-485 are the ability to obtain work authorization and travel permission while you wait for your green card.</p>

          <div class="benefit-grid">
            <div class="benefit-card">
              <div class="benefit-icon">💼</div>
              <h3>Employment Authorization Document (EAD)</h3>
              <p>The EAD authorizes you to work for any employer in the United States. It is issued as a physical card and replaces any employer-specific work authorization from a prior nonimmigrant status (e.g., OPT, H-4 EAD). File Form I-765 with your I-485 package — at no extra cost — to get it as fast as possible.</p>
              <ul class="benefit-list">
                <li>Valid for 2 years (renewable)</li>
                <li>Works for any employer — not tied to a sponsor</li>
                <li>File renewal 180 days before expiration</li>
              </ul>
            </div>
            <div class="benefit-card">
              <div class="benefit-icon">✈️</div>
              <h3>Advance Parole (Travel Document)</h3>
              <p>Advance Parole allows you to leave and re-enter the United States while your I-485 is pending without abandoning your case. Without it, any international travel will cause USCIS to consider your AOS application abandoned — and it will be closed.</p>
              <ul class="benefit-list">
                <li>Valid for 2 years (renewable)</li>
                <li>Wait until the physical card is in hand before traveling</li>
                <li>Emergency Advance Parole available at local USCIS offices</li>
              </ul>
            </div>
          </div>

          <div class="alert-box alert-danger" style="margin-top: 1.5rem;">
            <div class="alert-icon">⚠️</div>
            <div>
              <strong>Do NOT Travel Without Advance Parole</strong>
              <p>Leaving the United States while your I-485 is pending — even for a short trip — without an approved Advance Parole document will result in USCIS treating your application as abandoned. Your I-485 will be closed and you will have to start the process over. There is no grace period and exceptions are extremely rare. Always have the physical card before boarding any international flight.</p>
            </div>
          </div>

          <h3 style="margin-top: 1.5rem;">The Combo Card</h3>
          <p>USCIS issues EAD and Advance Parole as a single "combo card" — one card that serves both functions. It is coded with category "C09P" and shows both your work authorization and travel permission. Renew it at least 180 days before expiration to avoid gaps in work authorization.</p>
        </section>

        <!-- AOS Interview -->
        <section id="interview" class="content-section">
          <h2>AOS Interview — What to Expect</h2>
          <p>The AOS interview at your local USCIS field office is the final major step before green card approval. Both spouses typically attend together. The interview usually lasts 20–45 minutes.</p>

          <h3>What the Officer Reviews</h3>
          <div class="review-grid">
            <div class="review-item">
              <div class="review-num">01</div>
              <div>
                <strong>Bona fide marriage</strong>
                <p>Is the marriage genuine, or was it entered solely to obtain immigration benefits? The officer will ask questions about your relationship, living situation, and shared life.</p>
              </div>
            </div>
            <div class="review-item">
              <div class="review-num">02</div>
              <div>
                <strong>Form accuracy</strong>
                <p>The officer compares your interview answers to what was submitted on your forms. Any discrepancies — even innocent mistakes — trigger follow-up questions.</p>
              </div>
            </div>
            <div class="review-item">
              <div class="review-num">03</div>
              <div>
                <strong>Admissibility</strong>
                <p>The officer confirms there are no outstanding inadmissibility issues: criminal history, health grounds, prior immigration bars, or public charge concerns.</p>
              </div>
            </div>
            <div class="review-item">
              <div class="review-num">04</div>
              <div>
                <strong>Petitioner's income</strong>
                <p>The U.S. citizen sponsor must demonstrate ability to support their spouse. The officer may ask about current employment, salary, and household expenses.</p>
              </div>
            </div>
          </div>

          <h3 style="margin-top: 1.5rem;">Common Interview Questions</h3>
          <div class="question-list">
            <div class="q-item"><span class="q-bullet">Q</span><span>How did you meet? Where and when did you first meet in person?</span></div>
            <div class="q-item"><span class="q-bullet">Q</span><span>When and where did you get married? Who attended the ceremony?</span></div>
            <div class="q-item"><span class="q-bullet">Q</span><span>What is your spouse's current job and where do they work?</span></div>
            <div class="q-item"><span class="q-bullet">Q</span><span>Describe your home — how many rooms, what floor do you live on?</span></div>
            <div class="q-item"><span class="q-bullet">Q</span><span>What do you and your spouse do on weekends? What did you do last weekend?</span></div>
            <div class="q-item"><span class="q-bullet">Q</span><span>Do you have any joint accounts, shared leases, or joint insurance?</span></div>
            <div class="q-item"><span class="q-bullet">Q</span><span>What are your plans for building a life together in the U.S.?</span></div>
          </div>

          <h3 style="margin-top: 1.5rem;">Documents to Bring to the AOS Interview</h3>
          <div class="doc-checklist">
            <div class="doc-item"><span class="doc-check">✓</span><span>USCIS interview appointment notice</span></div>
            <div class="doc-item"><span class="doc-check">✓</span><span>Valid passport (applicant and sponsor)</span></div>
            <div class="doc-item"><span class="doc-check">✓</span><span>EAD/Advance Parole combo card (if received)</span></div>
            <div class="doc-item"><span class="doc-check">✓</span><span>Original marriage certificate + certified translation</span></div>
            <div class="doc-item"><span class="doc-check">✓</span><span>Divorce decrees or death certificates for any prior marriages</span></div>
            <div class="doc-item"><span class="doc-check">✓</span><span>Joint financial evidence: bank statements, joint lease or mortgage, joint insurance, joint tax returns</span></div>
            <div class="doc-item"><span class="doc-check">✓</span><span>Photos together (across time, multiple settings)</span></div>
            <div class="doc-item"><span class="doc-check">✓</span><span>Sponsor's current pay stubs and most recent tax return</span></div>
            <div class="doc-item"><span class="doc-check">✓</span><span>U.S. citizen's proof of citizenship (passport or naturalization certificate)</span></div>
            <div class="doc-item"><span class="doc-check">✓</span><span>Applicant's birth certificate + certified translation</span></div>
          </div>
        </section>

        <!-- Conditional vs permanent -->
        <section id="conditional" class="content-section">
          <h2>Conditional vs. Permanent Green Card</h2>
          <p>The type of green card you receive depends on how long you have been married at the time USCIS approves your I-485.</p>

          <div class="card-type-grid">
            <div class="card-type card-conditional">
              <div class="card-type-badge">CR-1 Code</div>
              <h3>2-Year Conditional Green Card</h3>
              <p><strong>When:</strong> Married less than 2 years at the time of approval.</p>
              <p>You receive a conditional permanent resident card valid for 2 years. Conditions are placed to verify the marriage was genuine. You must file <strong>Form I-751 (Petition to Remove Conditions)</strong> within the 90-day window before the card expires.</p>
              <div class="card-type-note">Filing I-751 late — or not at all — puts you at risk of losing your green card status.</div>
            </div>
            <div class="card-type card-permanent">
              <div class="card-type-badge">IR-1 Code</div>
              <h3>10-Year Permanent Green Card</h3>
              <p><strong>When:</strong> Married 2 or more years at the time of approval.</p>
              <p>You receive a 10-year permanent resident card with no conditions. No I-751 required. The card is renewable at the end of 10 years. After 3 years of marriage to your U.S. citizen spouse, you may be eligible to apply for naturalization.</p>
              <div class="card-type-note">Tip: If your approval is delayed past your 2-year anniversary, you may automatically qualify for the 10-year card.</div>
            </div>
          </div>

          <h3 style="margin-top: 1.5rem;">Removing Conditions with I-751</h3>
          <p>If you received a 2-year conditional green card, mark your calendar: <strong>file Form I-751 during the 90-day window before the card expires</strong>. Filing early or late is not accepted (except for hardship or other special circumstances). I-751 is typically filed jointly with your U.S. citizen spouse and includes updated evidence of the ongoing marriage.</p>
        </section>

        <!-- Common mistakes -->
        <section id="mistakes" class="content-section">
          <h2>Common AOS Mistakes to Avoid</h2>

          <div class="mistakes-list">
            <div class="mistake-item">
              <div class="mistake-num">01</div>
              <div>
                <h3>Traveling internationally without Advance Parole</h3>
                <p>The single most costly AOS mistake. Leaving the U.S. without an approved AP card causes USCIS to close your I-485 as abandoned. File I-131 with your initial package and wait for the physical card before any international travel.</p>
              </div>
            </div>
            <div class="mistake-item">
              <div class="mistake-num">02</div>
              <div>
                <h3>Missing your biometrics appointment</h3>
                <p>If you miss the ASC appointment without rescheduling, your case can be considered abandoned. Always reschedule in advance if you cannot attend — do not simply skip it.</p>
              </div>
            </div>
            <div class="mistake-item">
              <div class="mistake-num">03</div>
              <div>
                <h3>Not filing EAD and Advance Parole at the same time as I-485</h3>
                <p>I-765 and I-131 are free when filed concurrently with I-485. Filing them separately later costs $520 and $630 respectively, and takes additional time. Always file the full package together.</p>
              </div>
            </div>
            <div class="mistake-item">
              <div class="mistake-num">04</div>
              <div>
                <h3>Mismatched addresses or information across forms</h3>
                <p>USCIS cross-checks information on all submitted forms. Inconsistent addresses, dates, or names between I-485, I-130, I-864, and supporting documents trigger RFEs and slow down processing. Review every form for consistency before mailing.</p>
              </div>
            </div>
            <div class="mistake-item">
              <div class="mistake-num">05</div>
              <div>
                <h3>Not updating USCIS of an address change (Form AR-11)</h3>
                <p>You are legally required to notify USCIS of any address change within 10 days. Miss an appointment notice or RFE sent to your old address and your case may be denied in absentia. File Form AR-11 online immediately whenever you move.</p>
              </div>
            </div>
            <div class="mistake-item">
              <div class="mistake-num">06</div>
              <div>
                <h3>Submitting I-693 without the civil surgeon's sealed envelope</h3>
                <p>The medical examination report (I-693) must be submitted in the sealed envelope provided by the civil surgeon — unopened. If you open it, or if the civil surgeon did not properly seal it, USCIS will reject it and you will need a new examination. I-693 is also only valid for 2 years after the civil surgeon signs it.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- FAQ -->
        <section id="faq" class="content-section">
          <h2>Frequently Asked Questions</h2>
          <div class="faq-list">
            <details class="faq-item">
              <summary>Can I work while my Adjustment of Status is pending?</summary>
              <p>Yes — but only once you have an approved EAD (Employment Authorization Document, Form I-765) in hand. File I-765 concurrently with your I-485 at no extra charge. EADs typically arrive within 3–6 months. You cannot work based on a pending I-485 alone; you must wait for the physical EAD card.</p>
            </details>
            <details class="faq-item">
              <summary>Can I travel while my Adjustment of Status is pending?</summary>
              <p>Only with an approved Advance Parole document (Form I-131). Leaving the U.S. without it — even briefly — causes USCIS to consider your I-485 abandoned and close the case. File I-131 with your initial package and do not travel internationally until the Advance Parole card arrives and you have it physically in hand.</p>
            </details>
            <details class="faq-item">
              <summary>How long does AOS take after marriage in 2026?</summary>
              <p>Approximately 12–24 months from filing to receiving your green card. EAD and Advance Parole typically arrive within 3–6 months. Interview scheduling varies significantly by USCIS field office — some offices schedule interviews within 8 months; others take 18+ months. Check USCIS processing times for your specific location.</p>
            </details>
            <details class="faq-item">
              <summary>What if I entered on a tourist visa — can I still file AOS?</summary>
              <p>Generally yes. Immediate relatives of U.S. citizens (including spouses) who were lawfully inspected and admitted — including those who entered on a B-1/B-2 tourist visa — are eligible to adjust status regardless of visa type, as long as they have not triggered specific bars. Visa Waiver Program (VWP) entrants may also adjust status as immediate relatives. The key is that you were lawfully admitted, not that you entered on a specific visa.</p>
            </details>
            <details class="faq-item">
              <summary>What if my I-485 is denied?</summary>
              <p>USCIS will send a denial notice with the specific reason. You may file a Motion to Reopen (I-290B) within 33 days if there was a factual or legal error. For inadmissibility-based denials, an I-601 waiver may be available. In some cases you may be referred to immigration court. Consult an immigration attorney immediately after any I-485 denial — time limits for appeals are strict.</p>
            </details>
            <details class="faq-item">
              <summary>Do I need a lawyer for AOS after marriage?</summary>
              <p>Not legally required. Many couples with straightforward situations — especially K-1 holders adjusting after marriage — file successfully without an attorney. However, if you have any complicating factors (prior removal, criminal history, visa overstays, prior denials), a consultation with an immigration attorney is strongly recommended. A one-hour consultation ($150–$300) is a worthwhile investment to understand your risk before filing.</p>
            </details>
          </div>
        </section>


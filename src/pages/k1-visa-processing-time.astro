  .page-hero .hero-desc { font-size: 1.1rem; color: rgba(255,255,255,0.8); max-width: 650px; margin: 0 0 2rem; }
  .hero-meta { display: flex; gap: 1.5rem; flex-wrap: wrap; }
  .hero-meta-item { font-size: 0.85rem; color: rgba(255,255,255,0.6); }

  /* Timeline banner */
  .timeline-banner { background: var(--color-surface); border-bottom: 1px solid var(--color-border); padding: 0; overflow: hidden; }
  .tl-stages { display: flex; }

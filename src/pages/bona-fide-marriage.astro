    "headline": "Bona Fide Marriage Evidence: The Complete Guide for 2026",
    "description": "Learn exactly what USCIS considers bona fide marriage evidence — the 4 pillars, document checklist, photo tips, support letter templates, and red flags to avoid.",
    "url": "https://ldrvisa.org/bona-fide-marriage",
    "dateModified": "2026-04-24",
    "datePublished": "2026-04-24",
    "author": {
      "@type": "Organization",
      "name": "LDR Visa",
      "url": "https://ldrvisa.org"
    },
    "publisher": {
      "@type": "Organization",
      "name": "LDR Visa",
      "url": "https://ldrvisa.org",
      "logo": {
        "@type": "ImageObject",
        "url": "https://ldrvisa.org/favicon.svg"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://ldrvisa.org/bona-fide-marriage"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ldrvisa.org/" },
      { "@type": "ListItem", "position": 2, "name": "Bona Fide Marriage Evidence", "item": "https://ldrvisa.org/bona-fide-marriage" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What does bona fide marriage mean for USCIS?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "USCIS uses 'bona fide marriage' to describe a genuine marriage entered in good faith — not arranged solely for immigration benefits. You must show you have a real shared life: finances, cohabitation, children, and genuine emotional commitment."
        }
      },
      {
        "@type": "Question",
        "name": "How many photos do I need for a K-1 or CR-1 petition?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "USCIS doesn't specify a minimum, but most immigration attorneys recommend 15–30 photos showing you together in different times, places, and contexts. Include photos with each other's family and friends."
        }
      },
      {
        "@type": "Question",
        "name": "Can I submit screenshots of WhatsApp or text messages as evidence?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Screenshots of message threads, video call logs, and chat histories are accepted. Print them clearly, include timestamps and contact names, and organize them chronologically."
        }
      },
      {
        "@type": "Question",
        "name": "What if we haven't lived together?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Long-distance couples (LDRs) are common in K-1 and CR-1 cases. Emphasize communication records, visit documentation (boarding passes, stamps, hotel receipts), and future plans. USCIS understands cross-border couples may not have shared addresses."
        }
      },
      {
        "@type": "Question",
        "name": "Do we need a bona fide marriage letter from friends and family?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Support letters from friends and family are optional but strongly recommended. Each letter should describe how the writer knows both of you, observations of your relationship, and their belief in your genuine intent to marry."
        }
      },
      {
        "@type": "Question",
        "name": "What is a marriage fraud investigation?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "USCIS and ICE conduct marriage fraud investigations (site visits, Stokes interviews) when there are red flags — significant age gaps, short courtship, no common language, or prior fraud history. Strong, consistent evidence dramatically reduces this risk."
        }
      }
    ]
  }
]);

          <tr><th>Fee</th><th>Who Pays</th><th class="amt">Amount</th></tr>
        </thead>
        <tbody>
          <tr><td>Form I-130 filing fee</td><td>U.S. petitioner</td><td class="amt">$675</td></tr>
          <tr><td>Immigrant visa application (DS-260)</td><td>Foreign spouse (via NVC)</td><td class="amt">$325</td></tr>
          <tr><td>Affidavit of Support review fee (I-864)</td><td>U.S. petitioner (via NVC)</td><td class="amt">$120</td></tr>
          <tr><td>Medical exam (civil surgeon)</td><td>Foreign spouse</td><td class="amt">$200–$500</td></tr>
          <tr><td>Visa delivery / courier fee</td><td>Foreign spouse</td><td class="amt">$30–$80</td></tr>
          <tr><td>Immigration attorney (optional)</td><td>Either</td><td class="amt">$1,500–$3,000</td></tr>

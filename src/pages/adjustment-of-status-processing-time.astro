    { label: 'Biometrics notice',   value: '2–6 weeks after filing' },
    { label: 'EAD / Combo card',    value: '3–6 months' },
    { label: 'Advance Parole',      value: '3–6 months' },
    { label: 'Interview scheduled', value: '10–18 months' },

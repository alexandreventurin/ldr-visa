---
import Base from '../layouts/Base.astro';
import SmartLink from '../components/SmartLink.astro';

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Affidavit of Support Income Requirements 2026: Complete I-864 & I-134 Guide",
    "description": "Exact income thresholds for the Affidavit of Support in 2026 — I-864 and I-134 requirements, household size rules, joint sponsors, and how to document assets when income falls short.",
    "url": "https://ldrvisa.org/affidavit-of-support-income-requirements",
    "dateModified": "2026-04-28",
    "datePublished": "2026-04-28",
    "author": { "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org" },
    "publisher": {
      "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org",
      "logo": { "@type": "ImageObject", "url": "https://ldrvisa.org/favicon.svg" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://ldrvisa.org/affidavit-of-support-income-requirements" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ldrvisa.org/" },
      { "@type": "ListItem", "position": 2, "name": "Affidavit of Support", "item": "https://ldrvisa.org/affidavit-of-support" },
      { "@type": "ListItem", "position": 3, "name": "Income Requirements", "item": "https://ldrvisa.org/affidavit-of-support-income-requirements" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the minimum income for an Affidavit of Support in 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For 2026, the minimum income for an Affidavit of Support (I-864) is 125% of the federal poverty guideline for your household size. For a household of 2 (sponsor + immigrant), that is $25,550 per year. For a household of 3, it is $32,275. Military sponsors on active duty filing for a spouse or child only need to meet 100% of the poverty line."
        }
      },
      {
        "@type": "Question",
        "name": "Who counts as part of your household for the Affidavit of Support?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Your household size includes: yourself (the sponsor), your spouse (if married and living with you), all dependents listed on your most recent federal tax return, anyone you have previously sponsored on an I-864 who has not yet become a U.S. citizen or completed 40 quarters of work, and the intending immigrant(s) you are currently sponsoring."
        }
      },
      {
        "@type": "Question",
        "name": "Can a joint sponsor be used if income is too low?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. If you do not meet the income requirement, a joint sponsor (also called a co-sponsor) can file a separate I-864 on behalf of the immigrant. The joint sponsor must be a U.S. citizen or permanent resident who is at least 18, domiciled in the U.S., and independently meets the 125% poverty threshold for their own household size. The joint sponsor takes on full legal obligation."
        }
      },
      {
        "@type": "Question",
        "name": "Can assets be used instead of income for the Affidavit of Support?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, assets can supplement or replace insufficient income. For the I-864, assets must be worth at least 5 times the shortfall between your income and the 125% poverty threshold (3 times for U.S. citizen sponsors of a spouse or child). Countable assets include savings accounts, stocks, bonds, and real estate equity (minus mortgage). The asset's value is divided by 5 (or 3) to determine the income equivalent."
        }
      },
      {
        "@type": "Question",
        "name": "What documents do I need for the Affidavit of Support?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Required documents include: your most recent federal tax return (1040) with all W-2s and 1099s, tax transcripts or IRS-issued transcripts for the past 3 years, recent pay stubs (last 3 months), an employer letter confirming your job title and salary, and evidence of any assets if income is insufficient (bank statements, brokerage statements, property deed + appraisal)."
        }
      },
      {
        "@type": "Question",
        "name": "How long is the Affidavit of Support legally binding?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The I-864 obligation lasts until the sponsored immigrant: becomes a U.S. citizen, is credited with 40 qualifying quarters of work (about 10 years), permanently leaves the U.S., or dies. Divorce does not end the obligation. If the sponsored immigrant receives means-tested public benefits, the government can sue the sponsor to recover costs."
        }
      }
    ]
  }
]);
---

<Base
  title="Affidavit of Support Income Requirements 2026 — I-864 & I-134 Guide"
  description="Exact 2026 income thresholds for the Affidavit of Support (I-864 and I-134) — household size, joint sponsors, assets, and how to document everything correctly."
  schema={schema}
>

  <!-- Breadcrumb -->
  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="breadcrumb">
        <li><a href="/">Home</a></li>
        <li><SmartLink href="/affidavit-of-support">Affidavit of Support</SmartLink></li>
        <li aria-current="page">Income Requirements</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="hero-badge">💰 Financial Requirements</div>
      <h1>Affidavit of Support<br/><span>Income Requirements 2026</span></h1>
      <p class="hero-sub">Exact thresholds, household size rules, joint sponsor options, and asset calculations — everything you need to know before you file I-864 or I-134. Not sure if you qualify? <a href="#calculator" class="hero-calc-link">Use the income calculator →</a></p>

      <div class="quick-numbers">
        <div class="qn-item">
          <span class="qn-val">$25,550</span>
          <span class="qn-label">Minimum — household of 2</span>
        </div>
        <div class="qn-item">
          <span class="qn-val">125%</span>
          <span class="qn-label">Federal poverty guideline</span>
        </div>
        <div class="qn-item">
          <span class="qn-val">I-864</span>
          <span class="qn-label">CR-1 / IR-1 / AOS</span>
        </div>
        <div class="qn-item">
          <span class="qn-val">I-134</span>
          <span class="qn-label">K-1 fiancé visa stage</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Main -->
  <div class="container">
    <div class="content-sidebar-grid">

      <!-- MAIN COLUMN -->
      <main class="main-col">

        <!-- Overview -->
        <section id="overview" class="content-section">
          <h2>What Is the Affidavit of Support?</h2>
          <p>The Affidavit of Support is a legally binding contract in which the U.S. petitioner (sponsor) promises to financially support the immigrant and repay the government for any means-tested public benefits the immigrant receives. It is a critical piece of every spousal and fiancé visa application.</p>
          <p>Two forms are used, depending on the visa stage:</p>

          <div class="form-compare">
            <div class="form-card">
              <div class="form-badge badge-blue">I-134</div>
              <h3>Declaration of Financial Support</h3>
              <p>Required at the <strong>K-1 fiancé visa</strong> stage. Simpler form — it is not legally enforceable but is reviewed by the consular officer. Less stringent than I-864.</p>
              <ul class="form-details">
                <li>Filed by: U.S. citizen petitioner</li>
                <li>When: Before K-1 consular interview</li>
                <li>Threshold: 100% of poverty line (generally)</li>
                <li>Legally binding: No (advisory)</li>
              </ul>
            </div>
            <div class="form-card form-card-featured">
              <div class="form-badge badge-green">I-864</div>
              <h3>Affidavit of Support</h3>
              <p>Required for <strong>CR-1 / IR-1 spousal visas</strong> and <strong>Adjustment of Status (I-485)</strong>. This is the binding contract — enforceable in court.</p>
              <ul class="form-details">
                <li>Filed by: Petitioner + optional joint sponsor</li>
                <li>When: NVC stage or AOS filing</li>
                <li>Threshold: 125% of poverty line</li>
                <li>Legally binding: Yes — until termination conditions met</li>
              </ul>
            </div>
          </div>
        </section>

        <!-- 2026 income tables -->
        <section id="income-table" class="content-section">
          <h2>2026 Income Requirements by Household Size</h2>
          <p>The table below shows the minimum income thresholds based on 2026 federal poverty guidelines. Use the <strong>125% column</strong> for I-864 (most sponsors). The 100% column applies to military sponsors filing I-864 for a spouse or child.</p>

          <div class="table-tabs">
            <div class="tab-label tab-active">Contiguous U.S. (48 states + D.C.)</div>
          </div>

          <div class="income-table-wrap">
            <table class="income-table">
              <thead>
                <tr>
                  <th>Household Size</th>
                  <th>100% Poverty<br/><span class="th-sub">Military I-864</span></th>
                  <th class="col-highlight">125% Poverty<br/><span class="th-sub">Standard I-864</span></th>
                  <th>Per Additional<br/><span class="th-sub">person (125%)</span></th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><strong>2 people</strong> <span class="hh-note">(you + immigrant)</span></td>
                  <td>$20,440</td>
                  <td class="col-highlight"><strong>$25,550</strong></td>
                  <td>—</td>
                </tr>
                <tr>
                  <td><strong>3 people</strong></td>
                  <td>$25,820</td>
                  <td class="col-highlight"><strong>$32,275</strong></td>
                  <td>+$6,725</td>
                </tr>
                <tr>
                  <td><strong>4 people</strong></td>
                  <td>$31,200</td>
                  <td class="col-highlight"><strong>$39,000</strong></td>
                  <td>+$6,725</td>
                </tr>
                <tr>
                  <td><strong>5 people</strong></td>
                  <td>$36,580</td>
                  <td class="col-highlight"><strong>$45,725</strong></td>
                  <td>+$6,725</td>
                </tr>
                <tr>
                  <td><strong>6 people</strong></td>
                  <td>$41,960</td>
                  <td class="col-highlight"><strong>$52,450</strong></td>
                  <td>+$6,725</td>
                </tr>
                <tr>
                  <td><strong>7 people</strong></td>
                  <td>$47,340</td>
                  <td class="col-highlight"><strong>$59,175</strong></td>
                  <td>+$6,725</td>
                </tr>
                <tr>
                  <td><strong>8 people</strong></td>
                  <td>$52,720</td>
                  <td class="col-highlight"><strong>$65,900</strong></td>
                  <td>+$6,725</td>
                </tr>
                <tr class="add-row">
                  <td colspan="4" style="font-size:0.8rem; color: var(--color-muted); padding: 8px 14px;">Each additional person above 8: add $6,725 (125%) or $5,380 (100%)</td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="alert-box alert-info">
            <div class="alert-icon">🏔️</div>
            <div>
              <strong>Alaska and Hawaii Have Higher Thresholds</strong>
              <p>Sponsors domiciled in Alaska or Hawaii use a separate, higher poverty guideline table. For Alaska (household of 2): ~$32,010 at 125%. For Hawaii (household of 2): ~$29,400 at 125%. Check the USCIS website for the current year's Alaska/Hawaii tables.</p>
            </div>
          </div>

          <div class="alert-box alert-warning" style="margin-top: 1rem;">
            <div class="alert-icon">⚠️</div>
            <div>
              <strong>These Are Minimums — Not Guarantees</strong>
              <p>Meeting the 125% threshold satisfies the legal requirement, but consular officers have discretion. Sponsors at or barely above the minimum may face additional scrutiny. A comfortable buffer — or a joint sponsor — strengthens your application.</p>
            </div>
          </div>
        </section>

        <!-- Calculator -->
        <section id="calculator" class="content-section">
          <h2>Income Eligibility Calculator</h2>
          <p>Enter your household size and annual income below. The calculator checks whether you meet the 2026 threshold — and if not, shows exactly how much you're short and what assets you'd need to bridge the gap.</p>

          <div class="calc-widget">
            <div class="calc-inputs">
              <div class="calc-field">
                <label for="calc-hh">Household size</label>
                <input type="number" id="calc-hh" min="2" max="20" value="2" />
                <span class="calc-hint">You + immigrant + dependents + anyone you've sponsored before. Not sure? <a href="#household-size">See how to count →</a></span>
              </div>
              <div class="calc-field">
                <label for="calc-income">Your annual income ($)</label>
                <input type="text" id="calc-income" placeholder="e.g. 45,000" inputmode="numeric" />
                <span class="calc-hint">Gross annual income — wages, self-employment, Social Security, etc.</span>
              </div>
              <div class="calc-field">
                <label class="calc-check-label">
                  <input type="checkbox" id="calc-citizen-spouse" />
                  <span>I'm a U.S. citizen sponsoring my spouse or child <span class="calc-tag">uses 3× asset multiplier</span></span>
                </label>
              </div>
              <div class="calc-field">
                <label class="calc-check-label">
                  <input type="checkbox" id="calc-military" />
                  <span>Active duty military sponsoring spouse or child <span class="calc-tag">100% threshold</span></span>
                </label>
              </div>
            </div>
            <button id="calc-btn" type="button">Check my eligibility →</button>
            <div id="calc-result" class="calc-result" hidden></div>
          </div>
        </section>

        <script>
          (function() {
            // 2026 federal poverty guidelines — 48 states + D.C.
            // 125%: base $25,550 for 2 people, +$6,725 per additional person
            // 100% (military): base $20,440 for 2 people, +$5,380 per additional
            function getThreshold(hh, military) {
              hh = Math.max(2, parseInt(hh) || 2);
              if (military) {
                return 20440 + (hh - 2) * 5380;
              }
              return 25550 + (hh - 2) * 6725;
            }

            function fmt(n) {
              return '$' + Math.round(n).toLocaleString('en-US');
            }

            function parseIncome(val) {
              return parseFloat(val.replace(/[$,\s]/g, '')) || 0;
            }

            const btn    = document.getElementById('calc-btn');
            const result = document.getElementById('calc-result');

            btn.addEventListener('click', function() {
              const hh       = parseInt(document.getElementById('calc-hh').value) || 2;
              const income   = parseIncome(document.getElementById('calc-income').value);
              const citizen  = document.getElementById('calc-citizen-spouse').checked;
              const military = document.getElementById('calc-military').checked;

              if (income <= 0) {
                result.hidden = false;
                result.innerHTML = '<div class="calc-error">Please enter your annual income to calculate.</div>';
                return;
              }

              const required  = getThreshold(hh, military);
              const pct       = military ? '100%' : '125%';
              const shortfall = required - income;
              const multiplier = citizen ? 3 : 5;
              const assetsNeeded = shortfall > 0 ? Math.ceil(shortfall * multiplier) : 0;

              result.hidden = false;

              if (shortfall <= 0) {
                const surplus = -shortfall;
                result.innerHTML = `
                  <div class="calc-pass">
                    <div class="calc-verdict-icon">✅</div>
                    <div>
                      <div class="calc-verdict-title">You qualify</div>
                      <div class="calc-verdict-sub">Your income exceeds the ${pct} threshold for a household of ${hh}.</div>
                    </div>
                  </div>
                  <div class="calc-breakdown">
                    <div class="calc-row"><span>Your annual income</span><span class="calc-num green">${fmt(income)}</span></div>
                    <div class="calc-row"><span>Required (${pct} for ${hh} people)</span><span class="calc-num">${fmt(required)}</span></div>
                    <div class="calc-row calc-row-total"><span>Surplus above threshold</span><span class="calc-num green">+${fmt(surplus)}</span></div>
                  </div>
                  <p class="calc-note">✔ Your income alone satisfies the requirement. Include recent pay stubs and your latest tax return when filing.</p>
                `;
              } else {
                result.innerHTML = `
                  <div class="calc-fail">
                    <div class="calc-verdict-icon">⚠️</div>
                    <div>
                      <div class="calc-verdict-title">Income falls short</div>
                      <div class="calc-verdict-sub">You need ${fmt(shortfall)} more per year — or assets of ${fmt(assetsNeeded)} to compensate.</div>
                    </div>
                  </div>
                  <div class="calc-breakdown">
                    <div class="calc-row"><span>Your annual income</span><span class="calc-num red">${fmt(income)}</span></div>
                    <div class="calc-row"><span>Required (${pct} for ${hh} people)</span><span class="calc-num">${fmt(required)}</span></div>
                    <div class="calc-row calc-row-total"><span>Income shortfall</span><span class="calc-num red">−${fmt(shortfall)}</span></div>
                  </div>
                  <div class="calc-options">
                    <div class="calc-option">
                      <div class="calc-option-label">Option 1 — Use assets</div>
                      <div class="calc-option-val">${fmt(assetsNeeded)} in countable assets required</div>
                      <div class="calc-option-note">${multiplier}× the shortfall · <a href="#assets">See what qualifies →</a></div>
                    </div>
                    <div class="calc-option">
                      <div class="calc-option-label">Option 2 — Joint sponsor</div>
                      <div class="calc-option-val">Someone who independently earns ${fmt(required)}+</div>
                      <div class="calc-option-note">For their own household size · <a href="#joint-sponsor">Joint sponsor guide →</a></div>
                    </div>
                  </div>
                `;
              }
            });

            // Allow Enter key to trigger calculation
            ['calc-hh','calc-income'].forEach(function(id) {
              document.getElementById(id).addEventListener('keydown', function(e) {
                if (e.key === 'Enter') btn.click();
              });
            });
          })();
        </script>

        <!-- Household size -->
        <section id="household-size" class="content-section">
          <h2>How to Count Your Household Size</h2>
          <p>This is where most sponsors miscalculate. Household size for the I-864 is <strong>not</strong> just you and the immigrant. You must include all of the following:</p>

          <div class="hh-list">
            <div class="hh-item hh-always">
              <div class="hh-icon">👤</div>
              <div>
                <strong>Yourself (the sponsor)</strong>
                <p>Always counted as 1 person, regardless of your living situation.</p>
              </div>
            </div>
            <div class="hh-item hh-always">
              <div class="hh-icon">💑</div>
              <div>
                <strong>Your spouse</strong>
                <p>If you are married and living together, your spouse is included — even if they have their own income.</p>
              </div>
            </div>
            <div class="hh-item hh-always">
              <div class="hh-icon">👨‍👩‍👧‍👦</div>
              <div>
                <strong>All dependents listed on your tax return</strong>
                <p>Anyone you claimed as a dependent on your most recent federal tax return, whether or not they live with you.</p>
              </div>
            </div>
            <div class="hh-item hh-always">
              <div class="hh-icon">📄</div>
              <div>
                <strong>Previously sponsored immigrants</strong>
                <p>Anyone you previously signed an I-864 for who has not yet become a U.S. citizen or accumulated 40 quarters of work. Each counts as +1 to your household.</p>
              </div>
            </div>
            <div class="hh-item hh-always">
              <div class="hh-icon">🌍</div>
              <div>
                <strong>The intending immigrant(s) you are now sponsoring</strong>
                <p>The person(s) currently being sponsored — even though they don't live in the U.S. yet — must be counted.</p>
              </div>
            </div>
          </div>

          <div class="hh-example">
            <h3>📊 Example Calculation</h3>
            <p>Maria is a U.S. citizen sponsoring her husband Carlos (CR-1 visa). She has one child from a previous relationship who she claims on her taxes, and she previously sponsored her sister who is now a green card holder with 15 quarters of work.</p>
            <div class="hh-calc">
              <div class="hh-calc-row"><span>Maria (sponsor)</span><span>+1</span></div>
              <div class="hh-calc-row"><span>Carlos (intending immigrant)</span><span>+1</span></div>
              <div class="hh-calc-row"><span>Her child (tax dependent)</span><span>+1</span></div>
              <div class="hh-calc-row"><span>Her sister (prior I-864, 15 quarters)</span><span>+1</span></div>
              <div class="hh-calc-row hh-calc-total"><span>Total household size</span><span>4</span></div>
              <div class="hh-calc-row hh-calc-req"><span>Required income (125% for 4 people)</span><span>$39,000/yr</span></div>
            </div>
          </div>
        </section>

        <!-- What counts as income -->
        <section id="income-sources" class="content-section">
          <h2>What Counts as Income?</h2>
          <p>USCIS and consular officers look at your <strong>current annual income</strong> — what you are earning now, confirmed by recent pay stubs and your most recent tax return. Income that does not appear on your tax return is harder to document.</p>

          <div class="income-sources-grid">
            <div class="income-col income-yes">
              <h3>✅ Countable Income</h3>
              <ul>
                <li>Wages and salaries (W-2 employment)</li>
                <li>Self-employment income (Schedule C, net profit)</li>
                <li>Social Security benefits</li>
                <li>Retirement income (pension, 401k distributions)</li>
                <li>Rental income (net after expenses)</li>
                <li>Alimony received (if ordered before Jan 2019)</li>
                <li>Dividend and interest income</li>
                <li>Disability income (SSDI, long-term disability)</li>
                <li>Military allowances (BAH, BAS for active duty)</li>
              </ul>
            </div>
            <div class="income-col income-no">
              <h3>🚫 Not Countable</h3>
              <ul>
                <li>Means-tested public benefits (Medicaid, SNAP, SSI)</li>
                <li>Unemployment benefits</li>
                <li>Temporary or seasonal income not yet reflected on taxes</li>
                <li>Anticipated future income (e.g., a job offer not yet started)</li>
                <li>Child support received (not universally accepted)</li>
                <li>Household members' income (unless they co-sign I-864A)</li>
                <li>Assets themselves (must use asset calculation separately)</li>
              </ul>
            </div>
          </div>

          <div class="alert-box alert-info" style="margin-top: 1.25rem;">
            <div class="alert-icon">💡</div>
            <div>
              <strong>Combining Household Member Income (I-864A)</strong>
              <p>If a household member (like a spouse) has income that you want to count toward the requirement, they must sign Form I-864A (Contract Between Sponsor and Household Member). Their income can then be added to yours. This is different from a joint sponsor — an I-864A member must live in your household.</p>
            </div>
          </div>
        </section>

        <!-- Joint sponsor -->
        <section id="joint-sponsor" class="content-section">
          <h2>Using a Joint Sponsor</h2>
          <p>If your income doesn't meet the threshold, a <strong>joint sponsor</strong> (also called a co-sponsor) can file a separate I-864 to supplement yours. This is very common and fully accepted by USCIS and consular officers.</p>

          <div class="js-requirements">
            <h3>Joint Sponsor Eligibility Requirements</h3>
            <div class="req-grid">
              <div class="req-item req-must">
                <div class="req-dot"></div>
                <div>U.S. citizen or lawful permanent resident</div>
              </div>
              <div class="req-item req-must">
                <div class="req-dot"></div>
                <div>At least 18 years old</div>
              </div>
              <div class="req-item req-must">
                <div class="req-dot"></div>
                <div>Domiciled in the United States</div>
              </div>
              <div class="req-item req-must">
                <div class="req-dot"></div>
                <div>Independently meets 125% of poverty line for <em>their own</em> household size</div>
              </div>
              <div class="req-item req-must">
                <div class="req-dot"></div>
                <div>Must file a completely separate I-864 (not just a letter)</div>
              </div>
              <div class="req-item req-neutral">
                <div class="req-dot req-dot-gray"></div>
                <div>Does not need to be related to the petitioner or immigrant</div>
              </div>
              <div class="req-item req-neutral">
                <div class="req-dot req-dot-gray"></div>
                <div>Cannot combine income with the primary sponsor to meet requirements</div>
              </div>
            </div>
          </div>

          <div class="alert-box alert-warning" style="margin-top: 1.25rem;">
            <div class="alert-icon">⚖️</div>
            <div>
              <strong>Joint Sponsors Take On Full Legal Liability</strong>
              <p>A joint sponsor is equally liable for repaying any means-tested public benefits the immigrant receives. This obligation lasts until the immigrant becomes a citizen, completes 40 work quarters, permanently leaves the U.S., or dies. Make sure your joint sponsor understands this commitment.</p>
            </div>
          </div>

          <h3 style="margin-top: 1.5rem;">Joint Sponsor Income Example</h3>
          <div class="hh-calc" style="max-width: 480px;">
            <div class="hh-calc-row"><span>Primary sponsor income</span><span>$18,000</span></div>
            <div class="hh-calc-row"><span>Required for household of 2</span><span>$25,550</span></div>
            <div class="hh-calc-row" style="color: #dc2626;"><span>Shortfall</span><span>−$7,550</span></div>
            <div style="border-top: 1px dashed var(--color-border); margin: 8px 0;"></div>
            <div class="hh-calc-row"><span>Joint sponsor income</span><span>$45,000</span></div>
            <div class="hh-calc-row"><span>Joint sponsor household size</span><span>3 people</span></div>
            <div class="hh-calc-row"><span>Required for joint sponsor (125% × 3)</span><span>$32,275</span></div>
            <div class="hh-calc-row hh-calc-total"><span>$45,000 ≥ $32,275</span><span>✅ Qualifies</span></div>
          </div>
        </section>

        <!-- Assets -->
        <section id="assets" class="content-section">
          <h2>Using Assets When Income Is Insufficient</h2>
          <p>If your income alone doesn't meet the threshold, you can use <strong>assets</strong> to make up the difference. USCIS applies a specific formula to convert asset value into an income equivalent.</p>

          <div class="asset-formula">
            <div class="formula-box">
              <div class="formula-title">Standard I-864 Asset Formula</div>
              <div class="formula-math">Shortfall × 5 = Minimum Asset Value Required</div>
              <div class="formula-note">U.S. citizen sponsors of a spouse or child of a U.S. citizen may use a 3× multiplier instead of 5×</div>
            </div>
          </div>

          <h3 style="margin-top: 1.5rem;">Asset Calculation Example</h3>
          <div class="hh-calc" style="max-width: 480px;">
            <div class="hh-calc-row"><span>Sponsor income</span><span>$20,000</span></div>
            <div class="hh-calc-row"><span>Poverty threshold (125%, 2 people)</span><span>$25,550</span></div>
            <div class="hh-calc-row" style="color:#dc2626;"><span>Income shortfall</span><span>$5,550</span></div>
            <div style="border-top: 1px dashed var(--color-border); margin: 8px 0;"></div>
            <div class="hh-calc-row"><span>Multiplier (U.S. citizen sponsoring spouse)</span><span>×3</span></div>
            <div class="hh-calc-row hh-calc-total"><span>Minimum assets required</span><span>$16,650</span></div>
          </div>

          <h3 style="margin-top: 1.5rem;">What Counts as an Asset?</h3>
          <div class="asset-grid">
            <div class="asset-item asset-ok">
              <div class="asset-icon">🏦</div>
              <div>
                <strong>Bank accounts</strong>
                <p>Checking and savings. Must show 12 months of statements. Balance must be <em>liquid and available</em>.</p>
              </div>
            </div>
            <div class="asset-item asset-ok">
              <div class="asset-icon">📈</div>
              <div>
                <strong>Stocks &amp; bonds</strong>
                <p>Brokerage account value at current market prices. Provide recent statements.</p>
              </div>
            </div>
            <div class="asset-item asset-ok">
              <div class="asset-icon">🏠</div>
              <div>
                <strong>Real estate equity</strong>
                <p>Current appraised value minus outstanding mortgage balance. Must provide deed, appraisal, and mortgage statement.</p>
              </div>
            </div>
            <div class="asset-item asset-ok">
              <div class="asset-icon">🏛️</div>
              <div>
                <strong>Retirement accounts</strong>
                <p>IRA, 401(k), pension (vested value). Some officers apply a discount for early-withdrawal penalties — provide account statements.</p>
              </div>
            </div>
            <div class="asset-item asset-no">
              <div class="asset-icon">🚫</div>
              <div>
                <strong>Personal property</strong>
                <p>Cars, jewelry, furniture — generally not accepted as immigration assets unless documented by certified appraisal and easily liquidated.</p>
              </div>
            </div>
            <div class="asset-item asset-no">
              <div class="asset-icon">🚫</div>
              <div>
                <strong>Business interests</strong>
                <p>Value of a private business is difficult to document and rarely accepted without a formal valuation by a CPA.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Supporting documents -->
        <section id="documents" class="content-section">
          <h2>Required Supporting Documents</h2>
          <p>Your I-864 or I-134 is only as strong as the evidence you attach. Missing or inconsistent documents are one of the top 221(g) triggers. Organize everything in this order:</p>

          <div class="doc-checklist">
            <div class="doc-cat">
              <div class="doc-cat-header">
                <div class="doc-cat-icon">📋</div>
                <h3>Tax Documents (Required)</h3>
              </div>
              <div class="doc-items">
                <div class="doc-item">
                  <span class="doc-check">✓</span>
                  <div>
                    <strong>Most recent federal tax return (Form 1040)</strong>
                    <p>Complete copy including all schedules. If you used a tax preparer, request a copy from them or download from IRS.gov.</p>
                  </div>
                </div>
                <div class="doc-item">
                  <span class="doc-check">✓</span>
                  <div>
                    <strong>All W-2s and 1099s for the most recent year</strong>
                    <p>All income statements showing wages, contract income, or investment income.</p>
                  </div>
                </div>
                <div class="doc-item">
                  <span class="doc-check">✓</span>
                  <div>
                    <strong>Tax returns for the 2 prior years</strong>
                    <p>I-864 requires the 3 most recent years. You don't need to attach all W-2s for prior years — just the 1040.</p>
                  </div>
                </div>
                <div class="doc-item">
                  <span class="doc-check">✓</span>
                  <div>
                    <strong>IRS tax transcript (alternative)</strong>
                    <p>If you cannot locate a past return, order a Tax Return Transcript free at irs.gov/individuals/get-transcript. Officers accept these in lieu of the original return.</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="doc-cat">
              <div class="doc-cat-header">
                <div class="doc-cat-icon">💼</div>
                <h3>Employment Documents (Required)</h3>
              </div>
              <div class="doc-items">
                <div class="doc-item">
                  <span class="doc-check">✓</span>
                  <div>
                    <strong>Recent pay stubs (last 3–6 months)</strong>
                    <p>Shows current income, especially important if your most recent tax return doesn't reflect your current earnings (e.g., you got a raise or changed jobs).</p>
                  </div>
                </div>
                <div class="doc-item">
                  <span class="doc-check">✓</span>
                  <div>
                    <strong>Employer letter on company letterhead</strong>
                    <p>Must confirm: your name, job title, employment start date, full-time or part-time status, and annual salary or hourly rate. Signed by HR or your manager.</p>
                  </div>
                </div>
                <div class="doc-item">
                  <span class="doc-check">✓</span>
                  <div>
                    <strong>Self-employment: Schedule C + business records</strong>
                    <p>If self-employed, attach Schedule C from your tax return plus bank statements showing business income deposits and a business license if applicable.</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="doc-cat">
              <div class="doc-cat-header">
                <div class="doc-cat-icon">🏦</div>
                <h3>Asset Documents (If Using Assets)</h3>
              </div>
              <div class="doc-items">
                <div class="doc-item">
                  <span class="doc-check">✓</span>
                  <div>
                    <strong>Bank statements (12 months)</strong>
                    <p>Complete statements — not just balance summaries. All pages, all accounts.</p>
                  </div>
                </div>
                <div class="doc-item">
                  <span class="doc-check">✓</span>
                  <div>
                    <strong>Brokerage / investment account statements</strong>
                    <p>Most recent statement showing current market value of all holdings.</p>
                  </div>
                </div>
                <div class="doc-item">
                  <span class="doc-check">✓</span>
                  <div>
                    <strong>Real estate: deed + appraisal + mortgage statement</strong>
                    <p>Property deed to establish ownership, certified appraisal for current value, and current mortgage statement to calculate net equity.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Common mistakes -->
        <section id="mistakes" class="content-section">
          <h2>Common Mistakes That Cause Delays</h2>
          <div class="mistakes-list">
            <div class="mistake-item">
              <div class="mistake-num">01</div>
              <div>
                <h3>Using the wrong household size</h3>
                <p>Forgetting to count previously sponsored immigrants or all tax dependents leads to submitting an I-864 that appears to meet the threshold but actually doesn't. Officers will recalculate and may issue an RFE.</p>
              </div>
            </div>
            <div class="mistake-item">
              <div class="mistake-num">02</div>
              <div>
                <h3>Relying on a tax return that shows low income</h3>
                <p>If your tax return shows lower income than you earn today (e.g., you were between jobs last year), supplement with current pay stubs and an employer letter. Do not let the tax return speak alone.</p>
              </div>
            </div>
            <div class="mistake-item">
              <div class="mistake-num">03</div>
              <div>
                <h3>Joint sponsor submits an incomplete I-864</h3>
                <p>The joint sponsor must file a full, separate I-864 with all supporting documents — tax returns, pay stubs, employer letter — not just a support letter or note. Incomplete joint sponsor I-864s are a common 221(g) trigger.</p>
              </div>
            </div>
            <div class="mistake-item">
              <div class="mistake-num">04</div>
              <div>
                <h3>Counting household member income without I-864A</h3>
                <p>If you want to include a household member's income (like your spouse's), they must sign Form I-864A. Without it, only your own income counts, and the I-864 may fall short.</p>
              </div>
            </div>
            <div class="mistake-item">
              <div class="mistake-num">05</div>
              <div>
                <h3>Submitting outdated tax documents</h3>
                <p>USCIS and consular officers may flag I-864 packages with tax returns that are more than 12 months old. If the filing window falls after April 15, use the most recently filed return. If you haven't filed yet for the prior year, file promptly.</p>
              </div>
            </div>
            <div class="mistake-item">
              <div class="mistake-num">06</div>
              <div>
                <h3>Forgetting that divorce doesn't end I-864 obligations</h3>
                <p>Many sponsors are surprised to learn that if you divorce the immigrant, your legal obligation to support them continues until the termination conditions are met. This is a binding contract — not voided by divorce.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- When obligation ends -->
        <section id="obligation" class="content-section">
          <h2>When Does the I-864 Obligation End?</h2>
          <p>The Affidavit of Support is one of the longest-running immigration obligations. It terminates only when one of these conditions is met:</p>
          <div class="obligation-grid">
            <div class="ob-item ob-green">
              <div class="ob-icon">🇺🇸</div>
              <div><strong>Immigrant becomes a U.S. citizen</strong><br/>Fastest termination — typically 3–5 years after green card.</div>
            </div>
            <div class="ob-item ob-green">
              <div class="ob-icon">📊</div>
              <div><strong>40 qualifying work quarters (~10 years)</strong><br/>Immigrant can earn quarters on their own or receive credit from a spouse's work history.</div>
            </div>
            <div class="ob-item ob-green">
              <div class="ob-icon">✈️</div>
              <div><strong>Permanent departure from the U.S.</strong><br/>Immigrant permanently leaves and abandons lawful permanent resident status.</div>
            </div>
            <div class="ob-item ob-green">
              <div class="ob-icon">🕊️</div>
              <div><strong>Death of either party</strong><br/>Death of the sponsor or the immigrant terminates the obligation.</div>
            </div>
            <div class="ob-item ob-red">
              <div class="ob-icon">💔</div>
              <div><strong>Divorce does NOT end it</strong><br/>Even after divorce, the sponsor remains legally obligated to support the immigrant until the conditions above are met.</div>
            </div>
            <div class="ob-item ob-red">
              <div class="ob-icon">🚫</div>
              <div><strong>Separation does NOT end it</strong><br/>Living apart, legal separation, or restraining orders do not terminate the I-864 obligation.</div>
            </div>
          </div>
        </section>

        <!-- FAQs -->
        <section id="faq" class="content-section">
          <h2>Frequently Asked Questions</h2>
          <div class="faq-list">
            <details class="faq-item">
              <summary>What is the minimum income for an Affidavit of Support in 2026?</summary>
              <p>For most sponsors, the minimum is 125% of the federal poverty guideline for your household size. For a household of 2 (sponsor + immigrant), that is $25,550 per year. Military sponsors filing I-864 for a spouse or child only need to meet 100% ($20,440 for 2 people). Income thresholds are higher in Alaska and Hawaii.</p>
            </details>
            <details class="faq-item">
              <summary>Who counts as part of your household for the Affidavit of Support?</summary>
              <p>Yourself, your spouse (if living together), all dependents on your most recent tax return, any immigrants you previously sponsored who haven't become citizens or completed 40 work quarters, and the intending immigrant(s) you are currently sponsoring. This is frequently miscalculated — don't just count the people living in your home.</p>
            </details>
            <details class="faq-item">
              <summary>Can a joint sponsor be used if income is too low?</summary>
              <p>Yes. A joint sponsor files a completely separate I-864 and must independently meet the 125% threshold for their own household size. They do not need to be related to you. They take on full legal liability equal to yours. This is a common and fully accepted solution.</p>
            </details>
            <details class="faq-item">
              <summary>Can assets be used instead of income?</summary>
              <p>Yes. Assets can bridge the gap. For most sponsors, assets must be worth 5× the income shortfall. U.S. citizen sponsors of a spouse or child of a U.S. citizen may use a 3× multiplier. Countable assets include bank balances, stocks, bonds, and real estate equity — not personal property or cars.</p>
            </details>
            <details class="faq-item">
              <summary>What documents do I need to submit with the I-864?</summary>
              <p>Required: your most recent federal tax return (Form 1040) plus all W-2s and 1099s, tax returns for the 2 prior years, recent pay stubs (3–6 months), and an employer letter. If using assets: bank statements (12 months), brokerage statements, and for real estate: deed, appraisal, and mortgage statement. Joint sponsors need the same documents for their own I-864.</p>
            </details>
            <details class="faq-item">
              <summary>How long is the Affidavit of Support legally binding?</summary>
              <p>The I-864 obligation continues until the immigrant becomes a U.S. citizen, completes 40 qualifying work quarters (~10 years), permanently leaves the U.S., or either party dies. Divorce, separation, or remarriage of either party does not end the obligation. If the immigrant receives means-tested public benefits, the government can sue the sponsor to recover costs.</p>
            </details>
          </div>
        </section>


---
import Base from '../layouts/Base.astro';
import SmartLink from '../components/SmartLink.astro';

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "CR-1 Visa Cost 2026: Complete Fee Breakdown for the Spousal Visa",
    "description": "Every CR-1 spousal visa fee for 2026 — I-130, NVC, medical exam, USCIS immigrant fee, I-751, and attorney costs. See why CR-1 is cheaper than K-1 and how to reduce your total cost.",
    "url": "https://ldrvisa.org/cr1-visa-cost",
    "dateModified": "2026-04-29",
    "datePublished": "2026-04-29",
    "author": { "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org" },
    "publisher": {
      "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org",
      "logo": { "@type": "ImageObject", "url": "https://ldrvisa.org/favicon.svg" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://ldrvisa.org/cr1-visa-cost" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ldrvisa.org/" },
      { "@type": "ListItem", "position": 2, "name": "CR-1 Visa", "item": "https://ldrvisa.org/cr1-visa" },
      { "@type": "ListItem", "position": 3, "name": "CR-1 Visa Cost", "item": "https://ldrvisa.org/cr1-visa-cost" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does a CR-1 visa cost in 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The CR-1 spousal visa costs approximately $1,220 in mandatory government fees: $675 for Form I-130, $325 for the NVC immigrant visa fee, and $220 for the USCIS Immigrant Fee paid after entry. Add approximately $200–$500 for the required medical exam, $750 for the I-751 to remove conditions later, and optional attorney fees of $1,500–$4,000. Most couples spend $3,500–$7,000 total from petition to 10-year green card."
        }
      },
      {
        "@type": "Question",
        "name": "What is the I-130 filing fee for a CR-1 visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Form I-130 filing fee is $675 as of 2026. This is paid by the U.S. citizen or LPR petitioner to USCIS when filing the Petition for Alien Relative. The fee is non-refundable. Form I-130A (completed by the beneficiary spouse) is submitted with the I-130 at no additional cost."
        }
      },
      {
        "@type": "Question",
        "name": "What is the NVC immigrant visa fee?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The NVC (National Visa Center) charges a $325 immigrant visa fee per beneficiary. This is paid online through ceac.state.gov after the I-130 is approved and the case is transferred to NVC. This fee covers the visa processing and consular interview scheduling. It is separate from the I-130 filing fee paid to USCIS."
        }
      },
      {
        "@type": "Question",
        "name": "Is CR-1 cheaper than K-1?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes — significantly. The CR-1 path costs approximately $2,220 in total government fees (I-130 $675 + NVC fee $325 + USCIS immigrant fee $220 + I-751 $750 + one medical exam ~$250). The K-1 path costs approximately $3,680 in government fees because it requires a second I-485 filing ($1,440) and two separate medical exams. The CR-1 saves $1,400–$2,000+ in fees alone."
        }
      },
      {
        "@type": "Question",
        "name": "What is the USCIS Immigrant Fee and when do I pay it?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The USCIS Immigrant Fee is $220 paid online at pay.gov after the foreign spouse enters the U.S. on the CR-1 visa. It must be paid within one year of entry. This fee covers the production and mailing of the green card (Form I-551). Without paying it, the green card will not be produced."
        }
      },
      {
        "@type": "Question",
        "name": "Do I need to pay for two medical exams on the CR-1 visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No — only one medical exam is required on the CR-1 path. The foreign spouse has a medical exam by a USCIS-approved panel physician in their home country before the consular interview. Unlike the K-1 path, there is no second medical exam required after entry because the CR-1 beneficiary enters directly as a permanent resident without needing to file for Adjustment of Status."
        }
      }
    ]
  }
]);
---

<Base
  title="CR-1 Visa Cost 2026: Complete Fee Breakdown — I-130 to Green Card"
  description="Every CR-1 spousal visa fee explained — I-130, NVC, medical, USCIS immigrant fee, I-751 — and why CR-1 is cheaper than K-1. Updated April 2026."
  schema={schema}
>

  <!-- Breadcrumb -->
  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="breadcrumb">
        <li><a href="/">Home</a></li>
        <li><SmartLink href="/cr1-visa">CR-1 Visa</SmartLink></li>
        <li aria-current="page">CR-1 Visa Cost</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="hero-badge">💰 2026 Cost Guide</div>
      <h1>CR-1 Visa Cost 2026:<br/><span>The Most Cost-Efficient Path to a Green Card</span></h1>
      <p class="hero-sub">The CR-1 spousal visa costs significantly less than K-1 — one process, one medical exam, no I-485. Here's every fee from petition to your 10-year green card.</p>

      <div class="cost-hero-bar">
        <div class="chb-item">
          <span class="chb-label">I-130 petition</span>
          <span class="chb-val">$675</span>
          <span class="chb-sub">Paid to USCIS</span>
        </div>
        <div class="chb-plus">+</div>
        <div class="chb-item">
          <span class="chb-label">NVC + entry fees</span>
          <span class="chb-val">$545</span>
          <span class="chb-sub">Visa + immigrant fee</span>
        </div>
        <div class="chb-plus">+</div>
        <div class="chb-item">
          <span class="chb-label">I-751 (conditions)</span>
          <span class="chb-val">$750</span>
          <span class="chb-sub">~2 years after entry</span>
        </div>
        <div class="chb-equals">=</div>
        <div class="chb-item chb-total">
          <span class="chb-label">Total govt. fees</span>
          <span class="chb-val">~$2,220</span>
          <span class="chb-sub">vs $3,680 for K-1</span>
        </div>
      </div>
    </div>
  </section>

  <div class="container">
    <div class="content-sidebar-grid">

      <main class="main-col">

        <!-- Overview -->
        <section id="overview" class="content-section">
          <h2>Why CR-1 Is the More Affordable Path</h2>
          <p>The CR-1 spousal visa is a single continuous immigration process — petition → NVC → consular interview → enter as permanent resident. Because the foreign spouse enters directly with a green card, there is <strong>no second Adjustment of Status filing</strong> required (saving $1,440 in fees) and <strong>only one medical exam</strong> (saving $200–$500).</p>

          <div class="savings-banner">
            <div class="sb-left">
              <div class="sb-icon">💡</div>
              <div>
                <strong>CR-1 saves $1,460+ compared to K-1</strong>
                <p>No I-485 ($1,440 saved). No second medical exam ($200–$500 saved). One set of attorney fees instead of two. The CR-1's only "cost" is time — it takes longer overall, but gets you to a green card more efficiently.</p>
              </div>
            </div>
            <SmartLink href="/k1-vs-cr1" class="sb-link">Full K-1 vs CR-1 comparison →</SmartLink>
          </div>

          <div class="alert-box alert-info">
            <div class="alert-icon">📋</div>
            <div>
              <strong>CR-1 vs IR-1 — same process, different card</strong>
              <p>If your marriage was less than 2 years old when the visa is approved, you receive a CR-1 (2-year conditional green card) and must file I-751 later. If married 2+ years, you receive an IR-1 (10-year card) — no I-751 needed. The costs here cover the CR-1 path, which is more common for LDR couples.</p>
            </div>
          </div>
        </section>

        <!-- Stage 1 -->
        <section id="stage1" class="content-section">
          <h2>Stage 1 — Form I-130 Petition (USCIS)</h2>
          <p>The U.S. citizen or LPR petitioner files this package with USCIS. It's the foundational step that establishes the qualifying spousal relationship.</p>

          <table class="fee-table">
            <thead>
              <tr><th>Item</th><th>Fee</th><th>Who Pays</th><th>Required?</th></tr>
            </thead>
            <tbody>
              <tr class="fee-req">
                <td><strong>Form I-130 filing fee</strong></td>
                <td class="fa">$675</td>
                <td>Petitioner</td>
                <td><span class="badge-req">Required</span></td>
              </tr>
              <tr class="fee-req">
                <td><strong>Form I-130A</strong> (beneficiary supplement)</td>
                <td class="fa">$0</td>
                <td>Beneficiary</td>
                <td><span class="badge-req">Required</span></td>
              </tr>
              <tr class="fee-opt">
                <td>Document translations</td>
                <td class="fa">$50–$200</td>
                <td>Petitioner</td>
                <td><span class="badge-opt">If needed</span></td>
              </tr>
              <tr class="fee-opt">
                <td>Certified mail / courier</td>
                <td class="fa">$20–$50</td>
                <td>Petitioner</td>
                <td><span class="badge-opt">If mailing</span></td>
              </tr>
              <tr class="fee-opt">
                <td>Attorney fee — petition only</td>
                <td class="fa">$500–$1,500</td>
                <td>Petitioner</td>
                <td><span class="badge-opt">Optional</span></td>
              </tr>
            </tbody>
            <tfoot>
              <tr class="fee-sub">
                <td><strong>Stage 1 minimum</strong></td>
                <td class="fa"><strong>$675</strong></td>
                <td colspan="2">Government fee only</td>
              </tr>
            </tfoot>
          </table>

          <div class="alert-box alert-info" style="margin-top:1rem;">
            <div class="alert-icon">💡</div>
            <div>
              <strong>LPR petitioners: note the priority date</strong>
              <p>If the petitioner is a Lawful Permanent Resident (not a U.S. citizen), the same I-130 fee applies — but the case falls under the F2A preference category, which has a visa backlog. Wait times can add 1–3 years before the case reaches NVC. Citizens file as "immediate relatives" with no wait.</p>
            </div>
          </div>
        </section>

        <!-- Stage 2 -->
        <section id="stage2" class="content-section">
          <h2>Stage 2 — NVC Processing &amp; Consular Fees</h2>
          <p>After USCIS approves the I-130, the case transfers to the National Visa Center. Both parties submit financial documents and civil documents, and the beneficiary pays the visa processing fee.</p>

          <table class="fee-table">
            <thead>
              <tr><th>Item</th><th>Fee</th><th>Who Pays</th><th>Required?</th></tr>
            </thead>
            <tbody>
              <tr class="fee-req">
                <td><strong>NVC immigrant visa fee</strong></td>
                <td class="fa">$325</td>
                <td>Beneficiary</td>
                <td><span class="badge-req">Required</span></td>
              </tr>
              <tr class="fee-req">
                <td><strong>Medical exam — panel physician</strong></td>
                <td class="fa">$150–$500</td>
                <td>Beneficiary</td>
                <td><span class="badge-req">Required</span></td>
              </tr>
              <tr class="fee-req">
                <td><strong>Vaccinations</strong> (if not current)</td>
                <td class="fa">$50–$400</td>
                <td>Beneficiary</td>
                <td><span class="badge-req">If needed</span></td>
              </tr>
              <tr class="fee-opt">
                <td>Police certificate fees (varies by country)</td>
                <td class="fa">$0–$100</td>
                <td>Beneficiary</td>
                <td><span class="badge-opt">Country-specific</span></td>
              </tr>
              <tr class="fee-opt">
                <td>Document translations (civil docs)</td>
                <td class="fa">$50–$200</td>
                <td>Beneficiary</td>
                <td><span class="badge-opt">If needed</span></td>
              </tr>
              <tr class="fee-opt">
                <td>Travel to embassy</td>
                <td class="fa">Varies</td>
                <td>Beneficiary</td>
                <td><span class="badge-opt">If not local</span></td>
              </tr>
              <tr class="fee-opt">
                <td>Attorney fee — NVC + interview prep</td>
                <td class="fa">$500–$1,500</td>
                <td>Both</td>
                <td><span class="badge-opt">Optional</span></td>
              </tr>
            </tbody>
            <tfoot>
              <tr class="fee-sub">
                <td><strong>Stage 2 minimum (govt. only)</strong></td>
                <td class="fa"><strong>$325</strong></td>
                <td colspan="2">+ medical exam ($150–$500 est.)</td>
              </tr>
            </tfoot>
          </table>

          <!-- Medical exam by region -->
          <div class="region-med">
            <h3>Medical Exam Cost by Region</h3>
            <div class="rm-grid">
              <div class="rm-item"><div class="rm-region">Latin America</div><div class="rm-cost">$150–$350</div></div>
              <div class="rm-item"><div class="rm-region">Western Europe</div><div class="rm-cost">$200–$400</div></div>
              <div class="rm-item"><div class="rm-region">Southeast Asia</div><div class="rm-cost">$100–$250</div></div>
              <div class="rm-item"><div class="rm-region">Philippines</div><div class="rm-cost">$180–$320</div></div>
              <div class="rm-item"><div class="rm-region">Eastern Europe</div><div class="rm-cost">$150–$300</div></div>
              <div class="rm-item"><div class="rm-region">Africa</div><div class="rm-cost">$100–$250</div></div>
            </div>
            <p class="rm-note">Check the embassy's approved panel physician list for your country. Vaccinations not up to date are billed separately and can add $50–$400.</p>
          </div>

          <div class="alert-box alert-success" style="margin-top:1rem;">
            <div class="alert-icon">✅</div>
            <div>
              <strong>CR-1 advantage: only one medical exam ever</strong>
              <p>The K-1 path requires two medical exams — one before the consular interview abroad, and another (I-693) after entering the U.S. for Adjustment of Status. CR-1 requires just this one exam. Saves $200–$500 and eliminates the hassle of finding a civil surgeon inside the U.S.</p>
            </div>
          </div>
        </section>

        <!-- Stage 3: Entry -->
        <section id="stage3" class="content-section">
          <h2>Stage 3 — Entry &amp; Green Card Production</h2>
          <p>Unlike K-1, the CR-1 beneficiary enters the U.S. directly as a conditional permanent resident. There's one final fee to trigger the green card mailing:</p>

          <table class="fee-table">
            <thead>
              <tr><th>Item</th><th>Fee</th><th>When</th><th>Notes</th></tr>
            </thead>
            <tbody>
              <tr class="fee-req">
                <td><strong>USCIS Immigrant Fee</strong></td>
                <td class="fa">$220</td>
                <td>Within 1 year of entry</td>
                <td>Paid at pay.gov — triggers green card production</td>
              </tr>
            </tbody>
          </table>

          <div class="entry-flow">
            <div class="ef-step">
              <div class="ef-num">1</div>
              <div>
                <strong>Arrive at U.S. port of entry</strong>
                <p>CBP officer stamps your passport. Your visa + stamp serves as proof of LPR status for up to 1 year.</p>
              </div>
            </div>
            <div class="ef-step">
              <div class="ef-num">2</div>
              <div>
                <strong>Pay $220 USCIS Immigrant Fee at pay.gov</strong>
                <p>Do this within your first few days in the U.S. Without this payment, the green card (I-551) will not be produced or mailed.</p>
              </div>
            </div>
            <div class="ef-step">
              <div class="ef-num">3</div>
              <div>
                <strong>Receive green card by mail</strong>
                <p>The CR-1 (or IR-1) green card is mailed to your U.S. address within 2–4 weeks of entry. No further filing or fees needed until the I-751.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Stage 4: I-751 -->
        <section id="stage4" class="content-section">
          <h2>Stage 4 — Remove Conditions (I-751)</h2>
          <p>If your marriage was less than 2 years old when the CR-1 was approved, you receive a 2-year conditional green card. The I-751 converts it to a 10-year permanent card:</p>

          <table class="fee-table">
            <thead>
              <tr><th>Item</th><th>Fee</th><th>When</th><th>Notes</th></tr>
            </thead>
            <tbody>
              <tr class="fee-req">
                <td><strong>Form I-751 (Remove Conditions)</strong></td>
                <td class="fa">$750</td>
                <td>Months 21–24 after green card</td>
                <td>Includes biometrics. 90-day filing window before card expires.</td>
              </tr>
              <tr class="fee-opt">
                <td>Attorney fee (if used)</td>
                <td class="fa">$500–$1,500</td>
                <td>Before filing</td>
                <td>Recommended for waiver-based cases</td>
              </tr>
            </tbody>
          </table>

          <div class="ir1-note">
            <div class="ir1-icon">⭐</div>
            <div>
              <strong>Skip I-751 entirely with an IR-1</strong>
              <p>If your marriage was 2+ years old when the visa was approved, you receive an <strong>IR-1</strong> — a 10-year permanent green card with no conditions. No I-751 filing, no $750 fee, no 24–36 month processing wait. If your marriage is approaching 2 years when you file I-130, it may be worth waiting to pass that mark before petitioning.</p>
            </div>
          </div>
        </section>

        <!-- Total summary -->
        <section id="total" class="content-section">
          <h2>Complete Cost Summary — CR-1 to Green Card</h2>

          <div class="total-card">
            <div class="tc-header">
              <h3>CR-1 Total Cost Breakdown</h3>
              <div class="tc-badge">2026 figures</div>
            </div>
            <table class="sum-table">
              <tbody>
                <tr class="sum-stage"><td colspan="3"><strong>Stage 1 — I-130 Petition</strong></td></tr>
                <tr>
                  <td>Form I-130</td>
                  <td><span class="tag-req">Required</span></td>
                  <td class="sa">$675</td>
                </tr>
                <tr class="sum-stage"><td colspan="3"><strong>Stage 2 — NVC &amp; Consular</strong></td></tr>
                <tr>
                  <td>NVC immigrant visa fee</td>
                  <td><span class="tag-req">Required</span></td>
                  <td class="sa">$325</td>
                </tr>
                <tr>
                  <td>Medical exam (est. average)</td>
                  <td><span class="tag-req">Required</span></td>
                  <td class="sa">~$250</td>
                </tr>
                <tr>
                  <td>Vaccinations</td>
                  <td><span class="tag-opt">If needed</span></td>
                  <td class="sa">$0–$400</td>
                </tr>
                <tr class="sum-stage"><td colspan="3"><strong>Stage 3 — Entry</strong></td></tr>
                <tr>
                  <td>USCIS Immigrant Fee</td>
                  <td><span class="tag-req">Required</span></td>
                  <td class="sa">$220</td>
                </tr>
                <tr class="sum-stage"><td colspan="3"><strong>Stage 4 — Remove Conditions (if CR-1)</strong></td></tr>
                <tr>
                  <td>Form I-751</td>
                  <td><span class="tag-req">Required (CR-1)</span></td>
                  <td class="sa">$750</td>
                </tr>
                <tr class="sum-stage"><td colspan="3"><strong>Out-of-Pocket (estimated)</strong></td></tr>
                <tr>
                  <td>Document translations</td>
                  <td><span class="tag-opt">Likely needed</span></td>
                  <td class="sa">$100–$300</td>
                </tr>
                <tr>
                  <td>Self-filing platform</td>
                  <td><span class="tag-opt">Optional</span></td>
                  <td class="sa">$299–$499</td>
                </tr>
                <tr>
                  <td>Immigration attorney (full)</td>
                  <td><span class="tag-opt">Optional</span></td>
                  <td class="sa">$1,500–$4,000</td>
                </tr>
              </tbody>
              <tfoot>
                <tr class="sum-govt">
                  <td><strong>Government fees total</strong></td>
                  <td></td>
                  <td class="sa"><strong>~$2,220</strong></td>
                </tr>
                <tr class="sum-realistic">
                  <td><strong>Realistic total</strong></td>
                  <td></td>
                  <td class="sa"><strong>$3,500–$7,000+</strong></td>
                </tr>
              </tfoot>
            </table>
          </div>

          <!-- Affiliate CTA — after seeing full cost, prime moment -->
          <div class="mid-cta">
            <div class="mc-left">
              <div class="mc-icon">🧾</div>
              <div>
                <strong>Want to keep costs on the lower end?</strong>
                <p>Guided self-filing platforms like Boundless or RapidVisa handle the full I-130 → NVC → I-751 process for $299–$499, saving most couples $1,000–$2,500 vs. a full attorney. Best for couples with no prior immigration complications.</p>
              </div>
            </div>
            <a href="#" class="mc-btn" data-affiliate="cr1-self-filing">Compare Filing Options →</a>
          </div>
        </section>

        <!-- CR-1 vs K-1 cost -->
        <section id="vs-k1" class="content-section">
          <h2>CR-1 vs K-1 — Full Cost Comparison</h2>
          <p>The CR-1 is cheaper in every dimension. Here's the side-by-side:</p>

          <div class="vs-table-wrap">
            <table class="vs-table">
              <thead>
                <tr>
                  <th>Cost Item</th>
                  <th class="th-cr1">CR-1</th>
                  <th class="th-k1">K-1 Path</th>
                  <th class="th-save">CR-1 Saves</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Petition fee (I-130 or I-129F)</td>
                  <td class="cr1-val">$675</td>
                  <td class="k1-val">$675</td>
                  <td class="save-val">—</td>
                </tr>
                <tr>
                  <td>Visa / NVC fee</td>
                  <td class="cr1-val">$325</td>
                  <td class="k1-val">$265</td>
                  <td class="save-val minus">–$60</td>
                </tr>
                <tr>
                  <td>Medical exam(s)</td>
                  <td class="cr1-val">1 × ~$250</td>
                  <td class="k1-val">2 × ~$275</td>
                  <td class="save-val plus">+$300</td>
                </tr>
                <tr>
                  <td>I-485 Adjustment of Status</td>
                  <td class="cr1-val cr1-none">Not needed ✓</td>
                  <td class="k1-val">$1,440</td>
                  <td class="save-val plus">+$1,440</td>
                </tr>
                <tr>
                  <td>USCIS Immigrant Fee</td>
                  <td class="cr1-val">$220</td>
                  <td class="k1-val">—</td>
                  <td class="save-val minus">–$220</td>
                </tr>
                <tr>
                  <td>I-751 Remove Conditions</td>
                  <td class="cr1-val">$750</td>
                  <td class="k1-val">$750</td>
                  <td class="save-val">—</td>
                </tr>
                <tr>
                  <td>Attorney fees (typical)</td>
                  <td class="cr1-val">$1,500–$3,000</td>
                  <td class="k1-val">$2,000–$5,000</td>
                  <td class="save-val plus">+$500–$2,000</td>
                </tr>
              </tbody>
              <tfoot>
                <tr class="vs-total">
                  <td><strong>Government fees total</strong></td>
                  <td class="cr1-val"><strong>~$2,220</strong></td>
                  <td class="k1-val"><strong>~$3,680</strong></td>
                  <td class="save-val plus"><strong>+$1,460</strong></td>
                </tr>
                <tr class="vs-realistic">
                  <td><strong>Realistic total (incl. attorney)</strong></td>
                  <td class="cr1-val"><strong>$3,500–$7K</strong></td>
                  <td class="k1-val"><strong>$5,000–$10K+</strong></td>
                  <td class="save-val plus"><strong>$1.5K–$3K+</strong></td>
                </tr>
              </tfoot>
            </table>
          </div>

          <div class="when-k1-worth-it">
            <h3>When is K-1 worth the extra cost?</h3>
            <div class="wk-grid">
              <div class="wk-yes">
                <div class="wk-label">✅ Choose K-1 if…</div>
                <ul>
                  <li>You're not married yet and want to marry in the U.S.</li>
                  <li>Faster U.S. entry matters more than total cost</li>
                  <li>Your fiancé(e) needs to get to the U.S. urgently</li>
                  <li>You prefer a specific U.S. wedding venue</li>
                </ul>
              </div>
              <div class="wk-no">
                <div class="wk-label">✅ Choose CR-1 if…</div>
                <ul>
                  <li>You're already married</li>
                  <li>Minimizing total cost is a priority</li>
                  <li>You can wait the extra months for entry</li>
                  <li>You want one streamlined process instead of two</li>
                </ul>
              </div>
            </div>
          </div>
        </section>

        <!-- Ways to save -->
        <section id="save-money" class="content-section">
          <h2>5 Ways to Reduce Your CR-1 Total Cost</h2>
          <div class="save-list">
            <div class="sl-item">
              <div class="sl-num">01</div>
              <div>
                <h3>Wait until the marriage is 2 years old before filing</h3>
                <p>If your marriage will be 2+ years old by the time the I-130 is approved (~12–18 months from now), you'll receive an IR-1 instead of a CR-1 — skipping the I-751 entirely. <strong>Save $750</strong> in filing fees and avoid the 24–36 month I-751 processing wait.</p>
                <div class="sl-save">Potential savings: $750+</div>
              </div>
            </div>
            <div class="sl-item">
              <div class="sl-num">02</div>
              <div>
                <h3>Use a guided self-filing platform</h3>
                <p>For straightforward cases — no prior denials, no criminal history, no prior immigration issues — platforms like Boundless, RapidVisa, or FileRight prepare and review every form for $299–$499. That's $1,000–$2,500 less than a full attorney retainer.</p>
                <div class="sl-save">Potential savings: $1,000–$2,500</div>
              </div>
            </div>
            <div class="sl-item">
              <div class="sl-num">03</div>
              <div>
                <h3>Get vaccinations outside the panel physician</h3>
                <p>Panel physicians charge clinic rates for vaccines — often $30–$60 per shot vs. $10–$25 at a local pharmacy or health clinic. Get your vaccination records updated before the medical appointment and avoid paying the panel's markup.</p>
                <div class="sl-save">Potential savings: $100–$300</div>
              </div>
            </div>
            <div class="sl-item">
              <div class="sl-num">04</div>
              <div>
                <h3>File accurately the first time</h3>
                <p>An RFE (Request for Evidence) or denied petition doesn't trigger a refund — you pay fees again to refile. A careful first submission with complete supporting documents avoids paying $675 or more twice. Take the time to double-check every field.</p>
                <div class="sl-save">Avoids: $675–$1,000 in repeat fees</div>
              </div>
            </div>
            <div class="sl-item">
              <div class="sl-num">05</div>
              <div>
                <h3>Translate documents yourself</h3>
                <p>USCIS and the NVC require certified translations but do not require a professional agency. Any bilingual person who certifies their own competence can translate. For complex legal documents (divorce decrees, court orders), professional translation is worth the cost — but simple birth certificates and marriage certificates can be done in-house.</p>
                <div class="sl-save">Potential savings: $100–$250</div>
              </div>
            </div>
          </div>

          <!-- Bottom conversion block -->
          <div class="bottom-cta">
            <div class="bc-dark">
              <div class="bc-content">

---
import Base from '../layouts/Base.astro';
import SmartLink from '../components/SmartLink.astro';

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "K-1 Visa Sponsor Requirements 2026: Complete Petitioner Eligibility Guide",
    "description": "Everything the U.S. citizen petitioner must qualify for to sponsor a K-1 fiancé visa — citizenship, in-person meeting rule, financial requirements, criminal bars, and the I-129F filing.",
    "url": "https://ldrvisa.org/sponsor-requirements-k1-visa",
    "dateModified": "2026-04-30",
    "datePublished": "2026-04-30",
    "author": { "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org" },
    "publisher": {
      "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org",
      "logo": { "@type": "ImageObject", "url": "https://ldrvisa.org/favicon.svg" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://ldrvisa.org/sponsor-requirements-k1-visa" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ldrvisa.org/" },
      { "@type": "ListItem", "position": 2, "name": "K-1 Fiancé Visa", "item": "https://ldrvisa.org/k1-visa" },
      { "@type": "ListItem", "position": 3, "name": "Sponsor Requirements", "item": "https://ldrvisa.org/sponsor-requirements-k1-visa" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Can a green card holder sponsor a K-1 visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Only U.S. citizens can petition for a K-1 fiancé visa. Lawful permanent residents (green card holders) cannot file a K-1 petition regardless of how long they have held their green card. LPRs who want to bring a foreign spouse to the U.S. must use the CR-1 spousal visa or F-2A immigrant visa category, both of which take longer."
        }
      },
      {
        "@type": "Question",
        "name": "What if I don't meet the income requirement for the K-1 visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If your income falls below 100% of the federal poverty guideline for your household size, you have several options: (1) Use a joint sponsor — a U.S. citizen or LPR who independently meets the income requirement and files a separate I-134 on your behalf; (2) Supplement with assets — liquid assets such as bank savings, stocks, or retirement funds can offset insufficient income; (3) Include household member income — if someone living with you has income, they may be able to co-sign. The consular officer makes the final determination on financial ability at the K-1 interview."
        }
      },
      {
        "@type": "Question",
        "name": "What is the 2-year in-person meeting rule for the K-1 visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "U.S. law requires that the petitioner and beneficiary have physically met each other in person within the two years immediately preceding the filing of the I-129F petition. A video call, phone call, or online meeting does not satisfy this requirement — physical presence in the same location is mandatory. Waivers are available only on the grounds of extreme hardship to the petitioner or if meeting in person would violate strict and long-established customs of the beneficiary's culture or religion."
        }
      },
      {
        "@type": "Question",
        "name": "How many K-1 petitions can I file in my lifetime?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "There is no absolute numerical cap, but USCIS tracks all prior K-1 petitions you have filed. If you have had two or more prior K-1 petitions approved, USCIS will scrutinize your new petition heavily and may request extensive evidence that your current relationship is genuine. Additionally, under IMBRA, if you met your fiancé(e) through an international marriage broker, USCIS limits you to two K-1 approvals in your lifetime without a waiver."
        }
      },
      {
        "@type": "Question",
        "name": "What is the Adam Walsh Act and how does it affect K-1 sponsorship?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Adam Walsh Child Protection and Safety Act permanently bars anyone convicted of a 'specified offense against a minor' from petitioning for a K-1 visa. Specified offenses include sexual abuse, exploitation, kidnapping, and other crimes against minors. This bar applies even if the conviction was expunged, the sentence was suspended, or significant time has passed. Unlike some other immigration bars, there is no waiver available for this bar in the K-1 context — it is an absolute prohibition."
        }
      },
      {
        "@type": "Question",
        "name": "Do I need a lawyer to file the I-129F petition?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You are not legally required to hire an attorney to file Form I-129F. Many couples successfully self-file the K-1 petition. However, an immigration attorney is strongly recommended if: you have a criminal history of any kind, you have filed prior K-1 petitions, your income is borderline or you need a joint sponsor, there are any prior immigration violations, or your situation involves cultural/religious hardship waiver for the in-person meeting requirement. Attorney fees typically range from $1,500 to $3,500 for the I-129F filing. USCIS's filing fee for I-129F is $675."
        }
      }
    ]
  }
]);
---

<Base
  title="K-1 Visa Sponsor Requirements 2026 — Complete Petitioner Eligibility Guide"
  description="Are you eligible to sponsor a K-1 fiancé visa? Citizenship, in-person meeting rule, income requirements, criminal bars, and the I-129F — everything the petitioner must qualify for."
  schema={schema}
>

<style>
  /* Breadcrumb */
  .breadcrumb-bar { background: var(--color-surface); border-bottom: 1px solid var(--color-border); padding: 10px 0; }
  .breadcrumb { display: flex; align-items: center; gap: 8px; list-style: none; font-size: 0.8125rem; color: var(--color-muted); flex-wrap: wrap; }
  .breadcrumb li:not(:last-child)::after { content: '/'; margin-left: 8px; }
  .breadcrumb a { color: var(--color-accent); }

  /* Hero */
  .page-hero {
    padding: 56px 0 48px;
    text-align: center;
    background: linear-gradient(180deg, #dbeafe 0%, #fff 100%);
    border-bottom: 1px solid var(--color-border);
  }
  .hero-badge {
    display: inline-block;
    background: #1e40af;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 20px;
    margin-bottom: 18px;
  }
  .page-hero h1 {
    font-size: clamp(1.75rem, 4vw, 2.875rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 16px;
    color: #1e3a8a;
  }
  .page-hero h1 span { color: #1e40af; }
  .hero-sub {
    font-size: 1.0625rem;
    color: var(--color-muted);
    max-width: 620px;
    margin: 0 auto 32px;
    line-height: 1.7;
  }

  /* Eligibility quick-check bar */
  .eligibility-bar {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
    max-width: 760px;
    margin: 0 auto;
    border: 2px solid #1e40af;
    border-radius: 12px;
    overflow: hidden;
    background: #fff;
  }
  .elig-item {
    flex: 1;
    min-width: 160px;
    padding: 16px 18px;
    text-align: center;
    border-right: 1px solid #bfdbfe;
    background: #fff;
  }
  .elig-item:last-child { border-right: none; }
  .elig-check {
    display: block;
    font-size: 1.25rem;
    line-height: 1;
    margin-bottom: 6px;
  }
  .elig-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    color: #1e3a8a;
    line-height: 1.3;
  }

  /* Layout */
  .content-wrap { display: grid; grid-template-columns: 1fr 300px; gap: 48px; padding: 48px 0 80px; align-items: start; }
  .main-col {}
  .content-section { margin-bottom: 3rem; }
  .content-section h2 {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #dbeafe;
    color: #1e3a8a;
  }
  .content-section h3 { font-size: 1.1rem; font-weight: 700; margin: 1.25rem 0 0.5rem; color: var(--color-text); }
  .content-section p { color: var(--color-muted); line-height: 1.7; margin-bottom: 0.75rem; }

  /* Core requirement cards */
  .req-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 1.25rem; }
  .req-card {
    border-radius: 12px;
    padding: 1.375rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .req-card-citizenship { background: #eff6ff; border: 2px solid #1e40af; }
  .req-card-met       { background: #f0fdf4; border: 2px solid #16a34a; }
  .req-card-free      { background: #fffbeb; border: 2px solid #d97706; }
  .req-card-intent    { background: #fdf4ff; border: 2px solid #9333ea; }
  .req-card-num {
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.6;
  }
  .req-card-citizenship .req-card-num { color: #1e40af; }
  .req-card-met .req-card-num       { color: #16a34a; }
  .req-card-free .req-card-num      { color: #d97706; }
  .req-card-intent .req-card-num    { color: #9333ea; }
  .req-card h3 { font-size: 1rem; font-weight: 800; margin: 0; color: var(--color-text); }
  .req-card p { font-size: 0.8375rem; color: var(--color-muted); margin: 0; line-height: 1.6; }
  .req-card-icon { font-size: 1.5rem; line-height: 1; }

  /* Alert boxes */
  .alert-box { display: flex; gap: 12px; border-radius: 10px; padding: 1rem 1.25rem; margin: 1rem 0; }
  .alert-warning { background: #fffbeb; border: 1px solid #fde68a; }
  .alert-info    { background: #eff6ff; border: 1px solid #bfdbfe; }
  .alert-danger  { background: #fef2f2; border: 1px solid #fecaca; }
  .alert-icon { font-size: 1.25rem; flex-shrink: 0; margin-top: 2px; }
  .alert-box strong { display: block; font-weight: 700; margin-bottom: 4px; font-size: 0.9375rem; color: var(--color-text); }
  .alert-box p { font-size: 0.875rem; color: var(--color-muted); margin: 0; line-height: 1.6; }

  /* Income table */
  .income-table-wrap { border: 1px solid var(--color-border); border-radius: 10px; overflow: hidden; margin-top: 1.25rem; }
  .income-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  .income-table th { background: #1e40af; color: #fff; padding: 11px 14px; text-align: left; font-weight: 700; }
  .income-table .th-sub { font-size: 0.7rem; font-weight: 400; opacity: 0.8; display: block; }
  .income-table td { padding: 10px 14px; border-bottom: 1px solid var(--color-border); color: var(--color-muted); vertical-align: middle; }
  .income-table tr:last-child td { border-bottom: none; }
  .income-table tr:nth-child(even) td { background: #f8fafc; }
  .col-highlight { background: #dbeafe !important; color: #1e3a8a !important; font-weight: 700; }
  .hh-note { font-size: 0.7rem; font-weight: 400; color: var(--color-muted); }
  .add-row td { font-size: 0.78rem; color: var(--color-muted); background: var(--color-surface) !important; padding: 7px 14px; }

  /* Income sources */
  .income-sources-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 1rem; }
  .income-col { border-radius: 10px; padding: 1.25rem; }
  .income-yes { background: #f0fdf4; border: 1px solid #86efac; }
  .income-no  { background: #fef2f2; border: 1px solid #fecaca; }
  .income-col h3 { font-size: 0.9375rem; font-weight: 700; margin-bottom: 0.75rem; }
  .income-col ul { list-style: none; display: flex; flex-direction: column; gap: 5px; }
  .income-col li { font-size: 0.8375rem; color: var(--color-muted); padding-left: 1.1rem; position: relative; line-height: 1.45; }
  .income-yes li::before { content: '✓'; position: absolute; left: 0; color: #16a34a; font-weight: 700; font-size: 0.75rem; }
  .income-no  li::before { content: '✗'; position: absolute; left: 0; color: #dc2626; font-weight: 700; font-size: 0.75rem; }

  /* Mid-page CTA */
  .mid-cta {
    background: #eff6ff;
    border: 1px solid #bfdbfe;
    border-radius: 14px;
    padding: 1.75rem 2rem;
    margin: 2.5rem 0;
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }
  .mid-cta-icon { font-size: 2.5rem; flex-shrink: 0; }
  .mid-cta h3 { font-size: 1.125rem; font-weight: 800; color: #1e3a8a; margin-bottom: 6px; }
  .mid-cta p { font-size: 0.9rem; color: var(--color-muted); margin-bottom: 14px; line-height: 1.6; }
  .mid-cta-btns { display: flex; gap: 10px; flex-wrap: wrap; }
  .btn-primary {
    display: inline-block;
    background: #1e40af;
    color: #fff;
    font-weight: 700;
    font-size: 0.875rem;
    padding: 10px 20px;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s;
  }
  .btn-primary:hover { background: #1e3a8a; }
  .btn-outline {
    display: inline-block;
    background: transparent;
    color: #1e40af;
    font-weight: 700;
    font-size: 0.875rem;
    padding: 9px 20px;
    border-radius: 8px;
    border: 2px solid #1e40af;
    text-decoration: none;
    transition: all 0.15s;
  }
  .btn-outline:hover { background: #1e40af; color: #fff; }

  /* Document list */
  .doc-checklist { display: flex; flex-direction: column; gap: 18px; margin-top: 1rem; }
  .doc-cat { border: 1px solid var(--color-border); border-radius: 12px; overflow: hidden; }
  .doc-cat-header { display: flex; align-items: center; gap: 10px; padding: 0.875rem 1.25rem; background: var(--color-surface); border-bottom: 1px solid var(--color-border); }
  .doc-cat-icon { font-size: 1.125rem; }
  .doc-cat-header h3 { font-size: 0.9375rem; font-weight: 700; margin: 0; }
  .doc-items { padding: 0.25rem 0; }
  .doc-item { display: flex; align-items: flex-start; gap: 12px; padding: 0.8rem 1.25rem; border-bottom: 1px solid var(--color-border); }
  .doc-item:last-child { border-bottom: none; }
  .doc-check {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    background: #dbeafe;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    color: #1e40af;
    font-weight: 700;
    margin-top: 1px;
  }
  .doc-item strong { font-size: 0.875rem; display: block; margin-bottom: 2px; }
  .doc-item p { font-size: 0.8rem; color: var(--color-muted); margin: 0; line-height: 1.5; }

  /* Criminal bars */
  .bar-cards { display: flex; flex-direction: column; gap: 16px; margin-top: 1.25rem; }
  .bar-card {
    border-radius: 10px;
    border-left: 4px solid #dc2626;
    background: #fef2f2;
    padding: 1.125rem 1.375rem;
  }
  .bar-card h3 { font-size: 0.9375rem; font-weight: 800; color: #991b1b; margin-bottom: 6px; }
  .bar-card p { font-size: 0.875rem; color: var(--color-muted); margin: 0; line-height: 1.6; }

  /* I-129F steps */
  .process-steps { display: flex; flex-direction: column; gap: 0; border: 1px solid var(--color-border); border-radius: 12px; overflow: hidden; margin-top: 1.25rem; }
  .process-step { display: flex; align-items: flex-start; gap: 16px; padding: 1.125rem 1.375rem; border-bottom: 1px solid var(--color-border); background: #fff; }
  .process-step:last-child { border-bottom: none; }
  .step-num {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    background: #1e40af;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 0.875rem;
    margin-top: 1px;
  }
  .process-step strong { font-size: 0.9375rem; display: block; margin-bottom: 4px; }
  .process-step p { font-size: 0.8375rem; color: var(--color-muted); margin: 0; line-height: 1.55; }

  /* Split table (petitioner vs beneficiary) */
  .split-table-wrap { border: 1px solid var(--color-border); border-radius: 10px; overflow: hidden; margin-top: 1.25rem; }
  .split-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  .split-table th { padding: 12px 16px; text-align: left; font-weight: 800; font-size: 0.8125rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .split-table th:first-child { background: #1e40af; color: #fff; width: 50%; }
  .split-table th:last-child  { background: #16a34a; color: #fff; }
  .split-table td { padding: 10px 16px; border-top: 1px solid var(--color-border); vertical-align: top; font-size: 0.8375rem; color: var(--color-muted); }
  .split-table td:first-child { border-right: 1px solid var(--color-border); background: #eff6ff; }
  .split-table td:last-child { background: #f0fdf4; }
  .split-table td strong { color: var(--color-text); }

  /* Disqualifier checklist */
  .disq-list { display: flex; flex-direction: column; gap: 0; border: 1px solid #fecaca; border-radius: 10px; overflow: hidden; margin-top: 1.25rem; }
  .disq-item { display: flex; align-items: flex-start; gap: 14px; padding: 1rem 1.25rem; border-bottom: 1px solid #fecaca; background: #fff; }
  .disq-item:last-child { border-bottom: none; }
  .disq-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    background: #fee2e2;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 800;
    color: #dc2626;
    margin-top: 1px;
  }
  .disq-item strong { font-size: 0.9rem; display: block; margin-bottom: 2px; }
  .disq-item p { font-size: 0.8125rem; color: var(--color-muted); margin: 0; line-height: 1.5; }

  /* FAQ */
  .faq-list { display: flex; flex-direction: column; gap: 0; border: 1px solid var(--color-border); border-radius: 10px; overflow: hidden; }
  .faq-item { border-bottom: 1px solid var(--color-border); }
  .faq-item:last-child { border-bottom: none; }
  .faq-item summary {
    padding: 1rem 1.25rem;
    font-weight: 600;
    cursor: pointer;
    font-size: 0.9375rem;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--color-text);
  }
  .faq-item summary::after { content: '+'; color: #1e40af; font-size: 1.25rem; font-weight: 300; flex-shrink: 0; }
  .faq-item[open] summary::after { content: '−'; }
  .faq-item p { padding: 0 1.25rem 1rem; color: var(--color-muted); font-size: 0.9rem; line-height: 1.7; margin: 0; }

  /* LPR callout */
  .lpr-callout {
    background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%);
    border-radius: 14px;
    padding: 1.75rem 2rem;
    color: #fff;
    margin: 2rem 0;
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }
  .lpr-callout-icon { font-size: 2rem; flex-shrink: 0; margin-top: 2px; }
  .lpr-callout h3 { font-size: 1.125rem; font-weight: 800; margin-bottom: 8px; }
  .lpr-callout p { font-size: 0.9rem; opacity: 0.9; margin-bottom: 12px; line-height: 1.6; }
  .lpr-callout a { color: #93c5fd; font-weight: 700; text-decoration: underline; }

  /* Bottom CTA */
  .bottom-cta {
    background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%);
    border-radius: 16px;
    padding: 2.5rem 2rem;
    color: #fff;
    text-align: center;
    margin: 2.5rem 0 1rem;
  }
  .bottom-cta h2 { font-size: 1.5rem; font-weight: 800; margin-bottom: 10px; color: #fff; border: none; padding: 0; }
  .bottom-cta p { font-size: 1rem; opacity: 0.9; max-width: 520px; margin: 0 auto 1.5rem; line-height: 1.6; }
  .bottom-cta-btns { display: flex; justify-content: center; gap: 14px; flex-wrap: wrap; }
  .btn-white {
    display: inline-block;
    background: #fff;
    color: #1e40af;
    font-weight: 800;
    font-size: 0.9375rem;
    padding: 13px 28px;
    border-radius: 10px;
    text-decoration: none;
    transition: all 0.15s;
  }
  .btn-white:hover { background: #dbeafe; }
  .btn-ghost-white {
    display: inline-block;
    background: transparent;
    color: #fff;
    font-weight: 700;
    font-size: 0.9375rem;
    padding: 11px 28px;
    border-radius: 10px;
    border: 2px solid rgba(255,255,255,0.6);
    text-decoration: none;
    transition: all 0.15s;
  }
  .btn-ghost-white:hover { background: rgba(255,255,255,0.12); }

  /* Related guides */
  .related-guides { margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--color-border); }
  .related-guides h2 { font-size: 1.25rem; font-weight: 800; margin-bottom: 1rem; }
  .related-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }

  /* Sidebar */
  .sidebar { display: flex; flex-direction: column; gap: 20px; position: sticky; top: 80px; }
  .sidebar-card { background: #fff; border: 1px solid var(--color-border); border-radius: 10px; overflow: hidden; }
  .sidebar-card-title {
    padding: 12px 18px;
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
  }
  .sidebar-card.sidebar-blue { border-color: #93c5fd; }
  .sidebar-card.sidebar-blue .sidebar-card-title { background: #dbeafe; color: #1e3a8a; border-color: #93c5fd; }

  .sidebar-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 9px 18px;
    font-size: 0.875rem;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    transition: background 0.1s;
  }
  .sidebar-link:last-child { border-bottom: none; }
  .sidebar-link:hover { background: #eff6ff; color: #1e40af; }
  .sidebar-link span { color: var(--color-muted); font-size: 0.75rem; }

  /* Eligibility summary in sidebar */
  .elig-summary { display: flex; flex-direction: column; }
  .elig-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 18px;

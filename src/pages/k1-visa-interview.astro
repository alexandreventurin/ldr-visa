  .hero-meta-item { font-size: 0.8125rem; color: #60a5fa; font-weight: 600; }

  .content-layout { display: grid; grid-template-columns: 1fr 280px; gap: 48px; padding: 56px 0 80px; align-items: start; }
  @media (max-width: 900px) { .content-layout { grid-template-columns: 1fr; } .sidebar { display: none; } }

  .article h2 { font-size: 1.625rem; font-weight: 800; letter-spacing: -0.02em; margin: 48px 0 16px; padding-top: 48px; border-top: 1px solid var(--color-border); }
  .article h2:first-child { margin-top: 0; padding-top: 0; border-top: none; }
  .article h3 { font-size: 1.125rem; font-weight: 700; margin: 28px 0 12px; color: var(--color-accent); }
  .article p { font-size: 1rem; line-height: 1.75; color: #374151; margin-bottom: 16px; }
  .article ul, .article ol { margin: 12px 0 20px 20px; display: flex; flex-direction: column; gap: 8px; }
  .article li { font-size: 1rem; line-height: 1.65; color: #374151; }
  .article a { color: var(--color-accent); text-decoration: underline; text-underline-offset: 3px; }
  .article strong { color: var(--color-text); font-weight: 700; }

  /* Key stats */
  .key-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 14px; margin: 28px 0; }
  .stat-box { background: var(--color-accent-light); border: 1px solid #bfdbfe; border-radius: 10px; padding: 18px; text-align: center; }
  .stat-box .num { font-size: 1.75rem; font-weight: 800; color: var(--color-accent); letter-spacing: -0.03em; line-height: 1; margin-bottom: 4px; }
  .stat-box .label { font-size: 0.8125rem; color: #1e40af; font-weight: 600; line-height: 1.4; }

  /* Checklist */
  .checklist { margin: 20px 0; border: 1px solid var(--color-border); border-radius: 10px; overflow: hidden; }
  .checklist-section { border-bottom: 1px solid var(--color-border); }
  .checklist-section:last-child { border-bottom: none; }
  .checklist-head { padding: 12px 18px; background: var(--color-surface); font-size: 0.8125rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-muted); }
  .checklist-items { padding: 6px 0; }

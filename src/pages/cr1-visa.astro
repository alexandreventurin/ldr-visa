---
import Base from '../layouts/Base.astro';
import SmartLink from '../components/SmartLink.astro';

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "CR-1 Spousal Visa: Complete Guide for 2026",
    "description": "Everything about the CR-1 spousal visa — requirements, processing time, costs, documents, NVC process, and what happens after you arrive in the U.S.",
    "url": "https://ldrvisa.org/cr1-visa",
    "dateModified": "2026-04-27",
    "datePublished": "2026-04-27",
    "author": { "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org" },
    "publisher": {
      "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org",
      "logo": { "@type": "ImageObject", "url": "https://ldrvisa.org/favicon.svg" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://ldrvisa.org/cr1-visa" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ldrvisa.org/" },
      { "@type": "ListItem", "position": 2, "name": "CR-1 Spousal Visa", "item": "https://ldrvisa.org/cr1-visa" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the difference between CR-1 and IR-1?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "CR-1 (Conditional Resident) is issued when your marriage is less than 2 years old at visa approval — you get a 2-year green card and must file I-751 to remove conditions. IR-1 (Immediate Relative) is issued when the marriage is 2+ years old at approval — you get a 10-year permanent green card with no conditions to remove."
        }
      },
      {
        "@type": "Question",
        "name": "How long does the CR-1 visa take in 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The CR-1 visa typically takes 14–24 months total in 2026: 8–14 months for USCIS to approve the I-130 petition, 2–3 months for NVC processing, and 1–3 months for the consular appointment and visa issuance."
        }
      },
      {
        "@type": "Question",
        "name": "Can a green card holder (LPR) file for a CR-1 visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, but there is a key difference. Spouses of U.S. citizens are 'immediate relatives' with no visa backlog. Spouses of LPRs (green card holders) are in the F2A preference category and must wait for a visa number to become available, which can add years to the process."
        }
      },
      {
        "@type": "Question",
        "name": "Do I need to attend an interview for the CR-1 visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. The foreign spouse attends an in-person interview at the U.S. embassy or consulate in their home country. The U.S. citizen spouse does not typically need to attend the consular interview, though some embassies may request their presence."
        }
      },
      {
        "@type": "Question",
        "name": "What happens after I enter the U.S. on a CR-1 visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You enter as a conditional permanent resident. Your green card (Form I-551) is mailed to your U.S. address within a few weeks. If you receive a CR-1 (conditional), you must file Form I-751 (Petition to Remove Conditions) jointly with your spouse within the 90-day window before your 2-year anniversary."
        }
      },
      {
        "@type": "Question",
        "name": "What is the income requirement for the CR-1 visa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The U.S. citizen or LPR sponsor must earn at least 125% of the federal poverty level for their household size. For a household of 2 in 2026, that is $25,550 per year. This is demonstrated by filing Form I-864 (Affidavit of Support)."
        }
      }
    ]
  }
]);

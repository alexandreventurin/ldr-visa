---
import Base from '../layouts/Base.astro';
import SmartLink from '../components/SmartLink.astro';

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Form I-129F: Complete Guide, Instructions &amp; Checklist (2026)",
    "description": "How to fill out Form I-129F to petition for a K-1 fiancé visa — step-by-step instructions, document checklist, sample answers, and common mistakes to avoid.",
    "url": "https://ldrvisa.org/i-129f",
    "dateModified": "2026-04-27",
    "datePublished": "2026-04-27",
    "author": { "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org" },
    "publisher": {
      "@type": "Organization", "name": "LDR Visa", "url": "https://ldrvisa.org",
      "logo": { "@type": "ImageObject", "url": "https://ldrvisa.org/favicon.svg" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://ldrvisa.org/i-129f" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ldrvisa.org/" },
      { "@type": "ListItem", "position": 2, "name": "Form I-129F", "item": "https://ldrvisa.org/i-129f" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Who files Form I-129F?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The U.S. citizen petitioner files Form I-129F — not the foreign fiancé(e). The petitioner must be a U.S. citizen (not a green card holder). The form initiates the K-1 fiancé visa petition with USCIS."
        }
      },
      {
        "@type": "Question",
        "name": "Can I file Form I-129F online?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. As of 2026, Form I-129F cannot be filed online. It must be printed, signed, and mailed by paper to the USCIS Dallas Lockbox facility, regardless of where in the U.S. the petitioner lives."
        }
      },
      {
        "@type": "Question",
        "name": "How long does USCIS take to process Form I-129F?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "USCIS currently processes Form I-129F in approximately 7–14 months at the California and Vermont Service Centers. Processing times fluctuate — check the current estimate at egov.uscis.gov/processing-times."
        }
      },
      {
        "@type": "Question",
        "name": "What is the filing fee for Form I-129F?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The USCIS filing fee for Form I-129F is $675, effective April 2024. Make the check or money order payable to 'U.S. Department of Homeland Security.' Personal checks and money orders are accepted; credit cards are not accepted for paper filings."
        }
      },
      {
        "@type": "Question",
        "name": "What is the in-person meeting requirement for I-129F?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Both the petitioner (U.S. citizen) and the beneficiary (foreign fiancé) must have met in person within 2 years before filing the I-129F. If you haven't met in person yet, you must do so before filing — there is no exception for this requirement except on specific religious or cultural grounds."
        }
      },
      {
        "@type": "Question",
        "name": "What happens after USCIS approves the I-129F?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "USCIS sends the approval notice and transfers the case to the National Visa Center (NVC), which then forwards it to the U.S. embassy in the fiancé's country. The embassy schedules a visa interview. The full timeline from I-129F approval to visa in hand is typically 3–6 more months."
        }
      }
    ]
  }
]);
